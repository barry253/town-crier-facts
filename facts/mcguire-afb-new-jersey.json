  "facts": [
    {
      "id": 1,
      "text": "McGuire Air Force Base was renamed on 13 January 1948 to honor Major Thomas Buchanan McGuire Jr., a World War II pilot.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/McGuire_Air_Force_Base"
    },
    {
      "id": 2,
      "text": "The airfield began as Rudd Field in 1937, became Fort Dix Army Air Base in 1939, and expanded rapidly before World War II.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/McGuire_Air_Force_Base"
    },
    {
      "id": 3,
      "text": "On 1 October 2009, McGuire merged with Fort Dix and Naval Air Engineering Station Lakehurst to form Joint Base McGuire‑Dix‑Lakehurst.",
      "sourceSentenceIds": [
        20
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/McGuire_Air_Force_Base"
    },
    {
      "id": 4,
      "text": "The 87th Air Base Wing, headquartered at McGuire, manages all operations for the entire joint base.",
      "sourceSentenceIds": [
        21
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/McGuire_Air_Force_Base"
    },
    {
      "id": 5,
      "text": "During the Cold War, McGuire hosted a SAGE radar center that linked U.S. air defenses into a single command network.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/McGuire_Air_Force_Base"
    },
    {
      "id": 6,
      "text": "When the Bomarc missile site closed, McGuire became the sole Aerospace Defense Command installation in the area.",
      "sourceSentenceIds": [
        4
