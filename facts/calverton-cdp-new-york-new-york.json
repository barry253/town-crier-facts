    {
      "id": 3,
      "text": "The Navy bought 6,000 acres around Calverton in 1953 so Grumman could test and finish jets.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Calverton%2C_New_York"
    },
    {
      "id": 4,
      "text": "Calverton’s roots trace back to farmland and pine barrens, but its most defining role came when it became home to Grumman’s Naval Weapons Industrial Reserve Plant.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
