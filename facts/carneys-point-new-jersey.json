  "facts": [
    {
      "id": 1,
      "text": "Carneys Point got its name from Thomas Carney, a 17th‑century landowner whose estate grew so large the point of land was named after him.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/carneys_point_cdp_new_jersey"
    },
    {
      "id": 2,
      "text": "Before becoming its own township, the area that is now Carneys Point was part of Upper Penns Neck Township, created in 1721.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/carneys_point_cdp_new_jersey"
    },
    {
      "id": 3,
      "text": "The Delaware River borders Carneys Point to the west, and its tidal flows influence nearby tributaries like Whooping John Creek and Hanby Creek.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/carneys_point_cdp_new_jersey"
    },
    {
      "id": 4,
      "text": "Carneys Point has long been a chemical manufacturing hub, with the Chemours Company—formerly part of DuPont—operating a major facility there since the early 20th century.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/carneys_point_cdp_new_jersey"
    },
    {
      "id": 5,
      "text": "The area sits at sea level to about 50 feet, experiencing a humid subtropical climate with hot, humid summers and mild winters.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 1"
      ],
