  "facts": [
    {
      "id": 1,
      "text": "National Park borough hosts Fort Mercer, a Revolutionary War fort built by George Washington’s Continental Army to block Philadelphia’s approach.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.njtgo.com/towns/N/National%20Park/National_Park.html"
    },
    {
      "id": 2,
      "text": "Fort Mercer was named after Brigadier General Hugh Mercer, who died earlier that year at the Battle of Princeton.",
      "sourceSentenceIds": [
        4,
        5
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://www.nationalparknj.com/how_do_i/learn_about/about_national_park.php"
    },
    {
      "id": 3,
      "text": "Across the Delaware River, Washington’s forces also constructed Fort Mifflin on the Pennsylvania side, mirroring Fort Mercer’s defensive role.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.njtgo.com/towns/N/National%20Park/National_Park.html"
    },
    {
      "id": 4,
      "text": "The two forts together formed a critical river blockade that delayed the British advance toward Philadelphia during the war.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.njtgo.com/towns/N/National%20Park/National_Park.html"
    },
    {
      "id": 5,
      "text": "Fort Mercer’s location on the Delaware River made it a key point in controlling river traffic during the Revolutionary War.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.njtgo.com/towns/N/National%20Park/National_Park.html"
    },
    {
      "id": 6,
      "text": "The fort’s construction in 1777 marked the first major Continental Army effort to secure the Delaware River corridor.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.njtgo.com/towns/N/National%20Park/National_Park.html"
