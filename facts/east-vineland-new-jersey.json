  "facts": [
    {
      "id": 1,
      "text": "Vineland began in the mid‑1800s as a utopian temperance community that forbade the sale and consumption of alcohol.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.wisdomlib.org/cities/east-vineland-105553"
    },
    {
      "id": 2,
      "text": "The city’s name comes from its fertile soil, chosen to attract Italian grape growers to the land of vines.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://cumberlandcountyhome.com/the-history-of-vineland-new-jersey/"
    },
    {
      "id": 3,
      "text": "In 1864 the Vineland Historical and Antiquarian Society opened, becoming one of New Jersey’s oldest historical societies.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://cumberlandcountyhome.com/the-history-of-vineland-new-jersey/"
    },
    {
      "id": 4,
      "text": "The Vineland Cooperative Produce Auction, founded in 1931, still operates as the East Coast’s largest farmer’s cooperative.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://cumberlandcountyhome.com/the-history-of-vineland-new-jersey/"
    },
    {
      "id": 5,
      "text": "By 1862 the first houses appeared and a railroad linked Vineland to Philadelphia and New York, sparking rapid growth.",
      "sourceSentenceIds": [
        19
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://cumberlandcountyhome.com/the-history-of-vineland-new-jersey/"
    },
    {
      "id": 6,
      "text": "East Vineland is a residential census‑designated place within Vineland, sharing the area’s agricultural heritage while standing alone on the map.",
