  "facts": [
    {
      "id": 1,
      "text": "Winter Beach grew from a pineapple boom that began when Danish immigrant John Laurence Jensen planted the first grove in 1881.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Jensen_Beach%2C_Florida"
    },
    {
      "id": 2,
      "text": "By 1895 the area was nicknamed the “Pineapple Capital of the World,” shipping over a million boxes each summer.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Jensen_Beach%2C_Florida"
    },
    {
      "id": 3,
      "text": "The Florida East Coast Railway reached Winter Beach in 1894, letting farmers load pineapples directly onto freight cars.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Jensen_Beach%2C_Florida"
    },
    {
      "id": 4,
      "text": "Two devastating fires in 1908 and 1910 destroyed most of the town’s pineapple farms, prompting a shift to citrus cultivation.",
      "sourceSentenceIds": [
        14,
        15
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Jensen_Beach%2C_Florida"
    },
    {
      "id": 5,
      "text": "Today the pineapple lives on in the annual Jensen Beach Pineapple Festival, a celebration that honors the town’s historic fruit legacy.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Jensen_Beach%2C_Florida"
    },
    {
      "id": 6,
      "text": "Winter Beach sits on the Indian River Lagoon, a stretch of water that once guided Spanish treasure ships and still attracts maritime history enthusiasts.",
