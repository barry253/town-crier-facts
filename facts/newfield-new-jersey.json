  "facts": [
    {
      "id": 1,
      "text": "Newfield became a borough on February 19, 1924, after 240 residents petitioned the legislature from Trenton by special train.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.newfieldborough.org/history-2/"
    },
    {
      "id": 2,
      "text": "The town’s growth was driven by the Pennsylvania‑Reading Seashore Line and the Atlantic City spur, a double‑track line that ran straight to the shore.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.newfieldborough.org/history-2/"
    },
    {
      "id": 3,
      "text": "A glass factory once sat in the “Y” between the railroad and the Atlantic City spur, south of town.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.newfieldborough.org/history-2/"
    },
    {
      "id": 4,
      "text": "The first Newfield library began in a tiny building that had once housed the town’s fire company and an old school.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.newfieldborough.org/history-2/"
    },
    {
      "id": 5,
      "text": "The first council meeting was held on May 5, 1924, with Frank Morrell as council president and Godfrey V. as the town clerk.",
