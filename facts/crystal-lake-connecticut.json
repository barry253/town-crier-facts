  "facts": [
    {
      "id": 1,
      "text": "The lake was once called Wabbaquasset by the Nipmuc Indians, meaning 'place where cattails grow'.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://ctvisit.com/listings/crystal-lake"
    },
    {
      "id": 2,
      "text": "Before 1889, locals nicknamed it Square Pond or Ruby Lake after the garnets found in nearby hills.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://ctvisit.com/listings/crystal-lake"
    },
    {
      "id": 3,
      "text": "Crystal Lake covers about 187 acres and sits on the border between Ellington and Stafford.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Crystal_Lake%2C_Connecticut"
    },
    {
      "id": 4,
      "text": "Only one public beach, Sandy Beach, opens on the lake’s southern shore for swimmers.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Crystal_Lake%2C_Connecticut"
    },
    {
      "id": 5,
      "text": "The lake’s water is refreshed roughly once every year, keeping its ecosystem lively.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.crystallakeellingtonct.com/aboutcrystallake"
    },
    {
      "id": 6,
      "text": "With an average depth of 20 feet and a peak of 50 feet, the lake sits 637 feet above sea level.",
      "sourceSentenceIds": [
        8
