  "facts": [
    {
      "id": 1,
      "text": "Cape Vincent was named for Vincent LeRay, the son of Alexander LeRay, who commissioned the first settlement in 1809.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://capevincent.org/history/"
    },
    {
      "id": 2,
      "text": "The Cape Vincent and Rome Railroad opened in 1852, turning the village into a rail hub until the mid‑20th century.",
      "sourceSentenceIds": [
        3,
        16
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Cape_Vincent%2C_New_York"
    },
    {
      "id": 3,
      "text": "During the War of 1812, Cape Vincent served as an armed camp opposing British forces in Kingston, Ontario.",
      "sourceSentenceIds": [
        26
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Cape_Vincent%2C_New_York"
    },
    {
      "id": 4,
      "text": "The East Charity Shoals Light, erected in 1935, marks the entrance to the St. Lawrence Seaway and is on the National Register of Historic Places.",
      "sourceSentenceIds": [
        30,
        10
      ],
      "sourceLabels": [
