  "facts": [
    {
      "id": 1,
      "text": "Parsippany’s name comes from the Lenape word parsipanong, meaning “the place where the river winds through the valley.”",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Parsippany%E2%80%93Troy_Hills%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "The township was incorporated March 12 1928 from portions of Hanover Township after a May 9 referendum split off East Hanover and Parsippany–Troy Hills.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Parsippany%E2%80%93Troy_Hills%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "In the late 1600s, land speculators began buying large plots of acreage that would later become Parsippany’s core.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.parsippany.net/pages/history-of-parsippany"
    },
    {
      "id": 4,
      "text": "The Smith/Baldwin House is a Federal‑style, two‑story post‑and‑beam house built in four stages, a rare architectural gem.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://parsippanyhistoricalsociety.org/"
    },
    {
      "id": 5,
      "text": "The Bowlsby/DeGelleke House, a one‑and‑a‑half‑story clapboard farmhouse on a stone foundation, now houses the Parsippany Historical Museum.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://parsippanyhistoricalsociety.org/"
    },
    {
      "id": 6,
      "text": "Archaeologists trace Native American occupation in Parsippany back 6,000 years, when hunters and fishers used the area’s rivers.",
