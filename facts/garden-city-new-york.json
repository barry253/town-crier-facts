  "facts": [
    {
      "id": 1,
      "text": "Garden City, founded in 1869 by Alexander Turney Stewart, was one of the first planned communities in the United States.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.longislandguide.com/visit/garden-city/"
    },
    {
      "id": 2,
      "text": "The Cathedral of the Incarnation, a Gothic Revival masterpiece, stands as Garden City's historic Episcopal landmark.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.longislandguide.com/visit/garden-city/"
    },
    {
      "id": 3,
      "text": "Garden City's growth hinged on the Central Railroad of Long Island, another Stewart project that opened the village to commuters.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Garden_City%2C_New_York"
    },
    {
      "id": 4,
      "text": "In 1927, Charles Lindbergh stayed at the Garden City Hotel while preparing for his historic transatlantic flight.",
      "sourceSentenceIds": [
        21
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.britannica.com/place/Garden-City-New-York"
    },
    {
      "id": 5,
      "text": "Adelphi University moved its campus to Garden City in 1929, bringing higher education to the village.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.britannica.com/place/Garden-City-New-York"
    },
    {
      "id": 6,
      "text": "The Cradle of Aviation Museum, located next to the historic airport, showcases Long Island's deep aviation heritage.",
      "sourceSentenceIds": [
