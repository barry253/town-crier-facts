  "facts": [
    {
      "id": 1,
      "text": "Brookdale was renamed from Stone House Plains in 1873, marking its formal emergence as a distinct community.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://brookdalepark.org/brookdale-park-blog-education/2023/12/30/the-history-of-brookdale-park"
    },
    {
      "id": 2,
      "text": "The original Brookdale Park plan called for a track, football and baseball fields, tennis courts, a playground, a dancing pavilion, a bandstand, and a casino—most of which were never built.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://brookdalepark.org/brookdale-park-blog-education/2023/12/30/the-history-of-brookdale-park"
    },
    {
      "id": 3,
      "text": "In the 1890s, Essex County established the nation’s first county park system, with Brookdale Park among its pioneering sites.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://brookdalepark.org/brookdale-park-blog-education/2023/12/30/the-history-of-brookdale-park"
    },
    {
      "id": 4,
      "text": "Before European settlement, the Lenni Lenape people gathered on the land that would become Brookdale, making it a historic indigenous site.",
      "sourceSentenceIds": [
        3,
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/brookdale_new_jersey"
    },
    {
      "id": 5,
      "text": "Brookdale Park’s history traces back to the Yantecaw, a Lenape subgroup, who lived here for thousands of years before the area became part of modern New Jersey.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://brookdalepark.org/brookdale-park-blog-education/2023/12/30/the-history-of-brookdale-park"
    }
  ]
