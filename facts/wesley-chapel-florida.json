  "facts": [
    {
      "id": 1,
      "text": "Wesley Chapel got its name from a Methodist church that stood beside twin creeks once called Double Branch.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Wesley_Chapel%2C_Florida"
    },
    {
      "id": 2,
      "text": "The town was founded in the late 19th century, growing around a post office, sawmills, and a general store that operated from 1897 to 1902.",
      "sourceSentenceIds": [
        5,
        21
      ],
      "sourceLabels": [
        "Web source 2",
        "Wikipedia"
      ],
      "source": "https://floridatravel.blog/wesley-chapel-florida-a-boom-town-dream-destination-in-pasco-county/"
    },
    {
      "id": 3,
      "text": "A railroad arrived in the early 20th century, turning Wesley Chapel into a hub for transporting citrus, livestock, and passengers across central Florida.",
      "sourceSentenceIds": [
        11,
        12
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://floridatravel.blog/wesley-chapel-florida-a-boom-town-dream-destination-in-pasco-county/"
    },
    {
      "id": 4,
      "text": "Before settlers arrived, the area was home to Seminole and Creek peoples, with evidence of Native American presence dating back to 10,000 B.C.",
      "sourceSentenceIds": [
        3,
        17
      ],
      "sourceLabels": [
        "Web source 2",
        "Wikipedia"
      ],
      "source": "https://floridatravel.blog/wesley-chapel-florida-a-boom-town-dream-destination-in-pasco-county/"
    },
    {
      "id": 5,
      "text": "Lumber harvesting and turpentine production once dominated the local economy, while cash‑crop farming, citrus, and livestock ranching sustained early pioneers.",
