  "facts": [
    {
      "id": 1,
      "text": "Montverde earned its name from a Vermont settler who called the rolling green hills “Monte Verde,” the Spanish for green mountain.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Montverde%2C_Florida"
    },
    {
      "id": 2,
      "text": "The town’s first permanent settlement dates to 1865, when it was originally called West Lake Apopka.",
      "sourceSentenceIds": [
        1,
        2
      ],
      "sourceLabels": [
        "Web source 1",
        "Wikipedia"
      ],
      "source": "https://www.florida-backroads-travel.com/montverde-florida.html"
    },
    {
      "id": 3,
      "text": "Montverde Academy, founded in 1912, sits on a 125‑acre campus that still hosts students from around the world.",
      "sourceSentenceIds": [
        4,
        12,
        24
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://www.florida-backroads-travel.com/montverde-florida.html"
    },
    {
      "id": 4,
      "text": "From 1887 to 1969 the Tavares and Gulf Railroad ran through Montverde, hauling citrus and vegetables to market.",
      "sourceSentenceIds": [
        9,
        18
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://www.florida-backroads-travel.com/montverde-florida.html"
    },
    {
      "id": 5,
      "text": "The historic Harper House, built in the mid‑1870s, is listed on the National Register of Historic Places and stands on Lake Apopka’s western shore.",
