  "facts": [
    {
      "id": 1,
      "text": "Town 'n' Country began as a 525‑acre dairy farm before the LaMonte‑Shimberg Corporation built one of Tampa’s first suburban communities in 1958.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Town_'n'_Country%2C_Florida"
    },
    {
      "id": 2,
      "text": "From 1958 to 1978, LaMonte‑Shimberg erected nearly 8,000 single‑family homes and townhouses, shaping the area’s residential character.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Town_'n'_Country%2C_Florida"
    },
    {
      "id": 3,
      "text": "The CDP sits just 12 miles northwest of downtown Tampa, bordered to the south by the city itself.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Town_'n'_Country%2C_Florida"
    },
    {
      "id": 4,
      "text": "Town 'n' Country’s elevation averages only 6 feet above sea level, reflecting its low‑lying, coastal‑influenced geography.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Town_'n'_Country,_Florida"
    },
    {
      "id": 5,
      "text": "Before the 1950s, the land that is now Town 'n' Country was mostly natural areas and cattle farms.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Town_'n'_Country%2C_Florida"
    },
    {
