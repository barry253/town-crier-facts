  "facts": [
    {
      "id": 1,
      "text": "Sagaponack’s name comes from the Shinnecock word meaning “land of the big ground nuts,” a nod to the native groundnut plant.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Sagaponack%2C_New_York"
    },
    {
      "id": 2,
      "text": "First settled around 1653 as part of Southampton, Sagaponack only became an independent village in 2005 after a long push for local control.",
      "sourceSentenceIds": [
        13,
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Sagaponack%2C_New_York"
    },
    {
      "id": 3,
      "text": "Potato farms still dot the landscape, protected by community preservation efforts that keep the village’s agricultural heritage alive.",
      "sourceSentenceIds": [
        6,
        11
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Sagaponack,_New_York"
    },
    {
      "id": 4,
      "text": "Home prices in Sagaponack soar far above the national average, thanks to limited supply and strict open‑space preservation.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Sagaponack,_New_York"
    },
    {
      "id": 5,
      "text": "The village’s single operational one‑room schoolhouse and historic general store remain central to Sagaponack’s rural character.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 2"
      ],
