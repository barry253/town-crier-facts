  "facts": [
    {
      "id": 1,
      "text": "Newton earned its name either from the colonial Newtown in Queens, New York, where the influential Pettit brothers settled, or simply as a 'new town'.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Newton%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "Newton's first modern factory opened in 1873, sparking a boom that saw more factories rise in the early 1900s.",
      "sourceSentenceIds": [
        11,
        12,
        13
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://www.achp.gov/preserve-america/community/newton-new-jersey"
    },
    {
      "id": 3,
      "text": "The railroad's completion in 1854 opened new commercial opportunities, leading to a surge of businesses in Newton's fast‑growing downtown.",
      "sourceSentenceIds": [
        21,
        23
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://www.achp.gov/preserve-america/community/newton-new-jersey"
    },
    {
      "id": 4,
      "text": "The Newton Theatre, once a 1924 Reilly and Hall movie house, now hosts 605‑seat performances as a vibrant arts center.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Newton%2C_New_Jersey"
    },
    {
      "id": 5,
      "text": "Newton houses the Hill Memorial Museum, the state's oldest continuously operating museum building, run by the Sussex County Historical Society.",
      "sourceSentenceIds": [
        19
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Newton%2C_New_Jersey"
    },
    {
      "id": 6,
      "text": "Newton Cemetery, also called Old Newton Burial Ground, served as the town's primary burial site for a century after its 1762 establishment.",
