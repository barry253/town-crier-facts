  "facts": [
    {
      "id": 1,
      "text": "Ponce de Leon was named after Spanish explorer Juan Ponce de León, who first documented Florida in 1513.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Ponce_de_Leon,_Florida"
    },
    {
      "id": 2,
      "text": "The town sits in the valley of Sandy Creek, a south‑flowing tributary of the Choctawhatchee River.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ponce_de_Leon%2C_Florida"
    },
    {
      "id": 3,
      "text": "Ponce de Leon Springs, a second‑magnitude spring nearby, pumps about 14 million gallons of water daily into Sandy Creek.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Ponce_de_Leon,_Florida"
    },
    {
      "id": 4,
      "text": "European‑American pioneers began settling the area in the late 1820s and 1830s, drawn by fertile soils and abundant springs.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Ponce_de_Leon,_Florida"
    },
    {
      "id": 5,
      "text": "The town’s center is crossed by US 90, which runs northeast to the county seat Bonifay and west to DeFuniak Springs.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ponce_de_Leon%2C_Florida"
    },
    {
      "id": 6,
      "text": "Ponce de Leon’s town hall, located at PO Box 214, serves as the hub for local civic services and community events.",
      "sourceSentenceIds": [
        28
      ],
