  "facts": [
    {
      "id": 1,
      "text": "Bethlehem Village hosts Regina Laudis Abbey, a cloistered Benedictine community founded by French nuns after World War II.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.ncregister.com/features/a-visit-to-connecticut-s-bethlehem"
    },
    {
      "id": 2,
      "text": "In 1673 fifteen planters from Stratford trekked north, bought land from Indians, and laid the groundwork for Bethlehem.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://bethlehemct.org/index.asp?SEC=3F708C56-089B-4687-A073-68FD6ECFD5A0&DE=F5E55535-BE9D-4C2F-A575-ACC4AF6ADC70"
    },
    {
      "id": 3,
      "text": "Early settlers built a Bethlem church and school, where Doctor Bellamy ran America’s first theological school.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://bethlehemct.org/index.asp?SEC=3F708C56-089B-4687-A073-68FD6ECFD5A0&DE=F5E55535-BE9D-4C2F-A575-ACC4AF6ADC70"
    },
    {
      "id": 4,
      "text": "The village’s heart is the Bethlehem Green Historic District, a preserved center of 18th‑century architecture.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bethlehem_Village%2C_Connecticut"
    },
    {
      "id": 5,
      "text": "Connecticut Route 61 slices through Bethlehem Village, heading north eight miles to Litchfield and south four miles to U.S. Route 1.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bethlehem_Village%2C_Connecticut"
    },
    {
      "id": 6,
      "text": "Bethlehem Village covers roughly forty percent of the town, stretching from Morris in the north to Crane Hollow Road in the south.",
