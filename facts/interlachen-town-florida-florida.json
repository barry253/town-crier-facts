  "facts": [
    {
      "id": 1,
      "text": "Interlachen was incorporated in 1888 after the Florida Southern Railway opened in the 1870s, turning the former \"Blue Pond\" area into a winter vacation spot.",
      "sourceSentenceIds": [
        18,
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Interlachen%2C_Florida"
    },
    {
      "id": 2,
      "text": "The town’s name means \"between the lakes,\" reflecting its location between Lake Lagonda and Lake Chipco, and echoes a Swiss hometown.",
      "sourceSentenceIds": [
        4,
        23,
        24,
        25
      ],
      "sourceLabels": [
        "Web source 2",
        "Wikipedia"
      ],
      "source": "https://www.florida-backroads-travel.com/interlachen-florida.html"
    },
    {
      "id": 3,
      "text": "In 1891 the original Interlachen Town Hall burned; a new hall was built in 1892 and now houses the Historical Society museum.",
      "sourceSentenceIds": [
        5,
        20,
        21
      ],
      "sourceLabels": [
        "Web source 2",
        "Wikipedia"
      ],
      "source": "https://www.florida-backroads-travel.com/interlachen-florida.html"
    },
    {
      "id": 4,
      "text": "A caboose sits in the town square, a relic of the 1930s train that ran every two hours and once brought tourists to the citrus capital.",
      "sourceSentenceIds": [
        28,
        27
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Interlachen%2C_Florida"
    },
    {
      "id": 5,
      "text": "The Interlachen Museum, opened in 1892, occupies the historic town hall and opens Saturdays from 10 am to 2 pm for history buffs.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.florida-backroads-travel.com/interlachen-florida.html"
    },
    {
      "id": 6,
      "text": "Hog Wild Country Cafe, a local favorite, sits on County Road 310 and offers a taste of the town’s culinary scene.",
