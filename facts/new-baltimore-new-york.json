    },
    {
      "id": 2,
      "text": "The hamlet’s name honors New York State Senator Abraham Bogart Conger, who helped shape the region in the 1800s.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Congers%2C_New_York"
    },
    {
      "id": 3,
      "text": "Congers Station once hosted daily New York Central trains, making it a bustling river‑side stop in 1910.",
      "sourceSentenceIds": [
        24
