  "facts": [
    {
      "id": 1,
      "text": "Old Hurley’s Main Street is a National Historic Landmark because of its concentration of well‑preserved stone houses that have been homes for over 300 years.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.hurleyheritagesociety.org/hurley-tours/"
    },
    {
      "id": 2,
      "text": "Hurley was originally a Lenni Lenape community before Dutch settlers arrived in 1662.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.hurleyheritagesociety.org/hurley-tours/"
    },
    {
      "id": 3,
      "text": "The village of West Hurley was relocated after the Ashokan Reservoir was created, now sits on the northern bank of the reservoir.",
      "sourceSentenceIds": [
        22,
        23
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/West_Hurley%2C_New_York"
    },
    {
      "id": 4,
      "text": "The self‑guided tour map lists 27 historic sites around Hurley’s Main Street, making it easy to walk between them.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.hurleyheritagesociety.org/hurley-tours/"
    },
    {
      "id": 5,
      "text": "Hurley’s Main Street is compact enough that most historic locations can be seen on a single stroll.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.hurleyheritagesociety.org/hurley-tours/"
    },
    {
      "id": 6,
      "text": "The town hosts a guided walking tour every fourth Sunday, led by the Hurley Heritage Society.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.hurleyheritagesociety.org/hurley-tours/"
