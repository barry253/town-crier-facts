  "facts": [
    {
      "id": 1,
      "text": "In 1863 the Albany & Susquehanna Railroad opened a station in Central Bridge, linking the hamlet to the wider rail network.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.wgpfoundation.org/historic-markers/central-bridge/"
    },
    {
      "id": 2,
      "text": "The name Central Bridge comes from the Haudenosaunee word meaning “between the two waters,” referring to Lake George and Lake Champlain.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ticonderoga_(CDP)%2C_New_York"
    },
    {
      "id": 3,
      "text": "The La Chute River runs through the hamlet, draining Lake George into Lake Champlain and featuring a waterfall at its eastern edge.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ticonderoga_(CDP)%2C_New_York"
    },
    {
      "id": 4,
      "text": "During summer months a diesel‑powered cable ferry shuttles residents across the river to Shoreham, Vermont.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ticonderoga_(CDP)%2C_New_York"
    },
    {
      "id": 5,
      "text": "Central Bridge sits on the historic portage that once guarded Fort Ticonderoga, a key military outpost in the area.",
