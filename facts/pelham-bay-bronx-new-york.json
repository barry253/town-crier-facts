  "facts": [
    {
      "id": 1,
      "text": "Pelham Bay is named after Pelham Bay Park, New York City's largest park, and the body of water Pelham Bay within it.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
