  "facts": [
    {
      "id": 1,
      "text": "Briny Breezes began as Ward Beecher Miller's 43‑acre dairy farm called Shore Acres in 1919.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://education.pbchistory.org/pbc_community/briny-breezes/"
    },
    {
      "id": 2,
      "text": "During the Great Depression, Miller let tourists bring trailers and camp on his land, turning it into a winter getaway.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://education.pbchistory.org/pbc_community/briny-breezes/"
    },
    {
      "id": 3,
      "text": "Miller advertised the land with \"$3 a week rent\" flyers in Northern newspapers such as the Chicago Tribune.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://education.pbchistory.org/pbc_community/briny-breezes/"
    },
    {
      "id": 4,
      "text": "In 2005, Briny Breezes served as the setting for the film *In Her Shoes*, with many residents appearing as extras.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Briny_Breezes%2C_Florida"
    },
    {
      "id": 5,
      "text": "Briny Breezes is one of only two Florida mobile‑home parks that incorporated as towns, the other being Ocean Breeze.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Briny_Breezes%2C_Florida"
    },
    {
      "id": 6,
      "text": "The town sits 1.6 miles south of Ocean Ridge and 1.3 miles north of Gulf Stream, bordered by the Atlantic Ocean and the Intracoastal Waterway.",
