  "facts": [
    {
      "id": 1,
      "text": "In 1626, colonists led by Peter Minuit bought land from the Lenape and founded New Amsterdam, the seed of today's Financial District.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://away.mta.info/articles/have-you-been-guide-tour-of-the-financial-district-nyc/"
    },
    {
      "id": 2,
      "text": "The Buttonwood Agreement of 1792, signed under a sycamore tree, launched the New York Stock Exchange on Wall Street.",
      "sourceSentenceIds": [
        19
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://away.mta.info/articles/have-you-been-guide-tour-of-the-financial-district-nyc/"
    },
    {
      "id": 3,
      "text": "In 1998, a $900 million deal kept the NYSE from moving to Jersey City, preserving the district’s financial heart.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Financial_District%2C_Manhattan"
    },
    {
      "id": 4,
      "text": "South of Morris Street, the Fraunces Tavern Block Historic District preserves the area where George Washington bade farewell in 1783.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Financial_District%2C_Manhattan"
    },
    {
      "id": 5,
      "text": "The World Trade Center Transportation Hub, opened in 2016, now serves as a major transit nexus for the Financial District.",
