  "facts": [
    {
      "id": 1,
      "text": "Cambria Heights got its name in the 1920s when a Pennsylvania bank financed early development for families moving out of city apartments.",
      "sourceSentenceIds": [
        20
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Cambria_Heights%2C_Queens"
    },
    {
      "id": 2,
      "text": "In June 2022, the Landmarks Preservation Commission designated the Cambria Heights–222nd Street and –227th Street Historic Districts.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Cambria_Heights%2C_Queens"
    },
    {
      "id": 3,
      "text": "Those districts feature Tudor and Storybook‑style row houses, architectural highlights that echo early 20th‑century fairytale design.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.nyc.gov/site/lpc/about/pr2022/lpc-designates-two-historic-districts-in-cambria-heights-queens.page"
    },
    {
      "id": 4,
      "text": "Despite close proximity to major expressways, Cambria Heights still feels like a quiet small town where neighbors know each other.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.cityneighborhoods.nyc/cambria-heights"
    },
    {
      "id": 5,
      "text": "The neighborhood hosts a high concentration of Christian churches, from Linden Boulevard storefronts to the sprawling Sacred Heart Catholic Academy.",
      "sourceSentenceIds": [
        24
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Cambria_Heights%2C_Queens"
    },
