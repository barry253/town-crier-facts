  "facts": [
    {
      "id": 1,
      "text": "Kensington’s name comes from Old English, combining “Cen” for king and “tun” for settlement, meaning a king’s village.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.wisdomlib.org/cities/kensington-41077"
    },
    {
      "id": 2,
      "text": "In the 19th and early 20th centuries, Kensington was a hub for clockmaking and metalworking, shaping its industrial legacy.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.wisdomlib.org/cities/kensington-41077"
    },
    {
      "id": 3,
      "text": "The Henry Hooker House, a preserved historic home, stands as a testament to Kensington’s architectural past.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Kensington%2C_Connecticut"
    },
    {
      "id": 4,
      "text": "Noyes Library, opened in the early 20th century, now serves as a children’s library and community hub.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.kensingtonhistory.org/town-chronology/"
    },
    {
      "id": 5,
      "text": "Knowles Station railroad stop, later renamed Kensington, marked the town’s early connection to the B&O Railroad line.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.kensingtonhistory.org/town-chronology/"
    },
    {
      "id": 6,
      "text": "Kensington Historic District, listed on the National Register of Historic Places, preserves the town’s rich architectural heritage.",
      "sourceSentenceIds": [
