  "facts": [
    {
      "id": 1,
      "text": "New Canaan’s town band, founded in 1831, is the second‑oldest town band in the United States.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Canaan%2C_Connecticut"
    },
    {
      "id": 2,
      "text": "The New Canaan Historical Society, established in 1889, calls the town’s first town hall its home.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Canaan%2C_Connecticut"
    },
    {
      "id": 3,
      "text": "The New Canaan Museum & Historical Society runs seven museums, preserves five historic buildings, and hosts school tours and seminars.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Canaan%2C_Connecticut"
    },
    {
      "id": 4,
      "text": "When the New York, New Haven and Hartford Railroad reached New Canaan in 1868, wealthy New Yorkers began building summer homes here.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Canaan%2C_Connecticut"
    },
    {
      "id": 5,
      "text": "Since 1919, New Canaan residents gather on God’s Acre every Christmas Eve to sing carols with the town band.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Canaan%2C_Connecticut"
    },
    {
      "id": 6,
      "text": "Every June 19, the Stand Together Against Racism group hosts a Juneteenth “Hearts of Freedom” celebration on the lawn of the Historical Society.",
