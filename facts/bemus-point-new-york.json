  "facts": [
    {
      "id": 1,
      "text": "Bemus Point’s first ferry, built in 1811 by Thomas Bemus, linked the village to Stow across Chautauqua Lake.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bemus_Point%2C_New_York"
    },
    {
      "id": 2,
      "text": "The village officially became incorporated in 1911, marking its transition from a settlement to an incorporated municipality.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bemus_Point%2C_New_York"
    },
    {
      "id": 3,
      "text": "Thomas Bemus originally polled a raft across the lake; today a cable‑drawn ferry operated by the Sea Lion Project carries passengers.",
      "sourceSentenceIds": [
        17,
        18
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bemus_Point%2C_New_York"
    },
    {
      "id": 4,
      "text": "In 1805, William Bemus purchased land on both sides of Chautauqua Lake from the Holland Land Company for just $1.50.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bemus_Point%2C_New_York"
    },
    {
      "id": 5,
      "text": "Every summer, Bemus Point hosts the Bemus Bay Pops concert, a gathering that showcases local musicians and community spirit.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bemus_Point%2C_New_York"
    },
    {
      "id": 6,
      "text": "Located at 42.162886 latitude and –79.391230 longitude, Bemus Point sits on the eastern shore of Chautauqua Lake.",
