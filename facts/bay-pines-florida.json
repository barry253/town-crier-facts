  "facts": [
    {
      "id": 1,
      "text": "Bay Pines got its name in 1934 when Seminole Point was renamed after the nearby pine trees.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.va.gov/bay-pines-health-care/about-us/history/"
    },
    {
      "id": 2,
      "text": "The Bay Pines Veterans Administration Home and Hospital Historic District, built in the 1930s, showcases 14 Mediterranean‑Revival style buildings.",
      "sourceSentenceIds": [
        12,
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bay_Pines%2C_Florida"
    },
    {
      "id": 3,
      "text": "In 2012 the historic district was added to the National Register of Historic Places, honoring its architectural and military heritage.",
      "sourceSentenceIds": [
        5,
        8
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Bay_Pines%2C_Florida"
    },
    {
      "id": 4,
      "text": "Bay Pines is home to the VA Bay Pines Health Care System, one of the largest veterans’ hospitals in the United States.",
      "sourceSentenceIds": [
        6,
        7
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.va.gov/bay-pines-health-care/about-us/history/"
    },
    {
      "id": 5,
      "text": "The Bay Pines National Cemetery, adjacent to the hospital, serves as a final resting place for thousands of American veterans.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bay_Pines%2C_Florida"
    },
    {
      "id": 6,
      "text": "During World War II, the VA campus expanded by moving offices into temporary Quonset‑type huts, including a chapel and library.",
