  "facts": [
    {
      "id": 1,
      "text": "Gilbertsville was the first settlement in the town, named after landowner Abijah Gilbert of Nuneaton, England, father of US Senator Abijah Gilbert.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Gilbertsville%2C_New_York"
    },
    {
      "id": 2,
      "text": "The Empire House, founded in 1835, remains the only commercial building still operating as a B&B‑style hotel and restaurant in the village.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://roadrunnerjourneys.com/the-remarkable-village-of-gilbertsville-in-otsego-county-new-york/"
    },
    {
      "id": 3,
      "text": "The village’s architecture shows clear English influence, with half‑timbered Major’s Inn and Gilbert Block featuring classic gables.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.livingplaces.com/NY/Otsego_County/Gilbertsville_Village/Gilbertsville_Historic_District.html"
    },
    {
      "id": 4,
      "text": "Gilbertsville’s historic district is one of the most intact villages in Otsego County, with stone houses, churches, and rock walls preserving 19th‑century character.",
      "sourceSentenceIds": [
        15
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.livingplaces.com/NY/Otsego_County/Gilbertsville_Village/Gilbertsville_Historic_District.html"
    },
    {
      "id": 5,
      "text": "The arrival of the railroad in the late 19th century caused the decline of Gilbertsville’s small industries, a fate common to many similar communities.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.livingplaces.com/NY/Otsego_County/Gilbertsville_Village/Gilbertsville_Historic_District.html"
    },
    {
      "id": 6,
      "text": "Gilbertsville was the only village listed on the National Register of Historic Places as of May 1983, highlighting its preserved heritage.",
      "sourceSentenceIds": [
        20
      ],
      "sourceLabels": [
        "Web source 2"
      ],
