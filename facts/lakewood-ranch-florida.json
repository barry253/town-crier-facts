  "facts": [
    {
      "id": 1,
      "text": "Lakewood Ranch began in 1905 when Milwaukee businessman John Schroeder assembled the land as the Schroeder‑Manatee Ranch.",
      "sourceSentenceIds": [
        1,
        3
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Lakewood_Ranch%2C_Florida"
    },
    {
      "id": 2,
      "text": "In February 1994 the ranchland shifted from cattle and citrus to a master‑planned community.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Lakewood_Ranch,_Florida"
    },
    {
      "id": 3,
      "text": "The first neighborhood, Summerfield, opened its doors in 1995.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lakewood_Ranch%2C_Florida"
    },
    {
      "id": 4,
      "text": "The Braden River winds east‑west across the southern part of Lakewood Ranch, eventually reaching the Manatee River.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lakewood_Ranch%2C_Florida"
    },
    {
      "id": 5,
      "text": "Lakewood Ranch stretches from State Road 64 in the north to Fruitville Road in the south, and from I‑75 on the west to Bournside Boulevard on the east.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lakewood_Ranch%2C_Florida"
    },
    {
      "id": 6,
      "text": "Lakewood Ranch was granted development‑of‑regional‑impact status in December 1989, a key step that allowed the community to grow.",
      "sourceSentenceIds": [
        8,
        24
      ],
