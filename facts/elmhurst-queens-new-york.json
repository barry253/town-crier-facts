      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Elmhurst%2C_Queens"
    },
    {
      "id": 3,
      "text": "Elmhurst Memorial Park, acquired in 1928, honors local soldiers who died in World War I.",
      "sourceSentenceIds": [
