  "facts": [
    {
      "id": 1,
      "text": "Grand View‑on‑Hudson earned its name from the sweeping vista of the Hudson River that overlooks the village.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Grand_View-on-Hudson%2C_New_York"
    },
    {
      "id": 2,
      "text": "The village’s historic chapel, whose cornerstone was laid in 1867, stands as a landmark of its early community life.",
      "sourceSentenceIds": [
        3,
        7
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Grand_View-on-Hudson%2C_New_York"
    },
    {
      "id": 3,
      "text": "In the mid‑1800s, the Erie Railroad’s extension brought Grand View‑on‑Hudson into the wider world, turning a quiet hamlet into a connected community.",
      "sourceSentenceIds": [
        5,
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.gvoh-ny.gov/village-history/"
    },
    {
      "id": 4,
      "text": "Quarrymen, artists, and visionaries shaped the village’s character, making it a haven for creative minds beside the river.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.gvoh-ny.gov/village-history/"
    },
    {
      "id": 5,
      "text": "Grand View‑on‑Hudson was officially incorporated in 1918, establishing its municipal identity within Rockland County.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Grand_View-on-Hudson%2C_New_York"
    },
    {
      "id": 6,
      "text": "Nestled on the west bank of the Hudson, the village’s geography has kept it a tranquil escape from the bustle of nearby cities.",
      "sourceSentenceIds": [
        16,
        9
      ],
      "sourceLabels": [
        "Wikipedia",
