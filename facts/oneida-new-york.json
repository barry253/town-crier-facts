    },
    {
      "id": 2,
      "text": "The Oneida Community Mansion House, a National Historic Landmark, preserves the 19th‑century communal experiment that once occupied the site.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Oneida%2C_New_York"
    },
    {
      "id": 3,
      "text": "John Humphrey Noyes founded the Oneida Community in 1848; by 1881 it had become a silverware company.",
