  "facts": [
    {
      "id": 1,
      "text": "Founded in 1834 by Sands Higinbotham, Oneida grew as a depot for the Utica‑Syracuse Railroad, honoring the local Oneida people.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
