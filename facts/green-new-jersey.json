    },
    {
      "id": 2,
      "text": "Founded in the 18th century, Green Village traces its roots to early settlers.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Green_Village%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "Elias Boudinot’s 1760 home, built by General William Alexander, stands as one of the village’s oldest structures.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Green_Village%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "Local farmer John Cockrem and his family built the village center in 1800, including a Methodist church and post office.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Green_Village%2C_New_Jersey"
    },
    {
      "id": 5,
      "text": "Great Brook and Loantaka Brook drain Green Village, flowing southwest into the Great Swamp National Wildlife Refuge.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Green_Village%2C_New_Jersey"
    },
    {
      "id": 6,
      "text": "Green Village Road links east to Madison and west to New Vernon, while Meyersville and Britten Roads head south toward the Great Swamp.",
