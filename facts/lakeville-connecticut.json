  "facts": [
    {
      "id": 1,
      "text": "Lakeville kept the name Furnace Village until 1846, then changed to honor its deep lake.",
      "sourceSentenceIds": [
        7,
        12
      ],
      "sourceLabels": [
        "Web source 2",
        "Wikipedia"
      ],
      "source": "https://grokipedia.com/page/Lakeville,_Connecticut"
    },
    {
      "id": 2,
      "text": "In 1762, Ethan Allen and partners built Connecticut’s first blast furnace in Lakeville, sparking the state’s iron industry.",
      "sourceSentenceIds": [
        23
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Lakeville,_Connecticut"
    },
    {
      "id": 3,
      "text": "Lakeville hosts the Scoville Memorial Library, the first publicly funded library in the United States.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://ctliving.com/towns/lakeville/"
    },
    {
      "id": 4,
      "text": "The Holley‑Williams House, erected in 1768 by ironmaster John Holley, now serves as a museum of early industry.",
      "sourceSentenceIds": [
        16,
        24
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://ctliving.com/towns/lakeville/"
    },
    {
      "id": 5,
      "text": "Founded in 1891 by Maria Hotchkiss, the Hotchkiss School in Lakeville educates about 600 students with a 4:1 ratio.",
      "sourceSentenceIds": [
        4,
        29
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Lakeville%2C_Connecticut"
    },
    {
      "id": 6,
      "text": "During the Civil War, Lakeville’s foundries produced cannons and railroad tracks, cementing its industrial legacy.",
      "sourceSentenceIds": [
