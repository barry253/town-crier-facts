  "facts": [
    {
      "id": 1,
      "text": "Williamsburg was named for William Jaird Levitt, whose family created four Levittowns in the late 1940s.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.orangecountyfl.net/BoardofCommissioners/District1Commissioner/District1Communities/Williamsburg.aspx"
    },
    {
      "id": 2,
      "text": "Williamsburg lies between the Beachline Expressway north and the Central Florida GreeneWay south, bordered by Shingle Creek east and International Drive west.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Williamsburg%2C_Florida"
    },
    {
      "id": 3,
      "text": "The heart of Williamsburg centers around the intersection of Orangewood Boulevard and is a key hub for local traffic.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Williamsburg%2C_Florida"
    },
    {
      "id": 4,
      "text": "In the early 2000s, Williamsburg’s Homeowners Association teamed with Orange County to keep Convention Center traffic off the Orangewood‑Beachline interchange.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Williamsburg%2C_Florida"
    },
    {
      "id": 5,
      "text": "The new interchange now sends most southbound Universal Boulevard traffic onto the Beachline, leaving only a single lane underpass to Orangewood.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Williamsburg%2C_Florida"
    },
    {
      "id": 6,
      "text": "The original Levittown, outside New York City, pioneered mass‑produced homes that made post‑war housing affordable for returning veterans.",
