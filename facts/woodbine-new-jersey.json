  "facts": [
    {
      "id": 1,
      "text": "Woodbine’s name comes from the honeysuckle plant, symbolizing a bond of love that twines around trees and other plants.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.woodbinechamber.com/history-of-woodbine"
    },
    {
      "id": 2,
      "text": "The town’s street grid still follows the original 1891 layout, a rare glimpse into its early planning.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.woodbinechamber.com/history-of-woodbine"
    },
    {
      "id": 3,
      "text": "Subsidies in the early 1900s spurred the rise of factories producing clothing, rubber, paper products, and toys in Woodbine.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.woodbinechamber.com/history-of-woodbine"
    },
    {
      "id": 4,
      "text": "In 2004 the Sam Azeez Museum of Woodbine Heritage received the New Jersey Historic Preservation Award for its work preserving local history.",
      "sourceSentenceIds": [
        7
