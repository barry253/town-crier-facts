  "facts": [
    {
      "id": 1,
      "text": "Dennisville was founded in 1726 by Anthony Ludlam in the early colonial era.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Dennisville%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "The village adopted the name Dennisville in 1854, moving from Dennis Creek to honor its founder.",
      "sourceSentenceIds": [
        29
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Dennisville%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "In the 1880s, a unique cedar shingle industry sprang up, salvaging trees from swamps, described by the NYT as unlike any other.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Dennisville%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "Shipbuilding once thrived on Dennis Creek, forming a major economic base for over a century.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.livingplaces.com/NJ/Cape_May_County/Dennis_Township/Dennisville_Historic_District.html"
    },
    {
      "id": 5,
      "text": "The historic Dennisville Inn sits beside the former railroad station, a reminder of the town’s 19th‑century travel hub.",
      "sourceSentenceIds": [
        3
