  "facts": [
    {
      "id": 1,
      "text": "Lely Resort was founded in 1972 by Dutch inventor Cornelius van der Lely, who bought 25,000 acres to create a planned community.",
      "sourceSentenceIds": [
        1,
        11
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lely_Resort%2C_Florida"
    },
    {
      "id": 2,
      "text": "The community’s name honors its founder, reflecting his agricultural roots and innovative spirit.",
      "sourceSentenceIds": [
        2,
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lely_Resort%2C_Florida"
    },
    {
      "id": 3,
      "text": "Lely Resort evolved into a gated enclave with nearly 40 neighborhoods, offering condos, villas, townhomes, and custom estates up to 4,000 sq ft.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/lely_resort_florida"
    },
    {
      "id": 4,
      "text": "Three golf courses were built in 1990, 1991, and 1997, but development stalled until Stock Development bought 340 acres in 2001.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lely_Resort%2C_Florida"
    },
    {
      "id": 5,
      "text": "Lely Resort lies within the Naples–Marco Island Metropolitan Statistical Area, about 7 miles southeast of downtown Naples.",
      "sourceSentenceIds": [
        10,
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lely_Resort%2C_Florida"
    },
    {
      "id": 6,
      "text": "The area’s tranquil fishing ponds and resort-style pool serve as local landmarks, hosting memories like a child’s first catch or a lazy afternoon in the sun.",
