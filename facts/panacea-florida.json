  "facts": [
    {
      "id": 1,
      "text": "Panacea was renamed from Smith Springs in 1893 after Bostonians bought land around five springs, naming it after the goddess of universal remedy.",
      "sourceSentenceIds": [
        1,
        3
      ],
      "sourceLabels": [
        "Web source 2",
        "Wikipedia"
      ],
      "source": "https://roadtofreedom98.com/first-stop-on-our-journey-panacea-florida/"
    },
    {
      "id": 2,
      "text": "Founded in 1895, Panacea still feels like “Old Florida” with historic charm.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.visitpanacea.org/about"
    },
    {
      "id": 3,
      "text": "The Gulf Specimen Marine Laboratory and its nature center sit on Panacea’s waterfront, a long‑standing institution.",
      "sourceSentenceIds": [
        4,
        8
      ],
      "sourceLabels": [
        "Web source 1",
        "Wikipedia"
      ],
      "source": "https://www.visitpanacea.org/about"
    },
    {
      "id": 4,
      "text": "During the Civil War, a salt plant in Panacea supplied salt to much of western Florida.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Panacea%2C_Florida"
    },
    {
      "id": 5,
      "text": "A 1928 hurricane destroyed most development, and the Panacea Mineral Springs Hotel burned in the 1920s, leaving the town in decline.",
      "sourceSentenceIds": [
        10,
        12
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Panacea%2C_Florida"
    },
    {
      "id": 6,
      "text": "In World War II, proximity to industry revived Panacea, and today oyster harvesting has shifted to oyster farming.",
      "sourceSentenceIds": [
