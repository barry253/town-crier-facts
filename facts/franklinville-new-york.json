  "facts": [
    {
      "id": 1,
      "text": "In 1824, the town was renamed Franklinville after William Temple Franklin, a Holland Land Company agent and Benjamin Franklin’s grandson.",
      "sourceSentenceIds": [
        29
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Franklinville%2C_New_York"
    },
    {
      "id": 2,
      "text": "The village of Franklinville was officially incorporated in 1874, cementing its status as a distinct community.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.villagefranklinvilleny.gov/village-history.html"
    },
    {
      "id": 3,
      "text": "The Ischua Valley Historical Society, founded in 1966, preserves the region’s heritage through research and exhibits.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.villagefranklinvilleny.gov/village-history.html"
    },
    {
      "id": 4,
      "text": "Today the Historical Society’s building serves as a museum and meeting space, welcoming visitors to explore local history.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.villagefranklinvilleny.gov/village-history.html"
    },
    {
      "id": 5,
      "text": "Across the street from the Historical Society, the original mill stones from Franklinville’s early industry can still be seen.",
