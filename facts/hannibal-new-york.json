    },
    {
      "id": 3,
      "text": "In 1994 the society released 'Hannibal History in Pictures and Prose,' a comprehensive local history book born of years of research.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://oswego.nygenweb.net/towns/hannibal/hanhistsoc.html"
    },
    {
      "id": 4,
      "text": "'Hannibal History in Pictures and Prose' offers light, entertaining reading for young and old eager to learn about the village’s past.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://oswego.nygenweb.net/towns/hannibal/hanhistsoc.html"
    },
    {
      "id": 5,
      "text": "The village’s name honors the Carthaginian general Hannibal, reflecting a classical naming tradition.",
      "sourceSentenceIds": [
        27
