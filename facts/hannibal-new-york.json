    },
    {
      "id": 2,
      "text": "Its headquarters sits in a former 1827 Baptist church that now houses the Hannibal Free Library, senior center, and nursery school.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
