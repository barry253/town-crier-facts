  "facts": [
    {
      "id": 1,
      "text": "Cranberry Lake’s name comes from historic cranberry bogs that once lined its shores before forest reclaimed the area.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/cranberry_lake_new_york"
    },
    {
      "id": 2,
      "text": "The lake is the third‑largest in Adirondack Park, covering about 7,000 acres with 55 miles of shoreline, most of which is state‑owned.",
      "sourceSentenceIds": [
        18,
        27
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/cranberry_lake_new_york"
    },
    {
      "id": 3,
      "text": "A 1916 concrete dam replaced an earlier log crib dam, stabilizing water levels after the lake’s size doubled in 1867.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/cranberry_lake_new_york"
    },
    {
      "id": 4,
      "text": "The 50‑mile Cranberry Lake 50 trail loops the lake through old‑growth forest and backcountry ponds, a highlight for hikers.",
      "sourceSentenceIds": [
        14,
        30
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Cranberry_Lake%2C_New_York"
    },
    {
      "id": 5,
      "text": "The Presbyterian Church, built in 1897, is the only historic building left in the CDP and now serves as a community gathering spot.",
      "sourceSentenceIds": [
        5
