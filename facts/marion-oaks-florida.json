  "facts": [
    {
      "id": 1,
      "text": "Marion Oaks was founded in 1973 by the Deltona Corporation, a master‑planned retirement community created by the Mackle Brothers.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/marion_oaks_florida"
    },
    {
      "id": 2,
      "text": "The community covers roughly 2,537 acres and contains 4,909 lots, offering suburban living amid parks and natural scenery.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/marion_oaks_florida"
    },
    {
      "id": 3,
      "text": "Its community center houses a 450‑seat auditorium, a library, and light‑ed multi‑purpose sports courts, underscoring its early focus on recreation.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/marion_oaks_florida"
    },
    {
      "id": 4,
      "text": "The name Marion Oaks means “oak trees of Marion,” a nod to the county and the region’s abundant oak trees.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.wisdomlib.org/cities/marion-oaks-22229"
    },
    {
      "id": 5,
      "text": "The Marion Oaks Country Club golf course, once a local highlight, was temporarily closed as of 2024.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/marion_oaks_florida"
    },
    {
      "id": 6,
      "text": "Marion Oaks lies 14 miles south of Ocala and 27 miles north of Bushnell, within the Ocala Metropolitan Statistical Area.",
      "sourceSentenceIds": [
