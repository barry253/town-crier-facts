  "facts": [
    {
      "id": 1,
      "text": "Midland Park was incorporated as a borough on September 6, 1894, amid Bergen County’s boroughitis boom.",
      "sourceSentenceIds": [
        4,
        30
      ],
      "sourceLabels": [
        "Web source 2",
        "Web source 1"
      ],
      "source": "https://www.bergenreview.com/midland-park-nj.html"
    },
    {
      "id": 2,
      "text": "The borough’s name comes from the New Jersey Midland Railway that ran through the area in the 1870s.",
      "sourceSentenceIds": [
        1,
        5
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Midland_Park,_New_Jersey"
    },
    {
      "id": 3,
      "text": "Early settlers were Dutch colonists in the 17th century who built mills along Goffle Brook, then called Wagaraw Brook.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/Midland_Park,_New_Jersey"
    },
    {
      "id": 4,
      "text": "The Cornelius Lozier House, built around 1775, and the Wortendyke‑Demund House, erected in 1797, are surviving stone farmsteads that mark the borough’s rural past.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/Midland_Park,_New_Jersey"
    },
    {
      "id": 5,
      "text": "Midland Park’s compact 1.9‑square‑mile size has kept development modest, with residential units growing slowly rather than large tract developments.",
      "sourceSentenceIds": [
        2
