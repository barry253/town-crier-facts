  "facts": [
    {
      "id": 1,
      "text": "East Worcester was the largest settlement for most of the nineteenth century, a fact that still echoes in its historic Main Street.",
      "sourceSentenceIds": [
        27
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://worcesternyhistory.com/history/town-history/town-comprehensive-plan-history/"
    },
    {
      "id": 2,
      "text": "The town’s name honors Worcester County, Massachusetts, where many early settlers had lived before moving east in 1797.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://worcesternyhistory.com/history/town-history/town-comprehensive-plan-history/"
    },
    {
      "id": 3,
      "text": "During the Revolution, the area hosted skirmishes between patriot bands and British regulars, German mercenaries, Tories, and Iroquois led by Mohawk Chief Joseph Brant.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://worcesternyhistory.com/history/town-history/town-comprehensive-plan-history/"
    },
    {
      "id": 4,
      "text": "The railroad once powered prosperous hops, lumber, and potato industries, shaping East Worcester’s early economy before cars took over.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://worcesternyhistory.com/history/town-history/town-comprehensive-plan-history/"
    },
    {
      "id": 5,
      "text": "East Worcester sits at 42°35′30″N 74°45′1″W, right along New York State Route 7, a key corridor through the town.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Worcester_(CDP)%2C_New_York"
    },
    {
      "id": 6,
      "text": "The town’s first meeting was held at Silas Crippen’s home in 1797, and his homestead remains a working farm on Westford‑Maple Valley Road.",
      "sourceSentenceIds": [
        26
      ],
