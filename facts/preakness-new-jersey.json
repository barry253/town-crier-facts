  "facts": [
    {
      "id": 1,
      "text": "Preakness takes its name from the Lenape word Pra-qua-les, meaning “quail woods,” a nod to the area's early Native American heritage.",
      "sourceSentenceIds": [
        1,
        7,
        13,
        21
      ],
      "sourceLabels": [
        "Web source 1",
        "Wikipedia"
      ],
      "source": "https://grokipedia.com/page/preakness_new_jersey"
    },
    {
      "id": 2,
      "text": "Early settlers like the Berrys, Mitchells, Berdans, and Terhunes farmed along Valley Road, a route George Washington once crossed.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/preakness_new_jersey"
    },
    {
      "id": 3,
      "text": "Milton Holbrook Sanford founded Preakness Farms in 1865, breeding the colt Preakness whose win at Pimlico inspired the famous race.",
      "sourceSentenceIds": [
        22,
        23,
        24
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/preakness_new_jersey"
    },
    {
      "id": 4,
      "text": "The town sits atop the Preakness Basalt, a 200‑million‑year‑old volcanic layer that forms the Watchung Mountains’ distinctive ridges.",
      "sourceSentenceIds": [
        26,
        28,
        29,
        30
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/preakness_new_jersey"
    },
    {
      "id": 5,
      "text": "By the late 20th century, Preakness evolved from a rural farm community with a gristmill and church into a suburban enclave featuring modern homes and Valley Ridge Plaza.",
      "sourceSentenceIds": [
        25
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/preakness_new_jersey"
    },
    {
      "id": 6,
      "text": "Originally part of Bergen County, Preakness became part of the newly formed Passaic County in 1837.",
      "sourceSentenceIds": [
