  "facts": [
    {
      "id": 1,
      "text": "Seabrook Farms takes its name from Charles F. Seabrook, a pioneering truck farmer who founded the community in the early 1900s.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Seabrook_Farms%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "In 1934, a group of about 250 workers tried to stop tractors from harvesting beets, and sheriffs dispersed them with tear gas.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://exhibits.libraries.rutgers.edu/seabrook_farms/origins-innovations-and-early-labor-struggles"
    },
    {
      "id": 3,
      "text": "C.F. Seabrook introduced overhead irrigation to his father’s farm in 1907, a technique that boosted yields dramatically.",
      "sourceSentenceIds": [
        25
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://exhibits.libraries.rutgers.edu/seabrook_farms/origins-innovations-and-early-labor-struggles"
    },
    {
      "id": 4,
      "text": "After nearly going bankrupt twice, Seabrook Farms partnered with General Foods in 1934, gaining access to Clarence Birdseye’s frozen‑food technology.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://exhibits.libraries.rutgers.edu/seabrook_farms/origins-innovations-and-early-labor-struggles"
    },
    {
      "id": 5,
      "text": "By 1938, the company was producing two‑thirds of all frozen vegetables consumed in the United States.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://exhibits.libraries.rutgers.edu/seabrook_farms/origins-innovations-and-early-labor-struggles"
    },
    {
      "id": 6,
      "text": "Seabrook Farms first appeared as an unincorporated community in the 1950 U.S. Census, marking its formal recognition.",
      "sourceSentenceIds": [
