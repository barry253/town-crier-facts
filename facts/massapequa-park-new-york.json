  "facts": [
    {
      "id": 1,
      "text": "Massapequa Park once had its own airport, the Fitzmaurice Flying Field, named after pilot James Fitzmaurice, and 100,000 people attended its dedication in 1929.",
      "sourceSentenceIds": [
        9,
        10
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Massapequa_Park%2C_New_York"
    },
    {
      "id": 2,
      "text": "The village’s Long Island Rail Road station on the Babylon Branch sits in Massapequa Park, linking it to the wider island.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Massapequa_Park%2C_New_York"
    },
    {
      "id": 3,
      "text": "Brady and Colleran Parks honor two men who were instrumental in the village’s development, reflecting local heritage.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://masspkny.gov/about-us"
    },
    {
      "id": 4,
      "text": "The village was incorporated in 1931 to control land use, a move that shaped its modern layout.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Massapequa_Park%2C_New_York"
    },
    {
      "id": 5,
      "text": "Massapequa Park’s early history mirrors that of neighboring Massapequa, both tracing back to Native American roots on the South Shore.",
      "sourceSentenceIds": [
        4,
        6
      ],
      "sourceLabels": [
        "Wikipedia",
