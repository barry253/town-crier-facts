  "facts": [
    {
      "id": 1,
      "text": "Lake Luzerne CDP sits on the east side of the lake, where the Luzerne Music Center hosts summer concerts for musicians worldwide.",
      "sourceSentenceIds": [
        19
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lake_Luzerne_(CDP)%2C_New_York"
    },
    {
      "id": 2,
      "text": "The town’s name honors Anne‑César de La Luzerne, a French general who served as a diplomat to the United States in the early 1800s.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.lakeluzerneny.gov/lake-luzerne-history-museum/"
    },
    {
      "id": 3,
      "text": "Historical artifacts in the Frances Garnar Kinnear Museum chronicle the area’s evolution from farming and logging to grand hotels and summer camps.",
      "sourceSentenceIds": [
        3,
        6
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://www.lakeluzerneny.gov/lake-luzerne-history-museum/"
    },
    {
      "id": 4,
      "text": "Lake Luzerne’s early settlers traced back to 1767, when the land was granted to Edward and Ebenezer Jessup after the French and Indian War.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.lakeluzerneny.gov/lake-luzerne-history-museum/"
    },
    {
      "id": 5,
      "text": "The Jessup Brothers founded Jessup’s Landing and Jessup’s Little Falls on the Hudson River, anchoring the community’s early commerce.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.lakeluzerneny.gov/lake-luzerne-history-museum/"
    },
    {
      "id": 6,
      "text": "During the American Revolution, the Jessup Brothers, loyal to Britain, fought against the patriots and later fled to Canada after the war.",
      "sourceSentenceIds": [
        24,
        25
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.lakeluzerneny.gov/lake-luzerne-history-museum/"
    }
  ]
