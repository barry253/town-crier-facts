  "facts": [
    {
      "id": 1,
      "text": "Chaumont is named for Jacques‑Donatien Le Ray de Chaumont, Benjamin Franklin’s landlord and friend in France.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Chaumont%2C_New_York"
    },
    {
      "id": 2,
      "text": "The first European‑descended settlement of Chaumont began in 1802, after an unsatisfactory site was chosen the year before.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Chaumont%2C_New_York"
    },
    {
      "id": 3,
      "text": "Chaumont’s historic core lists dozens of National Register sites, from Cedar Grove Cemetery to the Chaumont Railroad Station.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Chaumont%2C_New_York"
    },
    {
      "id": 4,
      "text": "The village sits on a peninsula where the Chaumont River empties into Chaumont Bay, an arm of Lake Ontario, ending at Independence Point.",
      "sourceSentenceIds": [
        19,
        20
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Chaumont%2C_New_York"
    },
    {
      "id": 5,
      "text": "A 1840s Greek‑Revival church was rebuilt in Gothic style during the 1880s, reflecting changing tastes.",
