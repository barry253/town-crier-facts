  "facts": [
    {
      "id": 1,
      "text": "Cinco Bayou was platted in 1940 and officially incorporated on July 3, 1950, after a garage meeting attended by about sixty locals.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Cinco_Bayou%2C_Florida"
    },
    {
      "id": 2,
      "text": "Developers who platted the subdivision chose the name Cinco, Spanish for 'five,' and the town adopted it at incorporation.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Cinco_Bayou%2C_Florida"
    },
    {
      "id": 3,
      "text": "The town sits on an east‑west finger of water that feeds Choctawhatchee Bay, between Fort Walton’s city limits and the bay.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Cinco_Bayou%2C_Florida"
    },
    {
      "id": 4,
      "text": "Cinco Bayou is completely surrounded by the city of Fort Walton Beach, making it an enclave within the larger municipality.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Cinco_Bayou%2C_Florida"
    },
    {
      "id": 5,
      "text": "The climate here features hot, humid summers and generally mild winters, a typical pattern for northwest Florida.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Cinco_Bayou%2C_Florida"
    },
