    },
    {
      "id": 3,
      "text": "The 1910s saw 11,000 building lots mapped for summer cottages, stores, and dance pavilions, shaping Putnam Lake’s resort character.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
