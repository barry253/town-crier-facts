  "facts": [
    {
      "id": 1,
      "text": "Lake Erie Beach evolved from seasonal cottages to a year‑round community after tourism waned and the 1992 fire destroyed the Point Breeze Hotel.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
