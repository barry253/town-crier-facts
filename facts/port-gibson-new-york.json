      "id": 2,
      "text": "The Port Gibson United Methodist Church, built in 1871, sits on Greig Street and is listed on both state and national historic registers.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
