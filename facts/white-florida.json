  "facts": [
    {
      "id": 1,
      "text": "White City earned its name from the utopian Great White City of Chicago’s 1893 World’s Fair, a design vision by Daniel Burnham.",
      "sourceSentenceIds": [
        4,
        16
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://visitstlucie.com/white-city/"
    },
    {
      "id": 2,
      "text": "In 1894 Danish settlers founded the White City Improvement Club to preserve their cultural heritage.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://unitedstatesghosttowns.com/white-city-florida-ghost-town/"
    },
    {
      "id": 3,
      "text": "Midway Road mirrors the main avenue of Chicago’s World’s Fair, echoing the town’s original design inspiration.",
      "sourceSentenceIds": [
        1,
        21
      ],
      "sourceLabels": [
        "Web source 2",
        "Web source 2"
      ],
      "source": "https://unitedstatesghosttowns.com/white-city-florida-ghost-town/"
    },
    {
      "id": 4,
      "text": "The Captain Hammond House and White City Marketplace remain as tangible reminders of the once‑bustling Danish community.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://unitedstatesghosttowns.com/white-city-florida-ghost-town/"
    },
    {
      "id": 5,
      "text": "Henry Flagler’s railroad enabled Danish settlers to buy land and establish White City in Florida.",
      "sourceSentenceIds": [
        14,
        16
      ],
      "sourceLabels": [
        "Web source 2",
        "Web source 2"
      ],
      "source": "https://unitedstatesghosttowns.com/white-city-florida-ghost-town/"
    },
    {
      "id": 6,
      "text": "Today White City keeps a small‑town atmosphere while preserving its unique link to the Chicago World’s Fair.",
      "sourceSentenceIds": [
        15
      ],
