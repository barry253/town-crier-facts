  "facts": [
    {
      "id": 1,
      "text": "Kenvil was originally called McCainsville, a small hamlet in Roxbury Township by the 1870s with farmsteads and a post office.",
      "sourceSentenceIds": [
        2,
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Kenvil%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "The town hosted the second dynamite plant in the U.S., founded in 1872 by Atlantic Giant Powder Company, later owned by Hercules.",
      "sourceSentenceIds": [
        9,
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Kenvil%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "Hercules Powder Company explosions killed six in 1934, 51 in 1940, and shattered windows in 1989.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Kenvil%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "Route 46 cuts through Kenvil, linking Dover to the east and Netcong to the west.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Kenvil%2C_New_Jersey"
    },
    {
      "id": 5,
      "text": "The Lamington River originates from Sunset Lake in Kenvil and feeds the Raritan River watershed.",
      "sourceSentenceIds": [
        16
      ],
