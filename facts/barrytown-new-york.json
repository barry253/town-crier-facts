  "facts": [
    {
      "id": 1,
      "text": "Barrytown’s First National Bank opened in 1865, and for decades tobacco, chocolate factories, a hotel, and a village newspaper thrived.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.redhookny.gov/193/History"
    },
    {
      "id": 2,
      "text": "Maizeland, a cherished architectural landmark, still stands as a testament to Barrytown’s historic character.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.redhookny.gov/193/History"
    },
    {
      "id": 3,
      "text": "Lower Red Hook Landing was renamed Barrytown in the 1830s, marking the town’s early development.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.redhookny.gov/193/History"
    },
    {
      "id": 4,
      "text": "Until 1956, three New York Central trains a day stopped at Barrytown’s depot, linking the hamlet to Albany and New York City.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Red_Hook%2C_New_York"
    },
    {
      "id": 5,
      "text": "Before European settlers arrived in the 1650s, the Esopus and Sepasco Indians inhabited the Barrytown area.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.redhookny.gov/193/History"
    },
    {
      "id": 6,
      "text": "River commerce ended in 1851 when the Hudson River Railroad opened, ending regular passenger and freight boat stops at Barrytown.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
