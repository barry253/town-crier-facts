  "facts": [
    {
      "id": 1,
      "text": "Founded in 1793 by Revolutionary War officer John Hardenbergh, Auburn was first called Hardenbergh’s Corners.",
      "sourceSentenceIds": [
        6,
        9
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Auburn%2C_New_York"
    },
    {
      "id": 2,
      "text": "When Auburn became Cayuga County’s seat in 1805, the settlement was renamed from Hardenbergh’s Corners.",
      "sourceSentenceIds": [
        2,
        11
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Auburn%2C_New_York"
    },
    {
      "id": 3,
      "text": "Auburn Prison, opened in 1816, introduced the Auburn system of collective work and silence.",
      "sourceSentenceIds": [
        7,
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Auburn%2C_New_York"
    },
    {
      "id": 4,
      "text": "The Harriet Tubman Home for the Aged in Auburn, a National Register site, honors the famed abolitionist.",
      "sourceSentenceIds": [
        8,
        17,
        19
      ],
      "sourceLabels": [
        "Wikipedia",
