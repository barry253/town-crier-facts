  "facts": [
    {
      "id": 1,
      "text": "Geneva was incorporated as a village in 1806, then again in 1812 and 1871.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.visitfingerlakes.com/plan-your-trip/ontario-county-ny/geneva/"
    },
    {
      "id": 2,
      "text": "The city’s name likely comes from Geneva, Switzerland, because of its lakeside setting, though some say it has Native American roots.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.visitfingerlakes.com/plan-your-trip/ontario-county-ny/geneva/"
    },
    {
      "id": 3,
      "text": "Historic Geneva, founded in 1883, preserves the town’s past through the Geneva History Museum, Rose Hill Mansion, and John Johnston House.",
      "sourceSentenceIds": [
        1,
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://historicgeneva.org/"
    },
    {
      "id": 4,
      "text": "Belhurst Castle, a historic landmark on Seneca Lake, draws visitors for weddings and romantic getaways.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.visitfingerlakes.com/plan-your-trip/ontario-county-ny/geneva/"
    },
    {
      "id": 5,
      "text": "Geneva hosts Hobart and William Smith Colleges and Cornell’s New York State Agricultural Experiment Station, anchoring higher education in the area.",
      "sourceSentenceIds": [
        29
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.visitfingerlakes.com/plan-your-trip/ontario-county-ny/geneva/"
    },
    {
      "id": 6,
      "text": "In 2015, Geneva earned All-America City status and has repeatedly appeared on the Playful City USA list.",
