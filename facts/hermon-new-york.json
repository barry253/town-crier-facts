    },
    {
      "id": 3,
      "text": "The town of Hermon was formed from parts of De Kalb and Edwards on April 17, 1830.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Hermon_(hamlet)%2C_New_York"
    },
    {
      "id": 4,
      "text": "Hermon held village status from 1887 until its dissolution in 2016.",
