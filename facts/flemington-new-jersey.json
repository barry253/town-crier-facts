  "facts": [
    {
      "id": 1,
      "text": "Flemington takes its name from Irish‑born tavern owner Samuel Fleming, whose home once called Fleming Castle still stands on Bonnell Street.",
      "sourceSentenceIds": [
        4,
        5
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Flemington%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "The borough’s historic district covers 54 % of its parcels, showcasing Greek Revival, Italianate, Queen Anne, and Victorian architecture.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.historicflemington.com/boards/historic"
    },
    {
      "id": 3,
      "text": "The Hunterdon County Historical Society, based in Flemington, offers a free self‑guided walking tour in an eight‑page brochure available online and at the society’s office.",
      "sourceSentenceIds": [
        2,
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://hunterdonhistory.org/hunterdon-history/flemington-walking-tour/"
    },
    {
      "id": 4,
      "text": "Stangl Pottery Factory’s three kilns now house an art gallery, farmers’ market, coffee shop, restaurant, and concert venue.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://hunterdonhistory.org/hunterdon-history/flemington-walking-tour/"
    },
    {
      "id": 5,
      "text": "Flemington’s courthouse was the site of the Lindbergh Trial, a nationally famous case.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Flemington%2C_New_Jersey"
    },
    {
      "id": 6,
      "text": "Children’s Choir School at 3 Chorister Place, originally a stable, ran from 1895‑1958 and helped start the national junior choir movement.",
