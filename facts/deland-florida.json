  "facts": [
    {
      "id": 1,
      "text": "DeLand was founded on December 6 1876 by New York businessman Henry Addison DeLand.",
      "sourceSentenceIds": [
        15,
        17,
        19
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://historicdeland.com/"
    },
    {
      "id": 2,
      "text": "Dubbed the Athens of Florida, DeLand boasts a historic downtown that once rivaled New York’s cultural scene.",
      "sourceSentenceIds": [
        6,
        30
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://historicdeland.com/"
    },
    {
      "id": 3,
      "text": "Stetson University, Florida’s oldest private college, began as DeLand Academy in 1883 before moving to DeLand in 1887.",
      "sourceSentenceIds": [
        14,
        20,
        21
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://historicdeland.com/"
    },
    {
      "id": 4,
      "text": "The 1886 Stetson Mansion, a National Historic Landmark, crowns DeLand’s downtown skyline.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://historicdeland.com/"
    },
    {
      "id": 5,
      "text": "DeLand earned the title Skydiving Capital of the World, hosting the annual World Parachuting Championships.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://historicdeland.com/"
    },
    {
      "id": 6,
      "text": "Since 1992, DeLand has celebrated the DeLand Fall Festival of the Arts, a two‑day event each Thanksgiving weekend.",
