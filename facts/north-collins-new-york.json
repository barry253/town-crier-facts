  "facts": [
    {
      "id": 1,
      "text": "North Collins was founded in 1852 as the Town of Shirley, carved from the northern part of Collins.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/North_Collins%2C_New_York"
    },
    {
      "id": 2,
      "text": "The town adopted the name North Collins in 1853, shortly after its founding.",
      "sourceSentenceIds": [
        25
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/North_Collins%2C_New_York"
    },
    {
      "id": 3,
      "text": "In 1911, the village of North Collins incorporated, separating itself from the surrounding town.",
      "sourceSentenceIds": [
        26
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/North_Collins%2C_New_York"
    },
    {
      "id": 4,
      "text": "The North Collins Historical Society, founded in 1976, runs a museum that houses artifacts, documents, and photographs of the town.",
      "sourceSentenceIds": [
        1,
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://museumsdatabase.com/museums/view/22469"
    },
    {
      "id": 5,
      "text": "The society also maintains a research library open by appointment, offering books, maps, newspapers, and genealogical records.",
      "sourceSentenceIds": [
        7,
        19
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://museumsdatabase.com/museums/view/22469"
    },
    {
      "id": 6,
      "text": "The Gamel Hexadecagon Barn, an eight‑sided landmark, was listed on the National Register of Historic Places in 1984.",
