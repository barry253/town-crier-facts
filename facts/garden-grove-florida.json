  "facts": [
    {
      "id": 1,
      "text": "Garden Grove was platted in 1924 as part of a Florida Land Boom that spread from Miami to the west coast.",
      "sourceSentenceIds": [
        22
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://hernandopast.wordpress.com/2020/01/19/garden-grove-historic-marker/"
    },
    {
      "id": 2,
      "text": "The historic marker for Garden Grove was dedicated on September 7, 2019, by the Historic Hernando Preservation Society.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://hernandopast.wordpress.com/2020/01/19/garden-grove-historic-marker/"
    },
    {
      "id": 3,
      "text": "Garden Grove originally covered about 13,000 acres and was planned to include over 1,600 residential, commercial, and small farm lots.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://hernandopast.wordpress.com/2020/01/19/garden-grove-historic-marker/"
    },
    {
      "id": 4,
      "text": "County roads were built from Spring Lake and Aripeka to Garden Grove as the community expected a large influx of new residents.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://hernandopast.wordpress.com/2020/01/19/garden-grove-historic-marker/"
    },
    {
      "id": 5,
      "text": "The first house of worship in Garden Grove was the Methodist‑Episcopal Church South, followed by a one‑room school that operated until 1948.",
      "sourceSentenceIds": [
        29,
        30
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://hernandopast.wordpress.com/2020/01/19/garden-grove-historic-marker/"
    },
    {
      "id": 6,
      "text": "Garden Grove’s main street, Station Boulevard, was designed to lead to a train depot and was part of the town’s original grand plan.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 1"
      ],
