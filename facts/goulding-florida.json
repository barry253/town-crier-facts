  "facts": [
    {
      "id": 1,
      "text": "Goulding earned its name when the Florida East Coast Railway built a siding in 1903, operated by Lyman Goulds.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Goulds%2C_Florida"
    },
    {
      "id": 2,
      "text": "Originally called \"Gould's Siding,\" the community later shortened its name to Goulds.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Goulds%2C_Florida"
    },
    {
      "id": 3,
      "text": "Homesteaders first settled the area in 1900, laying the groundwork for what would become Goulding.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Goulds%2C_Florida"
    },
    {
      "id": 4,
      "text": "In its early days, Goulds earned a reputation as a rough town, with saloons catering to itinerant field workers.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Goulds%2C_Florida"
    },
    {
      "id": 5,
      "text": "Packing houses were devastated by a 1919 tornado and the 1926 Miami Hurricane, yet they were rebuilt in the years that followed.",
      "sourceSentenceIds": [
