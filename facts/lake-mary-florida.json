  "facts": [
    {
      "id": 1,
      "text": "Lake Mary takes its name from Mary Sundell, the wife of Reverend J.F. Sundell, who settled on the lake’s northern shore.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lake_Mary%2C_Florida"
    },
    {
      "id": 2,
      "text": "The town’s first settler, Frank Evans—a tight‑rope walker and chemist—established Lake Mary in 1882.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lake_Mary%2C_Florida"
    },
    {
      "id": 3,
      "text": "Frank Evans also built the original Lake Mary Elementary School, shaping the city’s early education.",
      "sourceSentenceIds": [
        19
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lake_Mary%2C_Florida"
    },
    {
      "id": 4,
      "text": "Inside the Lake Mary Chamber of Commerce Building, a small museum chronicles the city’s own history.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lake_Mary%2C_Florida"
    },
    {
      "id": 5,
      "text": "Lake Mary sits just 19 miles from downtown Orlando, making it a quiet suburb of the Greater Orlando area.",
      "sourceSentenceIds": [
