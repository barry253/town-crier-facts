    },
    {
      "id": 2,
      "text": "The village’s Civil War cenotaph, the Avon Inn, and the Opera Block together showcase Avon’s rich cultural heritage.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
