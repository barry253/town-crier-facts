  "facts": [
    {
      "id": 1,
      "text": "McGraw was settled in 1808 and became an incorporated village in 1869.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://villageofmcgraw.gov/"
    },
    {
      "id": 2,
      "text": "The village sits in a narrow valley about half a mile wide, running east from Cortland.",
      "sourceSentenceIds": [
        15
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://villageofmcgraw.gov/"
    },
    {
      "id": 3,
      "text": "McGraw’s Main Street Historic District covers the entire business core, two churches, the library, and many early homes.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.livingplaces.com/NY/Cortland_County/McGraw_Village/Main_Street_Historic_District.html"
    },
    {
      "id": 4,
      "text": "The Lamont Memorial Library, a two‑story Greek‑Revival frame building with a pedimented portico, was erected in 1845.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.livingplaces.com/NY/Cortland_County/McGraw_Village/Main_Street_Historic_District.html"
    },
    {
      "id": 5,
      "text": "Both the Main Street Historic District and the Presbyterian Church of McGraw earned spots on the National Register of Historic Places.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://villageofmcgraw.gov/"
    },
    {
      "id": 6,
      "text": "An original livery stable once stood where the village’s historic core now lies.",
