    },
    {
      "id": 2,
      "text": "The city’s name changed from “Orange Port” to Port Orange when passenger and freight stations on Dunlawton Avenue merged in 1924.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
