    {
      "id": 2,
      "text": "The 1841 New York & Erie Railroad built a station in Monsey, linking the hamlet to the wider region.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Monsey%2C_New_York"
    },
    {
      "id": 3,
      "text": "The Houser‑Conklin House, built in 1775, sits in Monsey and was added to the National Register of Historic Places in 2010.",
      "sourceSentenceIds": [
        9,
        10
      ],
      "sourceLabels": [
