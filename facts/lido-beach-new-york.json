  "facts": [
    {
      "id": 1,
      "text": "Lido Beach’s name comes from Venice’s Lido, with \"lido\" meaning beach in Italian.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lido_Beach%2C_New_York"
    },
    {
      "id": 2,
      "text": "The town began in the early 1900s when William H. Reynolds gathered investors to build a resort on Long Beach Island.",
      "sourceSentenceIds": [
        13,
        14,
        17
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lido_Beach%2C_New_York"
    },
    {
      "id": 3,
      "text": "Reynolds dredged Reynolds Channel, making the island easier to reach by boat and sparking the growth of Long Beach’s resort scene.",
      "sourceSentenceIds": [
        18,
        19
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lido_Beach%2C_New_York"
    },
    {
      "id": 4,
      "text": "During World War II, the Navy used the Lido Beach Hotel as a discharge station, reviving the area after wartime decline.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.lidodunes.org/From-Sandbar-to-Community"
    },
    {
      "id": 5,
      "text": "In the Cold War, a Nike surface‑to‑air missile defense site stood on Lido Beach’s north boulevard, now the site of a school.",
      "sourceSentenceIds": [
        10,
        11
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.lidodunes.org/From-Sandbar-to-Community"
    },
    {
      "id": 6,
      "text": "Soldiers stationed at Lido Beach patrolled the shore with K‑9 dogs to guard against German submarine agents, echoing nearby Amagansett’s wartime vigilance.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
