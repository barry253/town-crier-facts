  "facts": [
    {
      "id": 1,
      "text": "Argyle’s name comes from the Scottish Argyllshire, honoring the Highland settlers who arrived after the French and Indian War.",
      "sourceSentenceIds": [
        3,
        4
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Argyle_(town)%2C_New_York"
    },
    {
      "id": 2,
      "text": "The 1764 Argyle Patent, issued by Albany County, laid the legal groundwork for the town’s first settlement.",
      "sourceSentenceIds": [
        12,
        30
      ],
      "sourceLabels": [
        "Web source 1",
        "Wikipedia"
      ],
      "source": "https://grokipedia.com/page/argyle_village_new_york"
    },
    {
      "id": 3,
      "text": "During the 19th century, Argyle was a key stop on the Underground Railroad, with the County Poor House serving as a refuge for escaping slaves.",
      "sourceSentenceIds": [
        9,
        22
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Argyle_(town)%2C_New_York"
    },
    {
      "id": 4,
      "text": "The village’s brick office, built in 1827, helped manage the growing agricultural and civil affairs of early Washington County.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/argyle_village_new_york"
    },
    {
      "id": 5,
      "text": "Argyle’s rural character is reflected in its historic mills and modern efforts to preserve community infrastructure and scenic Hudson Valley landscapes.",
