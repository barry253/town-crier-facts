  "facts": [
    {
      "id": 1,
      "text": "Kathleen’s name may honor Kathleen deForest, a settler’s daughter, or the town of Kathleen, Georgia, where early residents once lived.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.floridasmart.com/city-guide/kathleen"
    },
    {
      "id": 2,
      "text": "The town’s roots run deep in agriculture and ranching, a legacy still visible in its rolling rural landscapes.",
      "sourceSentenceIds": [
        2,
        11
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.floridasmart.com/city-guide/kathleen"
    },
    {
      "id": 3,
      "text": "The railroad’s arrival in the early 1900s helped Kathleen grow by linking local citrus and livestock to larger markets.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.floridasmart.com/city-guide/kathleen"
    },
    {
      "id": 4,
      "text": "Kathleen Baptist Church, founded in the early 1900s, has long been a community cornerstone for residents.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.floridasmart.com/city-guide/kathleen"
    },
    {
      "id": 5,
      "text": "Kathleen High School, established in 1928, ranks among Polk County’s oldest high schools.",
      "sourceSentenceIds": [
