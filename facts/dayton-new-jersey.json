  "facts": [
    {
      "id": 1,
      "text": "Dayton began as Cross Roads, named for the crossroads of Crossweeksung Trail, Ridge Road, and Culver Road, locally called Five Corners.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Dayton,_New_Jersey"
    },
    {
      "id": 2,
      "text": "Around 1750 James Whitlock built the Whitlock Tavern at the crossroads, offering lodging and provisions to travelers and soldiers during the Revolutionary War.",
      "sourceSentenceIds": [
        7,
        8,
        9
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Dayton,_New_Jersey"
    },
    {
      "id": 3,
      "text": "Dayton sits where Route 130 meets local roads, draining southwest toward Devils Brook and northeast toward Lawrence Brook, tributaries of the Millstone and Raritan Rivers.",
      "sourceSentenceIds": [
        18,
        19
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Dayton%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "Dayton lies within South Brunswick Township in southwestern Middlesex County, bordered north by Deans and west by Monmouth Junction.",
