  "facts": [
    {
      "id": 1,
      "text": "Great Neck Plaza’s name traces back to Anne Hutchinson, who was called “Madnan’s Neck” by local legend.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Great_Neck%2C_New_York"
    },
    {
      "id": 2,
      "text": "Edward Hare, the village’s first constable, helped push for Madnan’s Neck’s independence in the early days.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Great_Neck%2C_New_York"
    },
    {
      "id": 3,
      "text": "The Great Neck Alert Fire Company, founded in 1901, still serves the village’s historic fire hall.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Great_Neck%2C_New_York"
    },
    {
      "id": 4,
      "text": "During the late 1800s, African Americans and European immigrants settled on Steamboat Road, working as estate gardeners and masons.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://greatneckplaza.com/history"
    },
    {
      "id": 5,
      "text": "Two late Italianate buildings in the plaza originally housed ground‑floor stores and upper‑floor apartments.",
      "sourceSentenceIds": [
        19
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://greatneckplaza.com/history"
    },
    {
      "id": 6,
      "text": "The village’s history page notes that post‑World War II suburban growth reshaped Great Neck Plaza’s streets and homes.",
