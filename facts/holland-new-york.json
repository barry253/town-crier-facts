  "facts": [
    {
      "id": 1,
      "text": "Holland’s name comes from the Holland Land Company, the Dutch syndicate that owned most of western New York in the 1790s.",
      "sourceSentenceIds": [
        7,
        11
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Holland%2C_New_York"
    },
    {
      "id": 2,
      "text": "The Holland Historical Society now calls the original 1894‑96 fire hall on Main Street its home, preserving the town’s early heritage.",
      "sourceSentenceIds": [
        2,
        5
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Holland%2C_New_York"
    },
    {
      "id": 3,
      "text": "In 1871 the Buffalo‑New York‑Philadelphia Railroad reached Holland, linking the town to larger markets and sparking economic growth.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/holland_new_york"
    },
    {
      "id": 4,
      "text": "Holland sits in Erie County’s southeast corner, just southeast of Buffalo and part of the county’s “Southtowns.”",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Holland%2C_New_York"
    },
    {
      "id": 5,
      "text": "The East Branch of Cazenovia Creek winds northward through Holland, adding a gentle waterway to the town’s landscape.",
      "sourceSentenceIds": [
        15
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Holland%2C_New_York"
    },
    {
      "id": 6,
      "text": "Every spring, Holland hosts its annual Tulip Festival, drawing visitors to celebrate the town’s Dutch heritage with blooming tulips.",
      "sourceSentenceIds": [
        22
