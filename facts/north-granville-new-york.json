  "facts": [
    {
      "id": 1,
      "text": "North Granville lies along New York State Route 22, just five miles northwest of the village of Granville.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/North_Granville%2C_New_York"
    },
    {
      "id": 2,
      "text": "The Slate Valley Museum, founded in 1994, displays slate‑mining artifacts and interactive exhibits that trace the region’s industry.",
      "sourceSentenceIds": [
        5,
        12
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.discovergranvilleny.com/arts-culture"
    },
    {
      "id": 3,
      "text": "Pember Library & Museum, opened in 1909 by Franklin Pember, holds more than 7,000 natural‑history specimens from his private collection.",
      "sourceSentenceIds": [
        2,
        27
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.discovergranvilleny.com/arts-culture"
    },
    {
      "id": 4,
      "text": "Hicks Orchard, New York State’s oldest U‑pick orchard, was founded in 1905 and still offers fresh fruit to visitors.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.discovergranvilleny.com/arts-culture"
    },
    {
      "id": 5,
      "text": "Each fall, North Granville hosts the Lighted Tractor Parade, a festival that celebrates local heritage and attracts regional visitors.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.discovergranvilleny.com/about/"
    },
    {
      "id": 6,
      "text": "Historic buildings in North Granville echo its colored slate industry, which shaped both the town’s architecture and identity.",
