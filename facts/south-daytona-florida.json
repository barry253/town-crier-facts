  "facts": [
    {
      "id": 1,
      "text": "South Daytona began life as the town of Blake, named after Boston businessman Alpheus P. Blake.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/South_Daytona%2C_Florida"
    },
    {
      "id": 2,
      "text": "Soon after its founding, a railroad station was built at Big Tree Crossing, linking the area to the wider rail network.",
      "sourceSentenceIds": [
        2,
        3
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/South_Daytona%2C_Florida"
    },
    {
      "id": 3,
      "text": "In 1938, residents of Blake successfully broke away from Daytona Beach, establishing the incorporated town of South Daytona.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/South_Daytona%2C_Florida"
    },
    {
      "id": 4,
      "text": "Four years later, in 1951, South Daytona was officially incorporated as a city, solidifying its municipal status.",
      "sourceSentenceIds": [
        19
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/South_Daytona%2C_Florida"
    },
    {
      "id": 5,
      "text": "South Daytona became the second community in the Halifax area to install a sanitary sewer system, improving public health.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/South_Daytona%2C_Florida"
    },
    {
      "id": 6,
      "text": "Located on the Halifax River, South Daytona lies just south of Daytona Beach, offering waterfront views.",
      "sourceSentenceIds": [
        20
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/South_Daytona%2C_Florida"
    }
  ]
