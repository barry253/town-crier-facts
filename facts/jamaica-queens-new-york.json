  "facts": [
    {
      "id": 1,
      "text": "Jamaica’s name comes from the Munsee word “yameco,” meaning beaver, a fact noted by both Wikipedia and the Downtown Jamaica website.",
      "sourceSentenceIds": [
        1,
        5
      ],
      "sourceLabels": [
        "Web source 2",
        "Wikipedia"
      ],
      "source": "https://www.downtownjamaica.org/history-culture/history"
    },
    {
      "id": 2,
      "text": "The 1900 clock on Jamaica Avenue earned New York City landmark status in 1981, a historic reminder of the area’s early infrastructure.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.downtownjamaica.org/history-culture/history"
    },
    {
      "id": 3,
      "text": "Across from the Museum sits the former First Reformed Dutch Church of Jamaica, now a National Register‑listed performing‑arts center.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Jamaica%2C_Queens"
    },
    {
      "id": 4,
      "text": "By 1834 the Brooklyn and Jamaica Railroad had completed a line into Jamaica, linking the borough to the rest of Long Island.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Jamaica%2C_Queens"
    },
    {
      "id": 5,
      "text": "Jamaica hosted the first state‑wide civil‑rights convention in New York, a pioneering gathering for Black activists.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.downtownjamaica.org/history-culture/history"
    },
    {
      "id": 6,
      "text": "The former Jamaica Savings Bank at 161‑02 Jamaica Ave, built in 1898, is Queens’ finest Beaux‑Arts landmark.",
