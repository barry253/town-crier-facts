  "facts": [
    {
      "id": 1,
      "text": "Bokeelia sits at the northern end of Pine Island, bordered by Pine Island Sound, Charlotte Harbor, and Matlacha Pass.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bokeelia%2C_Florida"
    },
    {
      "id": 2,
      "text": "The original settlement lies on Bokeelia Island, connected by a short bridge on Stringfellow Road, ending at Main Street along Charlotte Harbor.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bokeelia%2C_Florida"
    },
    {
      "id": 3,
      "text": "The area was first inhabited by Calusa Indians, a mound‑building culture that thrived from 500 CE until the mid‑1700s.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/Bokeelia,_Florida"
    },
    {
      "id": 4,
      "text": "The Museum of the Islands, housed in the former island library built by volunteers in the early 1960s, showcases local fishing and island history.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.museumoftheislands.com/"
    },
    {
      "id": 5,
      "text": "Bokeelia is home to one of Lee County’s first pioneer families, the Padillas, who arrived via Cayo Costa.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bokeelia%2C_Florida"
    },
    {
      "id": 6,
      "text": "Little Bokeelia Island, once owned by Charles Burgess, is a private island off Bokeelia.",
