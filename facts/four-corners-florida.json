  "facts": [
    {
      "id": 1,
      "text": "Four Corners earned its name from the rare quadripoint where Lake, Orange, Osceola, and Polk counties meet, a unique geographic marker.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Four_Corners_Florida"
    },
    {
      "id": 2,
      "text": "In 1993, Splendid China opened on a 75‑acre site, showcasing over 60 one‑tenth‑scale replicas of Chinese landmarks, costing $100 million.",
      "sourceSentenceIds": [
        3,
        12,
        13
      ],
      "sourceLabels": [
        "Web source 2",
        "Wikipedia"
      ],
      "source": "https://grokipedia.com/page/Four_Corners_Florida"
    },
    {
      "id": 3,
      "text": "After a decade of abandonment, the former park was cleared in 2018 and reopened as Margaritaville Resort Orlando in 2019, a Jimmy Buffett‑themed complex.",
      "sourceSentenceIds": [
        4,
        14
      ],
      "sourceLabels": [
        "Web source 2",
        "Wikipedia"
      ],
      "source": "https://grokipedia.com/page/Four_Corners_Florida"
    },
    {
      "id": 4,
      "text": "Four Corners is the only community in Florida that lies within four counties simultaneously.",
      "sourceSentenceIds": [
        24
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Four_Corners%2C_Florida"
    },
    {
      "id": 5,
      "text": "The area experiences more lightning strikes per square mile than any other place in the United States.",
