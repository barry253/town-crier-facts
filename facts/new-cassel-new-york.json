  "facts": [
    {
      "id": 1,
      "text": "New Cassel was founded in the mid‑1700s by formerly enslaved African American farmers.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Cassel%2C_New_York"
    },
    {
      "id": 2,
      "text": "The town’s name honors Hesse‑Cassel settlers, many Hessian mercenaries who stayed after the war.",
      "sourceSentenceIds": [
        4,
        16
      ],
      "sourceLabels": [
        "Web source 2",
        "Wikipedia"
      ],
      "source": "https://www.longislandexchange.com/towns/new-cassel/"
    },
    {
      "id": 3,
      "text": "The Long Island Rail Road’s Main Line cuts through New Cassel, yet no station sits inside the hamlet.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Cassel%2C_New_York"
    },
    {
      "id": 4,
      "text": "Walk west from the center of New Cassel and reach the Westbury LIRR station in minutes.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Cassel%2C_New_York"
    },
    {
      "id": 5,
      "text": "After World War II, New Cassel welcomed many Black and Latino veterans, later growing into a Haitian and Latino enclave.",
      "sourceSentenceIds": [
        19,
        20
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Cassel%2C_New_York"
    },
    {
      "id": 6,
      "text": "Today, New Cassel’s culture is heavily influenced by Latin American traditions, reflected in festivals and cuisine.",
