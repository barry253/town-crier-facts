  "facts": [
    {
      "id": 1,
      "text": "The Macedon Academy, a 1841 schoolhouse, now houses the Macedon Historical Society museum.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://museumsdatabase.com/museums/view/22038"
    },
    {
      "id": 2,
      "text": "The Macedon Historical Society was founded in 1961 to preserve and promote the town’s heritage.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://museumsdatabase.com/museums/view/22038"
    },
    {
      "id": 3,
      "text": "Macedon once thrived as an inland port on the Erie Canal, located near Lock 30 completed in 1825.",
      "sourceSentenceIds": [
        22
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Macedon_(hamlet)%2C_New_York"
    },
    {
      "id": 4,
      "text": "Lock 30 remains operational today and is part of the Erie Canalway National Heritage Corridor.",
      "sourceSentenceIds": [
        24,
        28
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Macedon_(hamlet)%2C_New_York"
    },
    {
      "id": 5,
      "text": "The village incorporated in 1856 and later disincorporated on March 31, 2017.",
      "sourceSentenceIds": [
        23,
        30
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Macedon_(hamlet)%2C_New_York"
    },
    {
      "id": 6,
      "text": "In the mid‑late 19th century, Bickford & Huffman manufactured grain drills in Macedon before joining Oliver Farm Equipment.",
