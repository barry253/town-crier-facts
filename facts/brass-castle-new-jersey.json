  "facts": [
    {
      "id": 1,
      "text": "Brass Castle takes its name from Jacob Brass, whose cabin was locally called a “castle.”",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://washington-twp-warren.org/community/local_history/brass_castle.php"
    },
    {
      "id": 2,
      "text": "The community sits at the foot of Montana Mountain, bordered by the Morris Canal, Brass Castle Creek, and Pohatcong Creek.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://washington-twp-warren.org/community/local_history/brass_castle.php"
    },
    {
      "id": 3,
      "text": "By 1874 the dispersed settlement featured a school, sawmill, gristmill, several smithies, and about a dozen homes.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://washington-twp-warren.org/community/local_history/brass_castle.php"
    },
    {
      "id": 4,
      "text": "Early industry also included a brickyard and a paper mill, supporting the growing local economy.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://washington-twp-warren.org/community/local_history/brass_castle.php"
    },
    {
      "id": 5,
      "text": "The original Brass Castle Schoolhouse, built in the 1800s, now serves as a private residence on Little Philadelphia Road.",
      "sourceSentenceIds": [
        20
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://washington-twp-warren.org/community/local_history/brass_castle.php"
    },
    {
      "id": 6,
      "text": "Since 1955, Brass Castle has expanded markedly, evolving into a suburb of Washington Borough.",
      "sourceSentenceIds": [
        19
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://washington-twp-warren.org/community/local_history/brass_castle.php"
