  "facts": [
    {
      "id": 1,
      "text": "Matawan was founded in 1686 by Scotch Presbyterians at the crossing of two Indian trails.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://matawanhistoricalsociety.org/history/"
    },
    {
      "id": 2,
      "text": "In 1857 the town of Middletown Point was renamed Matavan Township after it was incorporated, named for Matawan Creek.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Matawan%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "The first public library in Matawan opened in 1861, later becoming the official free library in 1903 on Main Street.",
      "sourceSentenceIds": [
        12,
        13
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://mapl.org/local-history/"
    },
    {
      "id": 4,
      "text": "The Matawan Train Station, built in 1875, helped keep the town a transportation hub even as Matawan Creek silting cut off ship trade.",
      "sourceSentenceIds": [
        1,
        28
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Matawan%2C_New_Jersey"
    },
    {
      "id": 5,
      "text": "Matawan’s historic downtown features dozens of 18th‑ and 19th‑century houses, many still privately owned today.",
      "sourceSentenceIds": [
        25,
