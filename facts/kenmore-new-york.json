  "facts": [
    {
      "id": 1,
      "text": "Kenmore was named by Frederick Parkhurst in his 1925 book, echoing the Erie Railroad station that first called the area Kenmore.",
      "sourceSentenceIds": [
        1,
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://kenmoreny.gov/community/history/"
    },
    {
      "id": 2,
      "text": "Incorporated on September 5, 1899, Kenmore ranks among New York’s most densely populated villages, a fact highlighted by local history sources.",
      "sourceSentenceIds": [
        10,
        11
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.villageofkenmore.com/about-kenmore.html"
    },
    {
      "id": 3,
      "text": "The American Planning Association honored Kenmore in 2009 as one of the Top 10 Great Neighborhoods in the United States.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Kenmore%2C_New_York"
    },
    {
      "id": 4,
      "text": "In 2014, Kenmore became a national finalist for the All‑America City Award, a rare distinction for a community its size.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.villageofkenmore.com/about-kenmore.html"
    },
    {
      "id": 5,
      "text": "Kenmore Village Hall, listed on the National Register of Historic Places in 1983, now serves as the town’s historic municipal building.",
      "sourceSentenceIds": [
        6,
        24
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Kenmore%2C_New_York"
    },
    {
      "id": 6,
      "text": "Locally called “Ken‑Ton,” Kenmore sits just north of Buffalo and is known as “Buffalo’s First Suburb.”",
