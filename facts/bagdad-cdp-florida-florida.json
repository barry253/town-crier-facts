  "facts": [
    {
      "id": 1,
      "text": "Bagdad was named after Baghdad, Iraq, by lumber businessman Joseph Forsyth, who opened a sawmill there in 1840.",
      "sourceSentenceIds": [
        2,
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bagdad%2C_Florida"
    },
    {
      "id": 2,
      "text": "The Historic Bagdad Village Museum, once the New Providence Missionary Baptist Church, showcases the town’s lumber heritage and African American history.",
      "sourceSentenceIds": [
        1,
        10
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.florida-backroads-travel.com/bagdad-village-historic-district.html"
    },
    {
      "id": 3,
      "text": "Bagdad’s original mills—saw, grist, shingle, cotton textile, and a bucket factory—were built along Pond Creek in the early 19th century.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.bagdadliving.com/history"
    },
    {
      "id": 4,
      "text": "In 1987, the Village of Bagdad earned a place on the National Register of Historic Places for its well-preserved 19th‑century architecture.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.bagdadliving.com/history"
    },
    {
      "id": 5,
      "text": "The town’s Blackwater River runs nearby, and today residents focus on restoring its natural and archaeological resources.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.bagdadliving.com/history"
    },
    {
      "id": 6,
      "text": "Bagdad sits 15 miles northeast of Pensacola, along Main Street, and is part of the Pensacola–Ferry Pass–Brent Metropolitan Statistical Area.",
      "sourceSentenceIds": [
        9,
        13
      ],
      "sourceLabels": [
        "Web source 2",
        "Wikipedia"
      ],
      "source": "https://www.florida-backroads-travel.com/bagdad-village-historic-district.html"
    }
  ]
