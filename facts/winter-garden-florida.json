  "facts": [
    {
      "id": 1,
      "text": "Winter Garden sits in western Orange County, Florida, just 14 miles west of downtown Orlando and part of the Orlando metro area.",
      "sourceSentenceIds": [
        14,
        15
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Winter_Garden%2C_Florida"
    },
    {
      "id": 2,
      "text": "Settlers first arrived in the 1850s, lured by the fertile muck land along Lake Apopka.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.cwgdn.com/398/History"
    },
    {
      "id": 3,
      "text": "The Orange Belt Railroad’s arrival drove Winter Garden’s growth, boosting citrus, turpentine, and lumber into the 20th century.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Winter_Garden%2C_Florida"
    },
    {
      "id": 4,
      "text": "Winter Garden still celebrates its citrus roots, with oranges and grapefruits remaining symbols of the town.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Winter_Garden%2C_Florida"
    },
    {
      "id": 5,
      "text": "The Winter Garden Heritage Foundation preserves the city’s history while fostering innovative cultural experiences.",
