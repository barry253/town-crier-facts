  "facts": [
    {
      "id": 1,
      "text": "Mauricetown Historical Society, founded in June 1983, preserves the town’s ship‑captain heritage and showcases artifacts from the Lenape Indians to local shipbuilding.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.mauricetown.com/historical-society/"
    },
    {
      "id": 2,
      "text": "The society’s museum sits in the former home of Captain Edward Compton, a local sea captain whose house once overlooked the Maurice River.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://visitingamuseum.com/2022/07/01/mauricetown-historical-society-1229-front-street-mauricetown-nj-08329/"
    },
    {
      "id": 3,
      "text": "Visitors can stroll through the historic 1840 Hoy House, recently restored to its original appearance by the society’s volunteers.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://visitingamuseum.com/2022/07/01/mauricetown-historical-society-1229-front-street-mauricetown-nj-08329/"
    },
    {
      "id": 4,
      "text": "The museum’s front foyer houses a military collection that traces Mauricetown’s history from indigenous peoples to 19th‑century shipbuilding.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://visitingamuseum.com/2022/07/01/mauricetown-historical-society-1229-front-street-mauricetown-nj-08329/"
    },
    {
      "id": 5,
      "text": "Mauricetown’s name honors its shellfish industry, a legacy that shaped the town’s early economy and culture.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Commercial_Township%2C_New_Jersey"
    },
    {
      "id": 6,
      "text": "The town’s streets feature Federalist and Victorian homes of former ship captains, offering a walking tour of early American architecture.",
      "sourceSentenceIds": [
        12
