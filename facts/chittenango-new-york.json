  "facts": [
    {
      "id": 1,
      "text": "Chittenango’s name derives from the Oneida word Chu‑de‑nääng′, meaning “where the water falls down.”",
      "sourceSentenceIds": [
        22
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Chittenango%2C_New_York"
    },
    {
      "id": 2,
      "text": "The Erie Canal opened in 1825, turning Chittenango into a bustling canal town.",
      "sourceSentenceIds": [
        26
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Chittenango%2C_New_York"
    },
    {
      "id": 3,
      "text": "A 1.5‑mile canal linked Chittenango to the Erie Canal, complete with a three‑bay dry dock for building and repairing boats.",
      "sourceSentenceIds": [
        28,
        29
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Chittenango%2C_New_York"
    },
    {
      "id": 4,
      "text": "Every summer, Chittenango hosts a three‑day Oz‑Stravaganza festival and houses the All Things Oz Museum downtown.",
      "sourceSentenceIds": [
        12,
        15,
        16,
        17
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Chittenango%2C_New_York"
    },
    {
      "id": 5,
      "text": "In 1982, downtown Genesee Street received a yellow brick sidewalk painted to honor the famous “yellow brick road.”",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
