  "facts": [
    {
      "id": 1,
      "text": "Mineville earned its name from the iron ore mines that once buzzed here.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Mineville%2C_New_York"
    },
    {
      "id": 2,
      "text": "The Cheever iron bed, the oldest in Moriah, began serious mining in 1853 and sits just north of Port Henry.",
      "sourceSentenceIds": [
        22,
        24
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.porthenrymoriah.com/living-here/about-0"
    },
    {
      "id": 3,
      "text": "In the 1860s, a railroad linked Mineville mines to Port Henry docks, replacing the old plank road and speeding ore delivery to the Delaware and Hudson line.",
      "sourceSentenceIds": [
        9,
        13
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://www.porthenrymoriah.com/living-here/about-0"
    },
    {
      "id": 4,
      "text": "Republic Steel revived mining in 1938, but the last ore was extracted in 1971, leaving behind the fenced #21 Mine pit and a private 1907 office building.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/mineville_new_york"
    },
    {
      "id": 5,
      "text": "Mineville sits at 44°5′35″N 73°31′6″W, just five miles northwest of Port Henry along County Road 7.",
      "sourceSentenceIds": [
        18,
        19
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Mineville%2C_New_York"
    },
    {
      "id": 6,
      "text": "During the Civil War, Mineville’s iron supplied a significant portion of the Union’s war effort, fueling the town’s rapid growth.",
      "sourceSentenceIds": [
        8
