    },
    {
      "id": 2,
      "text": "The village is the birthplace of Bill Horr, who earned silver and bronze medals at the 1908 London Olympics.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Munnsville%2C_New_York"
    },
    {
      "id": 3,
      "text": "The former NYO&W depot, closed in 1957, now serves as a private residence for railroad historian John Taibi.",
      "sourceSentenceIds": [
        3
