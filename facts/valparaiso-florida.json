  "facts": [
    {
      "id": 1,
      "text": "Valparaiso, Florida, takes its name from Valparaiso, Indiana, which itself was named after the Chilean port of Valparaiso.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Valparaiso%2C_Florida"
    },
    {
      "id": 2,
      "text": "James E. Plew, a Chicago businessman, moved to the Panhandle in 1922 and became one of Northwest Florida’s pioneer developers.",
      "sourceSentenceIds": [
        11,
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Valparaiso%2C_Florida"
    },
    {
      "id": 3,
      "text": "In 1924 Plew founded the Bank of Valparaiso, built the Valparaiso Inn, and launched the Chicago Country Club golf course.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Valparaiso%2C_Florida"
    },
    {
      "id": 4,
      "text": "Plew leased 1,460 acres in 1934 for a bombing and gunnery base that later became the headquarters of Eglin Air Force Base.",
      "sourceSentenceIds": [
        15,
        16,
        17
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Valparaiso%2C_Florida"
    },
    {
      "id": 5,
      "text": "Plew also started the Shalimar Winery, using surplus grape crops from Okaloosa County to produce local wine.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Valparaiso%2C_Florida"
    },
    {
      "id": 6,
      "text": "Valparaiso sits in a humid subtropical zone, with hot, humid summers and evenly distributed rainfall year‑round.",
      "sourceSentenceIds": [
