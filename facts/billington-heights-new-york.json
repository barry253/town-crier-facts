  "facts": [
    {
      "id": 1,
      "text": "Billington Heights got its name from early settler Stickney Billington who owned Lot 19 in the Mile Strip after 1828.",
      "sourceSentenceIds": [
        22
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/billington_heights_new_york"
    },
    {
      "id": 2,
      "text": "The community grew from scattered 5–15 acre homesteads into a cohesive suburban enclave by the late 19th century, coinciding with Elma town formation in 1856.",
      "sourceSentenceIds": [
        24
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/billington_heights_new_york"
    },
    {
      "id": 3,
      "text": "Mid‑20th century saw a boom: over half of the homes were built between 1950 and 1959, reflecting the post‑war suburban ideal.",
      "sourceSentenceIds": [
        26
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/billington_heights_new_york"
    },
    {
      "id": 4,
      "text": "Billington Heights sits on the former Buffalo Creek Reservation, part of the Seneca Nation until the early 19th century.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/billington_heights_new_york"
    },
    {
      "id": 5,
      "text": "The area’s residential character is almost entirely owner‑occupied, with 100% of housing units owned by residents.",
      "sourceSentenceIds": [
        15
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/billington_heights_new_york"
    },
    {
      "id": 6,
      "text": "The median household income in Billington Heights is $79,123, slightly above the regional average but below the state average.",
      "sourceSentenceIds": [
        14
      ],
