    {
      "id": 1,
      "text": "Bloomfield village sits in the Town of East Bloomfield, a community first settled in 1789 as part of the Phelps and Gorham Purchase.",
      "sourceSentenceIds": [
        13,
        8,
        21
      ],
      "sourceLabels": [
