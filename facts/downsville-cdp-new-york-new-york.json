  "facts": [
    {
      "id": 1,
      "text": "Downsville was named after Abel Downs, who ran a tannery there in the early 1800s.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Downsville%2C_New_York"
    },
    {
      "id": 2,
      "text": "Abel Downs arrived in Colchester around 1794 and owned most of the land that became Downsville.",
      "sourceSentenceIds": [
        2,
        27
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://colchesterhsny.org/our-town/downsville/"
    },
    {
      "id": 3,
      "text": "The hamlet sits on Downs Brook just north of its meeting with the East Branch Delaware River.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Downsville%2C_New_York"
    },
    {
      "id": 4,
      "text": "Downsville hosts the historic Downsville Bridge, a covered bridge listed on the National Register of Historic Places.",
      "sourceSentenceIds": [
        5,
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Downsville%2C_New_York"
    },
    {
      "id": 5,
      "text": "A 1954 dam built by New York City workers created the Pepacton Reservoir at Downsville, part of the city’s water supply.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
