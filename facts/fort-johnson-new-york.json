  "facts": [
    {
      "id": 1,
      "text": "Old Fort Johnson, a National Historic Landmark, is run by the Montgomery County Historical Society.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.iloveny.com/listing/old-fort-johnson/2040/"
    },
    {
      "id": 2,
      "text": "This historic landmark on the Mohawk River is probably the most intact original structure from the French & Indian War period.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://mohawkvalleymuseums.us/museums/old-fort-johnson/"
    },
    {
      "id": 3,
      "text": "In 1756 Sir William Johnson renamed the settlement Fort Edward to honor Prince Edward, grandson of King George II.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Fort_Edward%2C_New_York"
    },
    {
      "id": 4,
      "text": "After staying in private hands until 1906, Old Fort Johnson opened its doors as a historic house museum.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://mohawkvalleymuseums.us/museums/old-fort-johnson/"
    },
    {
      "id": 5,
      "text": "The museum displays Native American artifacts, a rare 18th‑century privy, and a room dedicated to Betsey Reynolds Voorhees.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.iloveny.com/listing/old-fort-johnson/2040/"
    },
    {
      "id": 6,
      "text": "Fort Edward serves as the county seat of Washington County in the state of New York.",
