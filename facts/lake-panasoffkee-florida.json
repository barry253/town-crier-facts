    {
      "id": 2,
      "text": "Lake Panasoffkee is an Outstanding Florida Water, historically a strategic waterway during the Second Seminole War.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 2"
      ],
