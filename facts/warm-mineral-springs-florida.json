    {
      "id": 2,
      "text": "Water at Warm Mineral Springs stays a steady 85 degrees year‑round, giving visitors a warm, therapeutic soak in Florida’s only natural warm spring.",
      "sourceSentenceIds": [
        20
      ],
      "sourceLabels": [
        "Web source 1"
