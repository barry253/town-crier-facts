  "facts": [
    {
      "id": 1,
      "text": "Port Colden sprang to life in 1831 when the Morris Canal opened, and it was named for canal president Cadwallader D.",
      "sourceSentenceIds": [
        1,
        2,
        15,
        22
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Port_Colden%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "Lock Number 6 and a large canal basin made Port Colden a busy port along the Morris Canal.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://washington-twp-warren.org/community/local_history/port_colden.php"
    },
    {
      "id": 3,
      "text": "A large brickmaking factory once stood just west of the village, fueling early industrial activity.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://washington-twp-warren.org/community/local_history/port_colden.php"
    },
    {
      "id": 4,
      "text": "The Port Colden House, a tavern turned hotel, was a local landmark until it closed in 1895.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://washington-twp-warren.org/community/local_history/port_colden.php"
    },
    {
      "id": 5,
      "text": "Since July 1998, Port Colden has been listed on both state and national historic registers, protecting its heritage.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://washington-twp-warren.org/community/local_history/port_colden.php"
    },
    {
      "id": 6,
      "text": "After the Morris Canal shut down in 1924, Port Colden’s growth stalled, leaving it a modest local service center.",
