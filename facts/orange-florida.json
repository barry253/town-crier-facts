  "facts": [
    {
      "id": 1,
      "text": "Orange City was incorporated in 1882 and was named for the hundreds of orange groves that once surrounded it.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.florida-backroads-travel.com/orange-city-florida.html"
    },
    {
      "id": 2,
      "text": "The Great Freeze of 1894‑1895 wiped out those groves, forcing many farmers to leave the area.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.florida-backroads-travel.com/orange-city-florida.html"
    },
    {
      "id": 3,
      "text": "Several historic buildings in the town—such as the Dickinson Memorial Library, the Town Hall, and the 1876 Heritage Inn—are listed on the National Register of Historic Places.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.florida-backroads-travel.com/orange-city-florida.html"
    },
    {
      "id": 4,
      "text": "Orange City earned Tree City USA status, highlighting its commitment to green spaces and environmental stewardship.",
      "sourceSentenceIds": [
        25
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.floridavisiting.com/list/orange-city/"
    },
    {
      "id": 5,
      "text": "The Thursby House, built in 1872, sits within Blue Spring State Park and remains one of the area’s most recognizable historic landmarks.",
      "sourceSentenceIds": [
        26
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.floridavisiting.com/list/orange-city/"
    },
    {
      "id": 6,
      "text": "The 1876 Heritage Inn, a distinctive landmark, anchors the Orange City Historic District and showcases the town’s Victorian‑era charm.",
      "sourceSentenceIds": [
        21
      ],
      "sourceLabels": [
        "Web source 1"
      ],
