    },
    {
      "id": 3,
      "text": "The Parker House, an oceanfront inn dating to 1879, still serves classic American fare with sweeping sea views.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.shore-guide.com/towns/monmouth/sea-girt/"
    },
    {
      "id": 4,
      "text": "The nearest train station, Manasquan, sits about a mile from Sea Girt’s shoreline.",
