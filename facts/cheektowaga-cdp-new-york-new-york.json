  "facts": [
    {
      "id": 1,
      "text": "Cheektowaga’s name comes from the Erie‑Seneca word Ji‑ik‑do‑wah‑gah, meaning “place of the crabapple tree.”",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
