  "facts": [
    {
      "id": 1,
      "text": "Hancock House, built in 1734 by Quaker judge William and his wife Sarah, still shows a blue glazed brick pattern that spells out 1734 and their initials W S.",
      "sourceSentenceIds": [
        21
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.journeythroughjersey.com/sites/hancock-house-state-historic-site/"
    },
    {
      "id": 2,
      "text": "The house’s front wall displays a unique blue glazed brick design that literally writes the year of construction and the Hancock initials.",
      "sourceSentenceIds": [
        21
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.journeythroughjersey.com/sites/hancock-house-state-historic-site/"
    },
    {
      "id": 3,
      "text": "On March 20, 1778, British forces attacked Hancock’s Bridge, meeting Major John Graves Simcoe and his Queen’s Rangers in a brief but fierce skirmish.",
      "sourceSentenceIds": [
        24
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.journeythroughjersey.com/sites/hancock-house-state-historic-site/"
    },
    {
      "id": 4,
      "text": "Judge William Hancock was among the casualties of the 1778 attack and died several days later.",
      "sourceSentenceIds": [
        25
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.journeythroughjersey.com/sites/hancock-house-state-historic-site/"
    },
    {
      "id": 5,
      "text": "The State of New Jersey purchased the Hancock House in 1931 and opened it as a museum the following year.",
      "sourceSentenceIds": [
        26
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.journeythroughjersey.com/sites/hancock-house-state-historic-site/"
    },
    {
      "id": 6,
      "text": "Today the Hancock House State Historic Site preserves the only surviving home linked to the 1778 Hancock’s Bridge massacre and the broader Revolutionary War.",
      "sourceSentenceIds": [
        6,
        3
      ],
