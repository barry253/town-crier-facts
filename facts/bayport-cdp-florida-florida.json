  "facts": [
    {
      "id": 1,
      "text": "Bayport was founded by Parsons in 1842 after a military land grant, setting the stage for a bustling port town.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://unitedstatesghosttowns.com/bayport-florida-ghost-town/"
    },
    {
      "id": 2,
      "text": "The town’s name originally spelled Bay Port, and it briefly served as Hernando County’s seat until 1856 when the capital moved to Brooksville.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bayport%2C_Florida"
    },
    {
      "id": 3,
      "text": "Bayport’s growth hinged on the confluence of Mud Creek and the Weeki Wachee River, which made it a key shipping hub for cotton, lumber, and turpentine.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://unitedstatesghosttowns.com/bayport-florida-ghost-town/"
    },
    {
      "id": 4,
      "text": "During the Civil War, Union blockade ships intercepted eleven runners near Bayport between 1862 and 1865, making it a focal point of naval skirmishes.",
      "sourceSentenceIds": [
        21
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bayport%2C_Florida"
    },
    {
      "id": 5,
      "text": "The historic Bayport Cemetery still exists, where founding families like the Parsons, Garrisons, and Jenkinses are buried amid vegetation.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://unitedstatesghosttowns.com/bayport-florida-ghost-town/"
    },
    {
      "id": 6,
      "text": "The landmark Bayport Hotel burned in 1943, symbolically ending the town’s century of prosperity.",
