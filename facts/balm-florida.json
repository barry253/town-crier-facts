    },
    {
      "id": 2,
      "text": "The town’s name changed from Doric to Balm just 24 days after the post office opened, reflecting the area’s “balmy” air.",
      "sourceSentenceIds": [
        7,
        8,
        10
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Balm%2C_Florida"
    },
    {
      "id": 3,
      "text": "A one‑room train station with a water tank once served Balm, linking local citrus growers to markets in Tampa and Manatee County.",
      "sourceSentenceIds": [
        9,
        17
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Balm%2C_Florida"
    },
    {
      "id": 4,
      "text": "Many original early‑1900s buildings survive, including abandoned barns and a historic station, giving Balm a ghost‑town vibe without full abandonment.",
      "sourceSentenceIds": [
        6,
        21
      ],
      "sourceLabels": [
        "Web source 1"
