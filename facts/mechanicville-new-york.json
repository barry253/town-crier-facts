  "facts": [
    {
      "id": 1,
      "text": "Mechanicville’s name comes from the early residents’ occupations, reflecting a town built by craftsmen.",
      "sourceSentenceIds": [
        27
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Mechanicville%2C_New_York"
    },
    {
      "id": 2,
      "text": "The Mechanicville Hydroelectric Plant, still running, is the oldest continuously operating hydroelectric plant in the United States.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Mechanicville%2C_New_York"
    },
    {
      "id": 3,
      "text": "When the Champlain Canal arrived in 1823 and the Rensselaer and Saratoga Railroad opened a line in 1835, Mechanicville became a key commerce hub.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Mechanicville%2C_New_York"
    },
    {
      "id": 4,
      "text": "Mechanicville’s downtown boasts a Main Street lined with historic buildings that give the area a distinctive, charming character.",
      "sourceSentenceIds": [
        20
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://mschambercommerce.org/area-history/"
    },
    {
      "id": 5,
      "text": "One of Mechanicville’s two historic smokestacks, visible from two miles away, was knocked down by a tornado.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Mechanicville%2C_New_York"
    },
    {
      "id": 6,
      "text": "Textile mills, factories, and a linen thread company fueled Mechanicville’s rapid growth during the 19th century.",
