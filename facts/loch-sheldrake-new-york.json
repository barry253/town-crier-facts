    },
    {
      "id": 2,
      "text": "During the mid‑20th century, Loch Sheldrake was a bustling Catskills Borscht Belt resort, hosting dozens of hotels and bungalow colonies.",
      "sourceSentenceIds": [
        17,
        22,
        28
      ],
      "sourceLabels": [
