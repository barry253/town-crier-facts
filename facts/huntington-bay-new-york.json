  "facts": [
    {
      "id": 1,
      "text": "Huntington Bay sits on Long Island’s North Shore, founded in 1653 and bordered by the Long Island Sound to the north.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Huntington%2C_New_York"
    },
    {
      "id": 2,
      "text": "The town’s name may honor Oliver Cromwell’s birthplace, Huntingdon, England.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Huntington%2C_New_York"
    },
    {
      "id": 3,
      "text": "Three Oyster Bay men bought the First Purchase in 1653, a parcel that stretched from Cold Spring Harbor to Northport Harbor.",
      "sourceSentenceIds": [
        14,
        15
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Huntington%2C_New_York"
    },
    {
      "id": 4,
      "text": "In 1872, the southern part of Huntington split off to form the town of Babylon.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Huntington%2C_New_York"
    },
    {
      "id": 5,
      "text": "During the Revolutionary War, British troops used Huntington as their headquarters until the war’s end.",
      "sourceSentenceIds": [
        19
