  "facts": [
    {
      "id": 1,
      "text": "Algonquins called the lake “Wangumbaug,” a name that meant Crooked Pond.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.coventry-ct.gov/314/Lake-History-Facts"
    },
    {
      "id": 2,
      "text": "Archaeologist Kevin McBride says “Wangunbaug” is more likely a Nipmuc word, reflecting the local tribe’s influence.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.coventry-ct.gov/314/Lake-History-Facts"
    },
    {
      "id": 3,
      "text": "The lake was carved by a glacier that retreated north about 13,000 years ago, leaving a huge block of ice that melted into water.",
      "sourceSentenceIds": [
        5,
        27
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.coventry-ct.gov/314/Lake-History-Facts"
    },
    {
      "id": 4,
      "text": "Cobblestones and boulders left by the retreating glacier line the shore, protecting the lake bottom from disturbance.",
      "sourceSentenceIds": [
        29
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.coventry-ct.gov/314/Lake-History-Facts"
    },
    {
      "id": 5,
      "text": "Around 7,000 years ago, the cold‑climate forest that once covered the area evolved into temperate oak‑hemlock woods.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.coventry-ct.gov/314/Lake-History-Facts"
    },
    {
      "id": 6,
      "text": "Coventry Lake sits within the residential area of the Coventry Lake census‑designated place, giving the community a distinct waterfront identity.",
