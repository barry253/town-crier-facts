      "id": 1,
      "text": "Northdale got its name by blending 'North' with 'Dale Mabry,' the highway that cuts through the community.",
      "sourceSentenceIds": [
        5,
        26
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
