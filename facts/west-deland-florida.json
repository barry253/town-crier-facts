  "facts": [
    {
      "id": 1,
      "text": "The Conrad History Center in West DeLand holds one of Volusia County's most comprehensive collections of historic artifacts and newspapers dating back to 1877.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://riveroflakesheritagecorridor.org/things-to-do/heritage-history/history-museums/"
    },
    {
      "id": 2,
      "text": "Beside the DeLand House Museum, the Conrad History Center showcases vintage photos and collectibles that trace the county’s evolution.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://riveroflakesheritagecorridor.org/things-to-do/heritage-history/history-museums/"
    },
    {
      "id": 3,
      "text": "DeBary Hall Historic Site, built in 1871 by wine importer Frederick DeBary, once served as a seasonal hunting estate on Florida’s frontier.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://riveroflakesheritagecorridor.org/things-to-do/heritage-history/history-museums/"
    },
    {
      "id": 4,
      "text": "The Enterprise Museum, located in a 1936 elementary school, preserves letters, photos, and artifacts collected by the Enterprise Preservation Society.",
      "sourceSentenceIds": [
        19
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://riveroflakesheritagecorridor.org/things-to-do/heritage-history/history-museums/"
    },
    {
      "id": 5,
      "text": "West DeLand’s heritage corridor highlights railroads, steamship routes, and life in Seminole County towns from the 1800s to the 1900s.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://riveroflakesheritagecorridor.org/things-to-do/heritage-history/history-museums/"
    },
    {
      "id": 6,
      "text": "West DeLand is part of the River of Lakes Heritage Corridor, a network celebrating Florida’s natural and cultural history.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://riveroflakesheritagecorridor.org/things-to-do/heritage-history/history-museums/"
