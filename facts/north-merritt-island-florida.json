  "facts": [
    {
      "id": 1,
      "text": "Merritt Island’s name comes from a 19th‑century land grant given by the King of Spain to a nobleman named Merritt.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Merritt_Island%2C_Florida"
    },
    {
      "id": 2,
      "text": "The island’s early economy thrived on citrus, especially orange and pineapple cultivation, before the Space Age reshaped the area.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Merritt_Island%2C_Florida"
    },
    {
      "id": 3,
      "text": "Field Manor, built in 1880, still stands as a living museum of pioneer life and agricultural traditions on Merritt Island.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://mymerrittislandfl.com/living-on-the-island/history-legacy/"
    },
    {
      "id": 4,
      "text": "Kennedy Space Center sits on Merritt Island, and its Vehicle Assembly Building once stacked the Saturn V and Space Shuttle components.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://mymerrittislandfl.com/living-on-the-island/history-legacy/"
    },
    {
      "id": 5,
      "text": "The Merritt Island National Wildlife Refuge lies north of the space center, preserving the island’s natural habitats for wildlife.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Merritt_Island%2C_Florida"
    },
    {
      "id": 6,
      "text": "Sea Ray Boats operated a factory on Merritt Island from 1978 until 2012, making the island a notable hub for marine manufacturing.",
