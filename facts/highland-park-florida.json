  "facts": [
    {
      "id": 1,
      "text": "Highland Park is Florida’s second‑smallest municipality and even boasts a castle that locals proudly call the village’s crown jewel.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.wtsp.com/article/news/local/community-connection/highland-park-village-florida-hidden-gem-preserving-history-community/67-e8b2f2d6-764b-43e8-b9ef-7ac5335ea05e"
    },
    {
      "id": 2,
      "text": "Walking through the village, you’ll see historic homes once owned by people who helped shape Florida’s early history.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.wtsp.com/article/news/local/community-connection/highland-park-village-florida-hidden-gem-preserving-history-community/67-e8b2f2d6-764b-43e8-b9ef-7ac5335ea05e"
    },
    {
      "id": 3,
      "text": "The village is currently applying for a historic marker to honor its long‑standing contribution to Polk County and the state.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.wtsp.com/article/news/local/community-connection/highland-park-village-florida-hidden-gem-preserving-history-community/67-e8b2f2d6-764b-43e8-b9ef-7ac5335ea05e"
    },
    {
      "id": 4,
      "text": "Highland Park spans roughly 500 acres and is home to two serene lakes, Lake Amoret and Lake Easy.",
      "sourceSentenceIds": [
        22
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.highlandpark-fl.org/"
    },
    {
      "id": 5,
      "text": "Although development began in 1919, Highland Park officially incorporated in 1927, marking the start of its modern civic life.",
      "sourceSentenceIds": [
        23
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.highlandpark-fl.org/"
    },
    {
      "id": 6,
      "text": "The surviving historic homes tell stories of resilience, having withstood hurricanes Charley, Jean, and Frances over the decades.",
