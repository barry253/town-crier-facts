    },
    {
      "id": 2,
      "text": "The community sits at 42°28′4″N 76°32′20″W, roughly 42.467894 latitude and –76.538980 longitude.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
