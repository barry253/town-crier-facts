  "facts": [
    {
      "id": 1,
      "text": "Micanopy is believed to be Florida's oldest inland town, founded in 1821.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://myfloridahistory.org/content/micanopy-fl-little-town-time-forgot"
    },
    {
      "id": 2,
      "text": "The town was named after Seminole chief Micanopy, honoring his authority over the land.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Micanopy%2C_Florida"
    },
    {
      "id": 3,
      "text": "The Micanopy Historical Society Museum, housed in the 1896 Thrasher Warehouse, showcases Native American, Bartram, and Civil War history.",
      "sourceSentenceIds": [
        21
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Micanopy%2C_Florida"
    },
    {
      "id": 4,
      "text": "A 1896 warehouse served the Atlantic Coast Line Railroad until the 1950s and is now on the National Register of Historic Places.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Micanopy%2C_Florida"
    },
    {
      "id": 5,
      "text": "Visitors can explore historic downtown Cholokka Boulevard, filled with antique shops and cafés, a charm that attracts weekend crowds.",
      "sourceSentenceIds": [
        23
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.visitflorida.com/places-to-go/north-central/micanopy/"
    },
    {
      "id": 6,
      "text": "The town’s 1845 Herlong Mansion Bed & Breakfast offers a stay in a historic home near the museum.",
