  "facts": [
    {
      "id": 1,
      "text": "Hyde Park was named by its founder in honor of his wife, Ann Hyde.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Hyde_Park%2C_New_York"
    },
    {
      "id": 2,
      "text": "The town hosts the Culinary Institute of America, founded in 1946, making it a culinary capital.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.britannica.com/place/Hyde-Park-New-York"
    },
    {
      "id": 3,
      "text": "Franklin and Eleanor Roosevelt are buried on the family estate, a 290‑acre national historic site since 1944.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.britannica.com/place/Hyde-Park-New-York"
    },
    {
      "id": 4,
      "text": "The estate now serves as the Franklin D. Roosevelt National Historic Site, preserving the former presidential home.",
      "sourceSentenceIds": [
        10,
        11
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.nps.gov/hofr/index.htm"
    },
    {
      "id": 5,
      "text": "The Roosevelt Library and Museum houses about 44,000 books and the president’s papers.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.britannica.com/place/Hyde-Park-New-York"
    },
    {
      "id": 6,
      "text": "Visitors can explore over a thousand acres of gardens and trails that tell the Roosevelt saga.",
      "sourceSentenceIds": [
        13
      ],
