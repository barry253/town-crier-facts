  "facts": [
    {
      "id": 1,
      "text": "Since November 2012, the Glenwood Post Office has hosted a historic exhibit showcasing Glenwood Landing and Glen Head.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://goldcoastlibrary.org/local_history/local-history-collection-featured-at-glenwood-post-office/"
    },
    {
      "id": 2,
      "text": "A historic sign at the corner of Roslyn Shore Road and Glenwood Road narrates the town’s early days.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://goldcoastlibrary.org/local_history/local-history-collection-featured-at-glenwood-post-office/"
    },
    {
      "id": 3,
      "text": "The Gold Coast Library moved into its new home at 146 Glen Head Road on March 20.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://goldcoastlibrary.org/local_history/local-history-collection-featured-at-glenwood-post-office/"
    },
    {
      "id": 4,
      "text": "Glenwood Landing once boasted a bustling dock where steamboats ferried passengers, alongside boatyards that built vessels later turned national landmarks.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://goldcoastlibrary.org/local_history/local-history-collection-featured-at-glenwood-post-office/"
    },
    {
      "id": 5,
      "text": "Three national landmarks are highlighted in the exhibit: the Stone House in Roslyn Harbor, the Christeen, and the Stephen Taber.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://goldcoastlibrary.org/local_history/local-history-collection-featured-at-glenwood-post-office/"
    },
    {
      "id": 6,
      "text": "Digitized images from the exhibit, plus many historic photos of Glen Head and Glenwood, are available online at nyheritage.org.",
      "sourceSentenceIds": [
