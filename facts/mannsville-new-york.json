  "facts": [
    {
      "id": 1,
      "text": "Mannsville was named after early developer Barzillian Mann, whose name lives on in the village’s official title.",
      "sourceSentenceIds": [
        15
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Mannsville%2C_New_York"
    },
    {
      "id": 2,
      "text": "The village incorporated in 1879, after more than 70 years of growth that began with settlers arriving in the late 1790s.",
      "sourceSentenceIds": [
        18,
        9
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Mannsville%2C_New_York"
    },
    {
      "id": 3,
      "text": "A cotton factory built in 1823 burned down in 1827, marking one of the first major setbacks for the young settlement.",
      "sourceSentenceIds": [
        2,
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/mannsville_new_york"
    },
    {
      "id": 4,
      "text": "The Pierrepont Manor Complex, just north of Mannsville, earned a spot on the National Register of Historic Places in 1977.",
      "sourceSentenceIds": [
        6,
        11
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Mannsville%2C_New_York"
    },
    {
      "id": 5,
      "text": "Mannsville’s Lilac Park, a historic community landmark, sits at the heart of the village and reflects its long‑standing agricultural roots.",
      "sourceSentenceIds": [
        7,
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/mannsville_new_york"
    },
    {
