  "facts": [
    {
      "id": 1,
      "text": "Ledgewood was originally called Drakesville, named after Abraham Drake who ran a mill and tavern there in the mid‑1700s.",
      "sourceSentenceIds": [
        5,
        6
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Ledgewood%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "The town’s iron‑ore mining roots supplied weapons to George Washington’s Continental Army during the Revolutionary War.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://roxburylibrary.org/historic-walking-tour-16894"
    },
    {
      "id": 3,
      "text": "Ledgewood’s Main Street hosts a historic walking tour that stops at 23 landmarks, including the Silas Riggs Saltbox House.",
      "sourceSentenceIds": [
        3,
        7,
        16
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://roxburylibrary.org/historic-walking-tour-16894"
    },
    {
      "id": 4,
      "text": "The Morris Canal, completed in 1831, turned Ledgewood into a key transportation hub for iron ore and later kaolin shipments.",
      "sourceSentenceIds": [
        6,
        15
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/ledgewood_new_jersey"
    },
    {
      "id": 5,
      "text": "The Roxbury Historic Trust preserves the 1826 King Store, a turn‑of‑the‑century shop that still shows its original storefront.",
      "sourceSentenceIds": [
        12,
        27
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://roxburylibrary.org/historic-walking-tour-16894"
    },
    {
      "id": 6,
      "text": "Geographically, Ledgewood sits on the New Jersey Highlands, where glacial till and gneiss form steep ridges and deep valleys.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 1"
      ],
