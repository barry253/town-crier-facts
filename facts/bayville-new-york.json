    },
    {
      "id": 2,
      "text": "The Dunstable Estate was sold to Harrison Williams, who renamed it Oak Point, adding a new landmark to the village.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bayville%2C_New_York"
    },
    {
      "id": 3,
      "text": "Bayville’s iconic bridge opened in 1938, marking the fourth crossing at that spot and a key entry to the village.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
