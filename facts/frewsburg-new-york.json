  "facts": [
    {
      "id": 1,
      "text": "Frewsburg takes its name from Hugh and Mary Frew, the first European family to settle there in 1807.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Frewsburg%2C_New_York"
    },
    {
      "id": 2,
      "text": "A historic marker on Main Street commemorates the exact spot where the Frews first built their house.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Frewsburg%2C_New_York"
    },
    {
      "id": 3,
      "text": "Conewango Creek runs along Frewsburg’s western edge, feeding into the Allegheny River and shaping local wetlands.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/frewsburg_new_york"
    },
    {
      "id": 4,
      "text": "In 1817, Frew brothers John and James relocated a Pennsylvania gristmill to the village, sparking local grain processing.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/frewsburg_new_york"
    },
    {
      "id": 5,
      "text": "The 1870 merger that created the Dunkirk, Allegheny Valley and Pittsburgh Railroad brought freight lines through Frewsburg, boosting lumber and grain exports.",
      "sourceSentenceIds": [
        18,
        19
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/frewsburg_new_york"
    },
    {
      "id": 6,
      "text": "Since 1974, the Carroll Historical Society in Frewsburg has preserved local history and hosts lectures, workshops, and fundraising events.",
