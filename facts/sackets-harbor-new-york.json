  "facts": [
    {
      "id": 1,
      "text": "Sackets Harbor was founded in 1801 by Augustus Sacket, who saw the deep harbor and timber as a commercial advantage.",
      "sourceSentenceIds": [
        1,
        2,
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Sackets_Harbor%2C_New_York"
    },
    {
      "id": 2,
      "text": "During the War of 1812, the U.S. Navy built a major shipyard and headquarters for the Great Lakes at Sackets Harbor, employing over 3,000 men.",
      "sourceSentenceIds": [
        27,
        28
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Sackets_Harbor%2C_New_York"
    },
    {
      "id": 3,
      "text": "The Sackets Harbor Battlefield State Historic Site commemorates the 1813 battle and the village's role in defending the United States.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Sackets_Harbor%2C_New_York"
    },
    {
      "id": 4,
      "text": "In 1975, residents formed the Sackets Harbor Historical Society to preserve and promote the area's rich history.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.shhistoricalsociety.org/history/"
    },
    {
      "id": 5,
      "text": "The village is a designated New York State Heritage Area, featuring tree‑lined streets, historic architecture, and the War of 1812 Battlefield.",
      "sourceSentenceIds": [
        16,
        17
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://visitsacketsharbor.com/"
    },
    {
      "id": 6,
      "text": "Madison Barracks, an active Army post in the village, kept Sackets Harbor involved in every major war through World War II.",
