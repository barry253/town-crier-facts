  "facts": [
    {
      "id": 1,
      "text": "Key Largo’s name comes from the Spanish Cayo Largo, meaning “long key.”",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Key_Largo%2C_Florida"
    },
    {
      "id": 2,
      "text": "The town sits on the same island that hosts the historic African Queen Canal Cruise, where you can ride the steamboat from the 1951 film.",
      "sourceSentenceIds": [
        2,
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
