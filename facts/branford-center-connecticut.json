    {
      "id": 3,
      "text": "Branford was founded in 1644 by English settlers from Wethersfield, then part of the New Haven Colony.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.branford-ct.gov/352/Historic-Districts"
    },
    {
      "id": 4,
      "text": "The Harrison House on West Main Street, now the Branford Historical Society headquarters, dates back to the 19th century.",
