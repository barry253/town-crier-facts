  "facts": [
    {
      "id": 1,
      "text": "Apopka comes from the Seminole word Ahapopka, meaning 'potato-eating place' in the local language.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Apopka%2C_Florida"
    },
    {
      "id": 2,
      "text": "Apopka is referred to as the 'Indoor Foliage Capital of the World' due to the many greenhouse nurseries there.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Apopka%2C_Florida"
    },
    {
      "id": 3,
      "text": "The earliest known inhabitants were the Acuera, part of the Timucua confederation, who vanished by 1730 after Spanish disease.",
      "sourceSentenceIds": [
        19,
        20
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Apopka%2C_Florida"
    },
    {
      "id": 4,
      "text": "In 1882, the town officially incorporated as the Town of Apopka City.",
      "sourceSentenceIds": [
        29
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Apopka%2C_Florida"
    },
    {
      "id": 5,
      "text": "The Museum of the Apopkans offers a glimpse into the city’s rich history.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
