  "facts": [
    {
      "id": 1,
      "text": "Fillmore was originally called \"The Mouth of the Creek\" before being renamed for President Millard Fillmore in 1850.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Fillmore%2C_New_York"
    },
    {
      "id": 2,
      "text": "They thought naming the village after a sitting president would improve their chances of getting a post office.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.alleganyhistory.org/places/towns-and-villages/f-j273/hume252/related-articles34/3629-fillmore-lucky-location-lucky-buck"
    },
    {
      "id": 3,
      "text": "In 1836 the state legislature authorized the Genesee Valley Canal to pass through Fillmore, linking Rochester to Olean.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.alleganyhistory.org/places/towns-and-villages/f-j273/hume252/related-articles34/3629-fillmore-lucky-location-lucky-buck"
    },
    {
      "id": 4,
      "text": "John Whiting, probably the first settler, built a saw‑mill that sparked early lumbering in the area.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.alleganyhistory.org/places/towns-and-villages/f-j273/hume252/related-articles34/3629-fillmore-lucky-location-lucky-buck"
    },
    {
      "id": 5,
      "text": "Fillmore sits where Cold Creek joins the Genesee River, about 1,200 feet above sea level, at the junction of County Road 4 and NY Route 19.",
