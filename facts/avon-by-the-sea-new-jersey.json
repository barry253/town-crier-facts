  "facts": [
    {
      "id": 1,
      "text": "Avon‑by‑the‑Sea got its name from either Avon, England or a local hotel called the Avon Inn built in 1883.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Avon-by-the-Sea%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "The borough was officially incorporated on March 23, 1900, carving out land from neighboring Neptune City.",
      "sourceSentenceIds": [
        20
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Avon-by-the-Sea%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "Avon‑by‑the‑Sea sits on the Atlantic Ocean, with the Shark River to its south and Sylvan Lake to its north.",
      "sourceSentenceIds": [
        22
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Avon-by-the-Sea%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "The town’s first public school opened in 1908, followed by a library that began serving residents in 1916.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.avonbytheseanj.com/community/about_avon_by_the_sea/history_of_avon.php"
    },
    {
      "id": 5,
      "text": "In 1876, a railroad bridge was built across the Shark River as part of the Long Branch‑Belmar line, though it never opened for traffic.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://avonbytheseahistoricalsociety.wordpress.com/avon-historical-timelines/"
    },
    {
      "id": 6,
      "text": "The original bridge over the Shark River at Main Street, connecting Avon to Belmar, was constructed in 1856.",
