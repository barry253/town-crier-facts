  "facts": [
    {
      "id": 1,
      "text": "Mystic Island was once called Hickory Island and was served by the Tuckerton Railroad and a two‑lane street that became Radio Road.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Mystic_Island%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "The original development was named Mystic Islands, plural, covering seven small islands that were filled in to create buildable land.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Mystic_Island%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "The area east of Radio Road became Pulaski Village with narrow homes, while west of Radio Road grew into Westwood, a suburban ranch and split‑level neighborhood.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Mystic_Island%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "A circular “Boatel” at Radio Road and Bayview Drive once let boaters dock, dine, and even sleep on the water.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Mystic_Island%2C_New_Jersey"
    },
    {
      "id": 5,
      "text": "The Tuckerton Wireless Tower, built in 1912 by a German company, stood on what is now Mystic Island and later served U.S. Navy communications.",
      "sourceSentenceIds": [
        27
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Mystic_Island%2C_New_Jersey"
    },
    {
      "id": 6,
      "text": "Mystic Island’s Little Egg Harbor Community Center was originally a prefabrication shop before becoming the local civic hub.",
