  "facts": [
    {
      "id": 1,
      "text": "East Hills became an incorporated village in 1931 after residents banded together to avoid higher taxes from Roslyn’s plans.",
      "sourceSentenceIds": [
        25
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.roslynlandmarks.org/news/how-east-hills-became-a-village"
    },
    {
      "id": 2,
      "text": "The first record of the area appears in 1661 town documents, calling it “Harbour Hill” beside Hempstead Harbor.",
      "sourceSentenceIds": [
        24
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.roslynlandmarks.org/news/how-east-hills-became-a-village"
    },
    {
      "id": 3,
      "text": "East Hills’ name comes from the hill overlooking Hempstead Harbor, a landmark noted in early colonial maps.",
      "sourceSentenceIds": [
        24
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.roslynlandmarks.org/news/how-east-hills-became-a-village"
    },
    {
      "id": 4,
      "text": "In 1835 Connecticut merchant John Pitkin bought the land north of New Lots Avenue and opened a shoe factory on what is now Pitkin Avenue.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/East_New_York"
    },
    {
      "id": 5,
      "text": "The area was originally used by the Jameco, Canarsee, and Rockaway Native American tribes for fishing and hunting.",
      "sourceSentenceIds": [
        15
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/East_New_York"
    },
    {
      "id": 6,
      "text": "Today East Hills hosts a vibrant mix of immigrants from Bangladesh, the Dominican Republic, Guyana, and Puerto Rico.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/East_New_York"
    }
  ]
