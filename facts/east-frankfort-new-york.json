  "facts": [
    {
      "id": 1,
      "text": "East Frankfort was originally called McGowansville, founded in 1854 by Archibald McGowan who built a dry dock and store along the Erie Canal in 1857.",
      "sourceSentenceIds": [
        1,
        2,
        4,
        5,
        20,
        22,
        27
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/east_frankfort_new_york"
    },
    {
      "id": 2,
      "text": "The hamlet was renamed East Frankfort in 1893 after McGowan’s death, keeping McGowan Road as a historical reminder.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/east_frankfort_new_york"
    },
    {
      "id": 3,
      "text": "The arrival of the West Shore Railroad in the 1880s brought over 200 workers and Italian immigrants, shaping the community’s industrial growth.",
      "sourceSentenceIds": [
        12,
        13
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/east_frankfort_new_york"
    },
    {
      "id": 4,
      "text": "East Frankfort sits along the historic Erie Canal, whose locks in nearby Frankfort facilitated barge navigation and commerce.",
      "sourceSentenceIds": [
        15,
        24
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/east_frankfort_new_york"
    },
    {
      "id": 5,
      "text": "The community’s agricultural roots saw dairying dominate, with local farms supplying cheese factories that processed milk from thousands of cows.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/east_frankfort_new_york"
    },
    {
      "id": 6,
      "text": "In 1935, a Mohawk River flood reached the area, causing widespread inundation across the Mohawk Valley.",
