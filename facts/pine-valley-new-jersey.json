  "facts": [
    {
      "id": 1,
      "text": "Pine Valley Golf Club, founded in 1913 by George Arthur Crump and fellow Philadelphia golfers, set a new standard for inland courses.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Pine_Valley,_New_Jersey"
    },
    {
      "id": 2,
      "text": "Pine Valley’s creation in 1929 was a classic case of New Jersey’s boroughitis, designed to protect the golf club’s exclusivity.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Pine_Valley,_New_Jersey"
    },
    {
      "id": 3,
      "text": "Pine Valley is a borough in Camden County, New Jersey, located in southern New Jersey.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Pine_Valley%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "Pine Valley Golf Club routinely ranks among Golf Digest’s top 100 courses in America.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Pine_Valley%2C_New_Jersey"
    },
    {
      "id": 5,
      "text": "The Borough of Pine Valley was incorporated on April 23, 1929, alongside four other new municipalities.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Pine_Valley%2C_New_Jersey"
    },
    {
      "id": 6,
      "text": "In 2022, Pine Valley merged with Pine Hill, ending its independent borough government.",
