  "facts": [
    {
      "id": 1,
      "text": "Pineland was originally called Barney’s Landing until 1902, when William Batty bought 142 acres and renamed it after himself.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.museumoftheislands.com/pineland/"
    },
    {
      "id": 2,
      "text": "The Pineland archaeological site, now the Randell Research Center, preserves the Calusa settlement that dates back at least 2,000 years.",
      "sourceSentenceIds": [
        4,
        21
      ],
      "sourceLabels": [
        "Web source 2",
        "Wikipedia"
      ],
      "source": "https://www.floridamuseum.ufl.edu/rrc/blog/recent-history-of-the-pineland-community-part-1/"
    },
    {
      "id": 3,
      "text": "Pineland sits on the west side of Pine Island, just north of the island’s center, and is bordered by Pine Island Sound to the west.",
      "sourceSentenceIds": [
        8,
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Pineland%2C_Florida"
    },
    {
      "id": 4,
      "text": "The Calusa Indians inhabited Pineland for 1,500 years, building shell mounds and a canal system that still echo in the landscape.",
      "sourceSentenceIds": [
        12,
        22
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Pineland%2C_Florida"
    },
    {
      "id": 5,
      "text": "Pineland’s post office is one of the smallest in the United States, a quirky landmark that locals still visit.",
      "sourceSentenceIds": [
        23
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Pineland%2C_Florida"
    },
    {
      "id": 6,
      "text": "In the early 1900s, only about three dozen people lived on Pine Island, making Pineland a tight-knit pioneer community.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.floridamuseum.ufl.edu/rrc/blog/recent-history-of-the-pineland-community-part-1/"
