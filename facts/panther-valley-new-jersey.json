  "facts": [
    {
      "id": 1,
      "text": "Panther Valley earned its name from the panthers that once roamed the Allamuchy hills, a legacy still echoed in local place names.",
      "sourceSentenceIds": [
        5,
        26
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://pvpoa.org/page/35596~680215/History"
    },
    {
      "id": 2,
      "text": "The 5th hole of Panther Valley Golf Course overlooks Panther Ledge, where New Jersey’s last big cat was killed in 1805.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://pvpoa.org/page/35596~680215/History"
    },
    {
      "id": 3,
      "text": "Allamuchy Township, home to Panther Valley, split from Independence Township on April 4, 1873, marking its official birth.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://allamuchynj.org/history"
    },
    {
      "id": 4,
      "text": "During the Civil War, Allamuchy served as a stop on the Underground Railroad, sheltering those seeking freedom.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://allamuchynj.org/history"
    },
    {
      "id": 5,
      "text": "Rutherfurd Hall, the historic estate of the Rutherfurd family, stands as one of Allamuchy’s most prominent landmarks.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://allamuchynj.org/history"
    }
  ]
