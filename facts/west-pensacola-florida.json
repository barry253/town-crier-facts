    },
    {
      "id": 2,
      "text": "Built in 1859, the Pensacola Lighthouse rises on NAS Pensacola and offers a 177‑step climb to sweeping Gulf Coast views.",
      "sourceSentenceIds": [
        1,
        22,
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.visitpensacola.com/plan-your-trip/neighborhoods/west-pensacola/"
    },
    {
      "id": 3,
      "text": "West Pensacola lies roughly four miles west of downtown Pensacola, placing it just a short drive from the city center.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/West_Pensacola%2C_Florida"
    },
    {
      "id": 4,
      "text": "The community sits at an elevation of 76 feet above sea level, typical for the Gulf Coast lowlands.",
