  "facts": [
    {
      "id": 1,
      "text": "Linwood sprang to life when the Delaware, Lackawanna & Western Railroad cut through the town in 1883, linking local farms to larger markets.",
      "sourceSentenceIds": [
        1,
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/linwood_new_york"
    },
    {
      "id": 2,
      "text": "The first post office opened September 10, 1883, with Daniel D. McMillan as postmaster, becoming a hub for farmers and neighbors.",
      "sourceSentenceIds": [
        16,
        17
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/linwood_new_york"
    },
    {
      "id": 3,
      "text": "Linwood lies about 30 miles southwest of Rochester, 15 miles southeast of Batavia, and 11 miles northwest of Geneseo.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Linwood%2C_New_York"
    },
    {
      "id": 4,
      "text": "Water from Linwood flows into Browns Creek, an east‑flowing tributary that joins the Genesee River.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Linwood%2C_New_York"
    },
    {
      "id": 5,
      "text": "Friends of Linwood work to preserve the hamlet’s historic gardens and its renowned tree‑peony collection.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.linwoodgardens.org/"
    },
    {
      "id": 6,
      "text": "Early 1800s Scottish settlers, drawn by fertile Genesee Valley soils, established the first farms that would become Linwood.",
