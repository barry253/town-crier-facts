  "facts": [
    {
      "id": 1,
      "text": "Pinecraft began as a winter escape in the 1920s, drawing Amish and Mennonite families to Sarasota’s warm climate.",
      "sourceSentenceIds": [
        8,
        9
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://thesunshinerepublic.com/2025/03/23/floridas-amish-community-tradition-and-modernity-explore-pinecraft/"
    },
    {
      "id": 2,
      "text": "Unlike traditional Amish farms, Pinecraft homes are modest, colorful cottages with electricity, yet televisions and computers remain absent.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://thesunshinerepublic.com/2025/03/23/floridas-amish-community-tradition-and-modernity-explore-pinecraft/"
    },
    {
      "id": 3,
      "text": "During the cooler winter months, thousands of Amish visitors arrive by bus, turning Pinecraft into a bustling seasonal community.",
      "sourceSentenceIds": [
        26,
        30
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.pinecraft.com/about-pinecraft-amish-community"
    },
    {
      "id": 4,
      "text": "Horse‑drawn buggies give way to bicycles and three‑wheeled adult trikes, but the values of simplicity, faith, and craftsmanship stay deeply rooted.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://thesunshinerepublic.com/2025/03/23/floridas-amish-community-tradition-and-modernity-explore-pinecraft/"
    },
    {
      "id": 5,
      "text": "A pavilion in the back of the community hosts many barbecues and sometimes features Amish or Mennonite singers.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.pinecraft.com/about-pinecraft-amish-community"
    },
    {
      "id": 6,
      "text": "Pinecraft’s residents run small businesses, bakeries, and local markets, offering handmade quilts, furniture, and fresh produce instead of traditional farming.",
      "sourceSentenceIds": [
        14,
