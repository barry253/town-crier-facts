  "facts": [
    {
      "id": 1,
      "text": "Hazardville earned its name from Colonel Augustus George Hazard, a prominent 19th‑century industrialist.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Hazardville%2C_Connecticut"
    },
    {
      "id": 2,
      "text": "The village grew around a gunpowder mill that began in 1835 when Allen Loomis built a small black powder plant in Powder Hollow.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Hazardville%2C_Connecticut"
    },
    {
      "id": 3,
      "text": "By the 1840s, foreign experts from Faversham, England, were hired to upgrade the mill into a large‑scale gunpowder factory.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.enfield-ct.gov/1492/Hazardville"
    },
    {
      "id": 4,
      "text": "In 1978 citizens rallied to save the historic Hazardville Institute, preventing its demolition and sparking a restoration effort.",
      "sourceSentenceIds": [
        8,
        9
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://www.enfield-ct.gov/1492/Hazardville"
    },
    {
      "id": 5,
      "text": "The Hazardville Historic District, covering 1,075 acres, was added to the National Register of Historic Places in 1980.",
      "sourceSentenceIds": [
        19
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Hazardville%2C_Connecticut"
    },
    {
      "id": 6,
      "text": "Today the restored Hazardville Institute serves as a civic meeting place, hosting cultural and intellectual events for the community.",
      "sourceSentenceIds": [
        2,
        6
      ],
      "sourceLabels": [
        "Web source 2",
        "Web source 1"
      ],
      "source": "https://hazardville.org/about/"
    }
  ]
}
