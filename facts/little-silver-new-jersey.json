  "facts": [
    {
      "id": 1,
      "text": "Little Silver got its name from Joseph and Peter Parker, who settled the area in 1667 and named it after their father's estate.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Little_Silver%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "The original Parker Homestead, built in 1725, now serves as one of New Jersey's oldest state historic sites.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Little_Silver%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "Little Silver’s train station, first built in 1875 and later redesigned by Henry Hobson Richardson in 1890, remains a historic landmark.",
      "sourceSentenceIds": [
        2,
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Little_Silver%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "Unlike most electrified lines, Little Silver’s NJ Transit station has no raised platforms, making boarding a unique experience.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Little_Silver%2C_New_Jersey"
    },
    {
      "id": 5,
      "text": "When trains stop at Little Silver, they block one of two crossings for the entire duration, often causing traffic backups.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Little_Silver%2C_New_Jersey"
    },
    {
      "id": 6,
      "text": "Since the 1920s, Little Silver’s farms and nurseries have largely been replaced by diverse residential housing.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Little_Silver%2C_New_Jersey"
    }
  ]
