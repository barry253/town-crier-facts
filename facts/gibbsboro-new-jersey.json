  "facts": [
    {
      "id": 1,
      "text": "Gibbsboro takes its name from the Gibbs family, early settlers who arrived in 1706 and gave the town its post office name in 1883.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Gibbsboro%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "In 1852, John Lucas and Joseph Foster opened the Gibbsboro White Lead, Zinc and Color Works, a paint factory that drew on the town’s pure water.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://westfieldnj.com/whs/history/Counties/CamdenCounty/gibbsboro.htm"
    },
    {
      "id": 3,
      "text": "By 1887, the Lucas paint works had grown so large that a spur rail line branched off the Camden‑to‑Atlantic main line to move products to Gibbsboro.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://westfieldnj.com/whs/history/Counties/CamdenCounty/gibbsboro.htm"
    },
    {
      "id": 4,
      "text": "Gibbsboro became an official borough on March 8 1924, after voters approved the change in a referendum held the following month.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Gibbsboro%2C_New_Jersey"
    },
    {
      "id": 5,
      "text": "The Lucas paint works employed 700 men in 1909, a dramatic increase from the 300 workers it had in 1886.",
