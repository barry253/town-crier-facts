  "facts": [
    {
      "id": 1,
      "text": "Mariaville Lake was created in 1793 when James Duane dammed Chuctanunda Creek, forming a reservoir that powered the first grist mill.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/mariaville_lake_new_york"
    },
    {
      "id": 2,
      "text": "The hamlet grew into an industrial hub, hosting two gristmills, three sawmills, a handle factory, and a trip hammer forging axe heads by the 1840s.",
      "sourceSentenceIds": [
        2,
        6
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/mariaville_lake_new_york"
    },
    {
      "id": 3,
      "text": "Mariaville’s name honors Duane’s eldest daughter, Maria, after whom the lake was originally called Maria Pond.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/mariaville_lake_new_york"
    },
    {
      "id": 4,
      "text": "The 197‑acre lake, only 12 feet deep, is a shallow spring‑fed body that supports fishing for panfish and is classified as Class B water.",
      "sourceSentenceIds": [
        23
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/mariaville_lake_new_york"
    },
    {
      "id": 5,
      "text": "Ice harvesting from Mariaville Lake continued into the 1930s, supplying local communities before refrigeration became common.",
      "sourceSentenceIds": [
        24
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/mariaville_lake_new_york"
    },
    {
      "id": 6,
      "text": "The hamlet pioneered rural telephone service in Schenectady County through the Mariaville and South Schenectady Telephone Company.",
      "sourceSentenceIds": [
        25
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/mariaville_lake_new_york"
    }
  ]
}
