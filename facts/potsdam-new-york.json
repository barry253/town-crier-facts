    {
      "id": 1,
      "text": "Potsdam, New York, takes its name from the German city of Potsdam.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Potsdam%2C_New_York"
    },
    {
      "id": 2,
      "text": "Settlers began arriving in 1802, and the Town of Potsdam was officially founded in 1806.",
      "sourceSentenceIds": [
        7,
        26
      ],
      "sourceLabels": [
        "Web source 1",
        "Wikipedia"
      ],
      "source": "https://villageofpotsdamny.gov/explore/"
    },
    {
      "id": 3,
      "text": "In 1831 the community of Potsdam separated from the town and incorporated as its own village.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Potsdam%2C_New_York"
    },
    {
      "id": 4,
      "text": "Lawrence Academy, founded in 1816, evolved into the State University of New York at Potsdam, a flagship campus.",
      "sourceSentenceIds": [
        5,
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Potsdam%2C_New_York"
    },
    {
      "id": 5,
      "text": "Clarkson University, established in 1896, shares the village’s campus with SUNY Potsdam, making it a rare dual‑university town.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Potsdam%2C_New_York"
    },
    {
      "id": 6,
      "text": "The village’s historic streets showcase reddish‑pink Potsdam sandstone, a local stone that gives the area its distinctive architectural hue.",
