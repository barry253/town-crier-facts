  "facts": [
    {
      "id": 1,
      "text": "Higganum’s name comes from an Indian term meaning either “at the tomahawk rock” or “Great Bend in River.”",
      "sourceSentenceIds": [
        25
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Higganum%2C_Connecticut"
    },
    {
      "id": 2,
      "text": "In the late 1700s through the mid‑1800s, Higganum Landing on the Connecticut River was a bustling shipbuilding and river‑port hub.",
      "sourceSentenceIds": [
        27
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Higganum%2C_Connecticut"
    },
    {
      "id": 3,
      "text": "The Higganum Landing Historic District earned a spot on the National Register of Historic Places in 2018, preserving its 19th‑century character.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Higganum%2C_Connecticut"
    },
    {
      "id": 4,
      "text": "Around 1800, Higganum Center became the town’s economic heart, driven by abundant water power and local industry.",
      "sourceSentenceIds": [
        26
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Higganum%2C_Connecticut"
    },
    {
      "id": 5,
      "text": "The Scovil Hoe Company, known for its cotton and tobacco hoes, once operated a major factory right in Higganum.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Higganum%2C_Connecticut"
    },
    {
      "id": 6,
      "text": "Historic Sanborn Fire Insurance Maps from 1901, 1908, and 1914 show Higganum’s downtown layout, labeled businesses, and industrial buildings.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://hometownhistorymaps.com/pages/history-of-higganum-connecticut"
