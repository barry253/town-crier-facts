  "facts": [
    {
      "id": 1,
      "text": "Mountain Lodge Park began as a cluster of summer homes and has gradually become a year‑round community.",
      "sourceSentenceIds": [
        2,
        4,
        7
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Mountain_Lodge_Park%2C_New_York"
    },
    {
      "id": 2,
      "text": "The community sits on the western slope of Schunemunk Mountain, the tallest peak in Orange County.",
      "sourceSentenceIds": [
        10,
        22
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Mountain_Lodge_Park%2C_New_York"
    },
    {
      "id": 3,
      "text": "About 800 homes split the area into two sides: the Mountain Lodge Park side and the Glenwood Hills side.",
      "sourceSentenceIds": [
        11,
        12,
        23,
        24
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Mountain_Lodge_Park%2C_New_York"
    },
    {
      "id": 4,
      "text": "Development kicked off just before World War II, stalled, and resumed after the war, shaping the town’s early layout.",
      "sourceSentenceIds": [
        13,
        25
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Mountain_Lodge_Park%2C_New_York"
    },
    {
      "id": 5,
      "text": "Glenwood Hills, built from the 1950s through the 1970s, features closer‑packed homes and paved streets.",
      "sourceSentenceIds": [
        14,
        26,
        29
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Mountain_Lodge_Park%2C_New_York"
    },
    {
      "id": 6,
      "text": "On the Mountain Lodge Park side, houses are spread farther apart and most trails remain unpaved.",
      "sourceSentenceIds": [
