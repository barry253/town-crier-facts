  "facts": [
    {
      "id": 1,
      "text": "Florida Ridge was originally inhabited by the Ais people along the Indian River Lagoon.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/florida_ridge_florida"
    },
    {
      "id": 2,
      "text": "Spanish explorers named the nearby river \"Rio de Ais\" after the indigenous inhabitants.",
      "sourceSentenceIds": [
        20
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/florida_ridge_florida"
    },
    {
      "id": 3,
      "text": "The area faces hurricane risks from Atlantic tropical cyclones, bringing strong winds, storm surges, and heavy rain.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/florida_ridge_florida"
    },
    {
      "id": 4,
      "text": "Early pioneers arrived by schooner in 1843–1844, planting citrus and pineapples before Seminole conflicts pushed many away.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/florida_ridge_florida"
    },
    {
      "id": 5,
      "text": "By the 1840s, Seminole bands from Georgia and Alabama began seasonal occupations, integrating with or displacing the Ais.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/florida_ridge_florida"
    },
    {
      "id": 6,
      "text": "In the 1960s, businessman Harold Schwartz began selling land in the area that would become The Villages through mail‑order sales.",
      "sourceSentenceIds": [
        23
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
