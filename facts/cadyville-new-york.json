  "facts": [
    {
      "id": 1,
      "text": "Cadyville sits along the Saranac River on New York State Route 374, just 8.8 miles west of Plattsburgh.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Cadyville%2C_New_York"
    },
    {
      "id": 2,
      "text": "Cadyville State Forest spans 371 forested acres east of the Adirondack Forest Preserve boundary.",
      "sourceSentenceIds": [
        15,
        16
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://dec.ny.gov/places/cadyville-state-forest"
    },
    {
      "id": 3,
      "text": "The main parking area lies at the intersection of Route 3 and Route 374, roughly ten miles west of downtown Plattsburgh.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://dec.ny.gov/places/cadyville-state-forest"
    },
    {
      "id": 4,
      "text": "Primitive camping is permitted, but campers must stay at least 150 feet from any water body, road, or trail.",
      "sourceSentenceIds": [
        21,
        23
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://dec.ny.gov/places/cadyville-state-forest"
    },
    {
      "id": 5,
      "text": "Hunting is allowed during season for whitetail deer, black bear, ruffed grouse, wild turkey, and other game species.",
