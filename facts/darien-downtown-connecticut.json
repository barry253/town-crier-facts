  "facts": [
    {
      "id": 1,
      "text": "Darien was first settled in 1641 by colonists from Wethersfield, long before it became a separate community in 1737.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.britannica.com/place/Darien-Connecticut"
    },
    {
      "id": 2,
      "text": "In 1820 the town was incorporated, and Thaddeus Bell renamed it Darien after the Darién region of Panama, a trading hub for local merchants.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.britannica.com/place/Darien-Connecticut"
    },
    {
      "id": 3,
      "text": "Weed Homestead, built in 1680, stands as Darien’s oldest house and a tangible link to the town’s early colonial era.",
      "sourceSentenceIds": [
        20
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.britannica.com/place/Darien-Connecticut"
    },
    {
      "id": 4,
      "text": "Darien Downtown’s core centers around the junction of U.S. Route 1, Connecticut Route 124, and Connecticut Route 136, forming the town’s historic commercial hub.",
      "sourceSentenceIds": [
        5,
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Darien_Downtown%2C_Connecticut"
    },
    {
      "id": 5,
      "text": "A mural in the town hall depicts the 1781 capture of Darien by British soldiers and local Tories, a pivotal moment in its history.",
      "sourceSentenceIds": [
        19
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.britannica.com/place/Darien-Connecticut"
    },
    {
      "id": 6,
      "text": "Darien borders Long Island Sound, giving the town a picturesque coastal setting that has shaped its maritime heritage.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.britannica.com/place/Darien-Connecticut"
    }
  ]
