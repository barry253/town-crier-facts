  "facts": [
    {
      "id": 1,
      "text": "Fultonville takes its name from Robert Fulton, the inventor of the steamboat.",
      "sourceSentenceIds": [
        4,
        7
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Fultonville%2C_New_York"
    },
    {
      "id": 2,
      "text": "The village was founded around 1824 to serve the Erie Canal and officially incorporated on August 9 1848.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Fultonville%2C_New_York"
    },
    {
      "id": 3,
      "text": "In 1889 the West Shore Railroad built a station in Fultonville, later joining the New York Central system.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Fultonville%2C_New_York"
    },
    {
      "id": 4,
      "text": "In 2019 Fultonville’s historic core earned National Register status as the Fultonville Historic District, showcasing well‑preserved canal‑era architecture.",
      "sourceSentenceIds": [
        24
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Fultonville%2C_New_York"
    },
    {
      "id": 5,
      "text": "Cobblestone Hall and Free Library, erected before 1868, grew into a wooden addition by 1905, serving as a community hub.",
      "sourceSentenceIds": [
        18,
        19
      ],
      "sourceLabels": [
        "Wikipedia"
