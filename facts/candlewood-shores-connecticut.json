  "facts": [
    {
      "id": 1,
      "text": "Candlewood Shores sits on the east shore of Candlewood Lake, in the northwestern part of Brookfield.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Candlewood_Shores%2C_Connecticut"
    },
    {
      "id": 2,
      "text": "The community is bordered to the south by Candlewood Orchards, to the north by Candlewood Lake Club, and to the west by New Fairfield.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Candlewood_Shores%2C_Connecticut"
    },
    {
      "id": 3,
      "text": "Developed in 1948 by Ralph and Raymond Reynolds, Candlewood Shores began as a private summer recreation community.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.candlewoodshores.com/about/"
    },
    {
      "id": 4,
      "text": "A Homeowners Association was formed in 1963 to manage the growing community.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.candlewoodshores.com/about/"
    },
    {
      "id": 5,
      "text": "The community’s purchase debt was fully repaid in 2002, ending a long‑term financial commitment.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.candlewoodshores.com/about/"
    },
    {
      "id": 6,
      "text": "Candlewood Shores’ geographic coordinates are 41.482° N, 73.4421° W, placing it in Western Connecticut County.",
