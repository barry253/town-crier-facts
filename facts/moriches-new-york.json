  "facts": [
    {
      "id": 1,
      "text": "Moriches takes its name from Meritces, a Native sachem who owned land on Moriches Neck, a stretch along the south shore.",
      "sourceSentenceIds": [
        3,
        11,
        29
      ],
      "sourceLabels": [
        "Web source 1",
        "Wikipedia"
      ],
      "source": "https://grokipedia.com/page/Center_Moriches,_New_York"
    },
    {
      "id": 2,
      "text": "Long before Europeans, the Algonquian Unkechaug people hunted, fished, and seasonally lived on the south shore of what is now Center Moriches.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/Center_Moriches,_New_York"
    },
    {
      "id": 3,
      "text": "English settlers began arriving in the late 1600s under the Town of Brookhaven, expanding into the Moriches area by the early 1700s.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/Center_Moriches,_New_York"
    },
    {
      "id": 4,
      "text": "By the early 1900s, wealthy New Yorkers flocked to Center Moriches for its railroad access and bay recreation, while farming stayed core.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/Center_Moriches,_New_York"
    },
    {
      "id": 5,
      "text": "The Terry‑Ketcham Inn, dating to the late 1600s, stands as a living reminder of Center Moriches’ colonial roots.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/Center_Moriches,_New_York"
    },
    {
      "id": 6,
      "text": "Center Moriches Public Library sits at 235 Main Street, serving residents with books, events, and community programs.",
