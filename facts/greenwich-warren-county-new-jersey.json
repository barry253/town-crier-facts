  "facts": [
    {
      "id": 1,
      "text": "Greenwich Township earned its name from Greenwich, England, reflecting early settlers' ties to the English capital.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Greenwich_Township%2C_Warren_County%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "First mentioned in official documents on October 9, 1738, Greenwich Township emerged from Bethlehem Township in Hunterdon County.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Greenwich_Township%2C_Warren_County%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "Within a decade, Greenwich Township moved from Hunterdon to Morris, then to Sussex, and finally settled in Warren County in 1824.",
      "sourceSentenceIds": [
        14,
        16,
        19
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Greenwich_Township%2C_Warren_County%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "Long before Europeans, the Lenni Lenape Minsi people farmed and hunted along the Musconetcong and Delaware valleys that now border Greenwich.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/greenwich_cdp_warren_county_new_jersey"
    },
    {
      "id": 5,
      "text": "A segment of the historic Lehigh Line, once the mainline of the Lehigh Valley Railroad, cuts through Greenwich’s southern edge.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Greenwich_Township%2C_Warren_County%2C_New_Jersey"
    },
    {
      "id": 6,
      "text": "Greenwich Township was formally incorporated by New Jersey Legislature on February 21, 1798, solidifying its municipal status.",
      "sourceSentenceIds": [
