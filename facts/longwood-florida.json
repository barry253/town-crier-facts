  "facts": [
    {
      "id": 1,
      "text": "Longwood earned its name from settler Edward Warren Henck, who christened it after a Boston suburb he helped design.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.florida-backroads-travel.com/longwood-historic-district.html"
    },
    {
      "id": 2,
      "text": "After the South Florida Railroad reached the area in 1880, Longwood blossomed into a winter retreat for wealthy northerners.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.florida-backroads-travel.com/longwood-historic-district.html"
    },
    {
      "id": 3,
      "text": "The 190‑acre Longwood Historic District was added to the National Register of Historic Places in 1990.",
      "sourceSentenceIds": [
        11,
        14
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.florida-backroads-travel.com/longwood-historic-district.html"
    },
    {
      "id": 4,
      "text": "Henck’s 38‑room Longwood Village Inn later served as a filming location for the 1966 movie Johnny Tiger.",
      "sourceSentenceIds": [
