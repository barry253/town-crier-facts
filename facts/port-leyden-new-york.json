  "facts": [
    {
      "id": 1,
      "text": "Port Leyden got its name when the Black River Canal was being built, changing from \"Kelsey's Mills\" around 1838.",
      "sourceSentenceIds": [
        15,
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Port_Leyden%2C_New_York"
    },
    {
      "id": 2,
      "text": "The village began as a mill site around 1800, later becoming a thriving hamlet with sawmill, gristmill, cheese box factory.",
      "sourceSentenceIds": [
        15,
        2
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Port_Leyden%2C_New_York"
    },
    {
      "id": 3,
      "text": "The Black River Canal reached Port Leyden in 1850, but traffic only started in 1851, ending when the canal was abandoned in 1900.",
      "sourceSentenceIds": [
        17,
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Port_Leyden%2C_New_York"
    },
    {
      "id": 4,
      "text": "The Utica and Black River Railroad opened a line through Leyden in 1855, later leased to New York Central in 1891.",
      "sourceSentenceIds": [
        7,
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://historicallylewis.org/township_history/leyden/"
    },
    {
      "id": 5,
      "text": "Mark's Church and the Edmund Wilson House in Port Leyden are listed on the National Register of Historic Places.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Port_Leyden%2C_New_York"
    },
    {
      "id": 6,
      "text": "The Port Leyden Community Library sits on Canal Street, a nod to the village's canal heritage.",
