    },
    {
      "id": 2,
      "text": "The Douglaston Club, founded 1917 in a converted 1819 mansion overlooking Little Neck Bay, became the neighborhood’s social hub.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.cityneighborhoods.nyc/douglaston"
    },
    {
      "id": 3,
      "text": "In 1997 the Douglas Manor Historic District was designated, protecting over 600 early 20th‑century homes from alteration.",
      "sourceSentenceIds": [
        18,
        13
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.cityneighborhoods.nyc/douglaston"
    },
    {
      "id": 4,
      "text": "Douglaston Park Golf Course, once part of the Douglas estate, was turned into a municipal park in 1962, preserving open space for residents.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.cityneighborhoods.nyc/douglaston"
    },
    {
      "id": 5,
      "text": "The Immaculate Conception Center, a former seminary, sits in southern Douglaston and reflects the area’s Catholic heritage.",
