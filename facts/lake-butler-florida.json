  "facts": [
    {
      "id": 1,
      "text": "Lake Butler was named after the lake it borders, honoring Robert Butler, Florida's first Surveyor General.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.florida-backroads-travel.com/lake-butler-florida.html"
    },
    {
      "id": 2,
      "text": "The Townsend‑Green Building, once the Old Drugstore, now houses the Union County Historical Museum and is on the National Register of Historic Places.",
      "sourceSentenceIds": [
        1,
        11
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.floridavisiting.com/list/lake-butler/"
    },
    {
      "id": 3,
      "text": "Union County’s first courthouse, the historic Townsend Building, showcases Italian Renaissance architecture and opened in the late 19th century.",
      "sourceSentenceIds": [
        3,
        15
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.florida-backroads-travel.com/lake-butler-florida.html"
    },
    {
      "id": 4,
      "text": "Lake Butler’s settlement dates back to 1859, and the town grew around cattle ranching, lumber milling, and construction led by the Townsend brothers.",
      "sourceSentenceIds": [
        12,
        8
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.florida-backroads-travel.com/lake-butler-florida.html"
    },
    {
      "id": 5,
      "text": "The town’s historic King House is a preserved residence that reflects local architectural styles from the early 20th century.",
      "sourceSentenceIds": [
        4,
        16
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.florida-backroads-travel.com/lake-butler-florida.html"
    },
    {
      "id": 6,
      "text": "Lake Butler sits 11 miles west‑southwest of downtown Orlando, yet it remains a quiet community within the Orlando–Kissimmee–Sanford metropolitan area.",
      "sourceSentenceIds": [
        21,
        19
      ],
