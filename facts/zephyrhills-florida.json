    },
    {
      "id": 2,
      "text": "In 1910, Captain Jeffries formalized Abbott Station as the City of Zephyrhills, honoring Civil War veterans.",
      "sourceSentenceIds": [
        15,
        24
      ],
      "sourceLabels": [
        "Web source 1",
