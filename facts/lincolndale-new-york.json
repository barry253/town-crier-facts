  "facts": [
    {
      "id": 1,
      "text": "Lincolndale sits at 41°20′20″N 73°43′33″W, a spot that marks the heart of the historic Town of Somers.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lincolndale%2C_New_York"
    },
    {
      "id": 2,
      "text": "In 1697 King William III granted an 83,000‑acre tract to Stephanus Van Cortland, laying the groundwork for Somers and its hamlets like Lincolndale.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.somersny.gov/resources/history"
    },
    {
      "id": 3,
      "text": "The Empire Sewing Machine factory ran in South Somers from 1866 to 1885, powered by the Muscoot River’s waterwheel.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.somersny.gov/resources/history"
    },
    {
      "id": 4,
      "text": "The Elephant Hotel, bought by the town in 1927, now houses both the town offices and the Somers Historical Society museum.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.somersny.gov/resources/history"
    },
    {
      "id": 5,
      "text": "A railroad reached Brewster in the 1840s, bypassing Somers’ center and slowing the town’s growth for a century.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.somersny.gov/resources/history"
    },
    {
      "id": 6,
      "text": "Lincolndale’s median age is 37.5 years, reflecting a fairly young community in the broader Westchester area.",
      "sourceSentenceIds": [
        22
      ],
      "sourceLabels": [
        "Web source 1"
      ],
