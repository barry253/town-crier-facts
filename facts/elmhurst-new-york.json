    },
    {
      "id": 2,
      "text": "Elmhurst hosts the National Register–listed Benevolent and Protective Order of Elks Lodge Number 878, once the largest Elks lodge in the Eastern U.S.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Elmhurst%2C_Queens"
    },
    {
      "id": 3,
      "text": "The Reformed Church of Newtown, founded in 1731 by Dutch immigrants, is one of New York City’s oldest wood churches.",
      "sourceSentenceIds": [
        3,
        10,
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Elmhurst%2C_Queens"
    },
    {
      "id": 4,
      "text": "Elmhurst Memorial Park, acquired in 1928, honors local soldiers who died in World War I and was originally called Elmhurst Memorial Park.",
      "sourceSentenceIds": [
        4
