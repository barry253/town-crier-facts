      "id": 1,
      "text": "Lower Berkshire Valley CDP sits in western Morris County, mainly in the northeast part of Roxbury Township along Berkshire Valley Road.",
      "sourceSentenceIds": [
        23
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
