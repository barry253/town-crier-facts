  "facts": [
    {
      "id": 1,
      "text": "Founded in 1834 by Sands Higinbotham, Oneida grew around a railroad depot that served the Utica‑Syracuse line.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.britannica.com/place/Oneida-New-York"
    },
    {
      "id": 2,
      "text": "In 1848 John Humphrey Noyes launched the Oneida Community, a 19‑year‑old experiment in communal living that later became a silverware factory.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Oneida_County%2C_New_York"
    },
    {
      "id": 3,
      "text": "The Oneida Silver Company, founded here, still produces American‑made flatware under the Liberty Tabletop brand.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Oneida_County%2C_New_York"
    },
    {
      "id": 4,
      "text": "Oneida County was named in honor of the Oneida, one of the Five Nations of the Iroquois League that long occupied the area.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Oneida_County%2C_New_York"
    },
    {
      "id": 5,
      "text": "The city sits in New York’s Mohawk Valley, a region known for its rich Native American history and early colonial settlements.",
      "sourceSentenceIds": [
        23
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Oneida_County%2C_New_York"
    },
    {
      "id": 6,
      "text": "Oneida is part of the Utica–Rome Metropolitan Statistical Area, linking it to a larger regional economy.",
