  "facts": [
    {
      "id": 1,
      "text": "Indian Creek is a gated community and man‑made barrier island in Miami‑Dade County.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Indian_Creek%2C_Florida"
    },
    {
      "id": 2,
      "text": "The island was created in the 1900s from dredged material and remained a mangrove forest until 1928 when a country club was built.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Indian_Creek%2C_Florida"
    },
    {
      "id": 3,
      "text": "In 1939, the village incorporated, then had only 17 residents and a country club with 180 members.",
      "sourceSentenceIds": [
        15
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Indian_Creek%2C_Florida"
    },
    {
      "id": 4,
      "text": "The village earned the nickname “Billionaire Bunker” because of its concentration of highly affluent residents.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Indian_Creek%2C_Florida"
    },
    {
      "id": 5,
      "text": "A single 1.6‑mile private road, Indian Creek Island Road, runs east‑west, linking homes and the country club.",
      "sourceSentenceIds": [
        23
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Indian_Creek%2C_Florida"
    },
    {
      "id": 6,
      "text": "Automobile access comes solely via a bridge from Surfside, the only land connection to the island.",
      "sourceSentenceIds": [
