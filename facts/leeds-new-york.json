  "facts": [
    {
      "id": 1,
      "text": "Leeds takes its name from the English city of Leeds, United Kingdom.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Leeds%2C_New_York"
    },
    {
      "id": 2,
      "text": "The hamlet sits north of Route 23, west of the New York State Thruway, and northwest of Catskill village.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Leeds%2C_New_York"
    },
    {
      "id": 3,
      "text": "Leeds’ center overlooks Mill Pond, a widening of Catskill Creek that flows through the area.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Leeds%2C_New_York"
    },
    {
      "id": 4,
      "text": "Before becoming Leeds, the settlement was known as Madison, Mill Village, and in the local Native language as Pasqoecq.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Leeds%2C_New_York"
    },
    {
      "id": 5,
      "text": "Leeds lies within the town of Catskill, close to the northern town line of that town.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Leeds%2C_New_York"
    },
    {
      "id": 6,
      "text": "Geographically, Leeds sits at 42°15′12″N 73°53′48″W, on the north side of Catskill Creek.",
