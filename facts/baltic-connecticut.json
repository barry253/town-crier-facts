  "facts": [
    {
      "id": 1,
      "text": "Baltic grew around a cotton mill on the Shetucket River, founded in 1856 by former Rhode Island Governor William Sprague III.",
      "sourceSentenceIds": [
        5,
        8
      ],
      "sourceLabels": [
        "Web source 2",
        "Wikipedia"
      ],
      "source": "https://alchetron.com/Baltic,-Connecticut"
    },
    {
      "id": 2,
      "text": "The village sits where Beaver Brook meets the larger Shetucket River.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.livingplaces.com/CT/New_London_County/Sprague_Town/Baltic_Historic_District.html"
    },
    {
      "id": 3,
      "text": "Baltic Historic District, covering 210 buildings over 122 acres, was listed on the National Register in 1987.",
      "sourceSentenceIds": [
        7,
        15
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Baltic%2C_Connecticut"
    },
    {
      "id": 4,
      "text": "After the original mill burned in 1887, it was rebuilt, sold to a New York syndicate in 1963, and closed in 1967.",
      "sourceSentenceIds": [
        9,
        12,
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Baltic%2C_Connecticut"
    },
    {
      "id": 5,
      "text": "In 1999, the remaining mill ruins were destroyed by fire, leaving only one building that survived but was critically damaged.",
      "sourceSentenceIds": [
        16,
        17
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Baltic%2C_Connecticut"
    },
    {
      "id": 6,
      "text": "Every spring, Baltic hosts the Sprague River Run, a tubing event on the Shetucket River that runs from April to October.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Baltic%2C_Connecticut"
    }
  ]
