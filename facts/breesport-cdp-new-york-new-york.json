  "facts": [
    {
      "id": 1,
      "text": "Breesport began with two log houses built in 1816, marking the earliest settlement in the area.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/breesport_new_york"
    },
    {
      "id": 2,
      "text": "The Chemung County poorhouse opened in 1837 on an 180‑acre farm in Breesport and served the disadvantaged until 1971.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://chemungcountyny.gov/289/History"
    },
    {
      "id": 3,
      "text": "In 1857 Joseph Rodbourn built Breesport’s first steam‑powered sawmill, capable of 3 million feet of lumber per year, boosting local industry.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/breesport_new_york"
    },
    {
      "id": 4,
      "text": "Rodbourn also helped fund the Utica‑Ithaca‑Elmira Railroad in 1874, making Breesport a rail link to regional markets.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/breesport_new_york"
    },
    {
      "id": 5,
      "text": "New York State Route 223 runs through Breesport, connecting the hamlet to Horseheads and Erin over a span of about six miles.",
      "sourceSentenceIds": [
        15
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/breesport_new_york"
    },
    {
      "id": 6,
      "text": "Breesport sits at 1,099 feet above sea level, giving it a moderate highland setting in upstate New York.",
