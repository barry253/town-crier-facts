  "facts": [
    {
      "id": 1,
      "text": "Cumberland Head Lighthouse, standing on the tip of the peninsula, was erected to guide ships into Plattsburgh harbor.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://lighthousefriends.com/light.asp?ID=676"
    },
    {
      "id": 2,
      "text": "The station’s 50‑foot conical tower rises beside a two‑story Victorian Gothic house, a rare architectural pairing for a lighthouse.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://lighthousefriends.com/light.asp?ID=676"
    },
    {
      "id": 3,
      "text": "Cumberland Head itself juts into Lake Champlain, forming a peninsula that hosts the communities of Rocky Point and Champlain Park.",
      "sourceSentenceIds": [
        15
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Cumberland_Head%2C_New_York"
    },
    {
      "id": 4,
      "text": "At the southern tip, a ferry landing once carried passengers to Gordon Landing on Grand Isle, Vermont.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Cumberland_Head%2C_New_York"
    },
    {
      "id": 5,
      "text": "The lighthouse’s coordinates are 44°42′59″N 73°24′9″W, placing it just north of Plattsburgh’s downtown.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Cumberland_Head%2C_New_York"
    },
    {
      "id": 6,
      "text": "The lighthouse’s stone walls were finished in a style praised by contractors for its high quality craftsmanship.",
