  "facts": [
    {
      "id": 1,
      "text": "Ellenton takes its name from Ellen Patten, the daughter of Major George Patten who purchased the plantation in 1870.",
      "sourceSentenceIds": [
        1,
        2
      ],
      "sourceLabels": [
        "Web source 1",
        "Wikipedia"
      ],
      "source": "https://www.floridasmart.com/city-guide/ellenton"
    },
    {
      "id": 2,
      "text": "The Gamble Plantation, built between 1845 and 1850 by Major Robert Gamble, remains Ellenton’s oldest standing structure.",
      "sourceSentenceIds": [
        6,
        13
      ],
      "sourceLabels": [
        "Web source 2",
        "Wikipedia"
      ],
      "source": "https://grokipedia.com/page/Ellenton,_Florida"
    },
    {
      "id": 3,
      "text": "A fuller's earth refinery opened on the Manatee River in 1903, employing over 150 workers before burning down in 1908, 1912, and 1922.",
      "sourceSentenceIds": [
        15,
        17,
        18
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ellenton%2C_Florida"
    },
    {
      "id": 4,
      "text": "Ellenton lies on the north side of the tidal Manatee River, which forms its southern boundary.",
      "sourceSentenceIds": [
        20,
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ellenton%2C_Florida"
    },
    {
      "id": 5,
      "text": "The United States established Ellenton’s post office in 1881, cementing its status as a local community center.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ellenton%2C_Florida"
    },
    {
      "id": 6,
      "text": "Ellenton is included in the North Port–Bradenton–Sarasota Metropolitan Statistical Area, linking it to a broader regional economy.",
