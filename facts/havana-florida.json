  "facts": [
    {
      "id": 1,
      "text": "Havana was named after Havana, Cuba, because a local teacher believed Florida’s hand‑rolled cigars matched Cuban ones.",
      "sourceSentenceIds": [
        3,
        14,
        15
      ],
      "sourceLabels": [
