    {
      "id": 1,
      "text": "West Hempstead first appeared on maps as a Long Island Railroad station in 1893.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/West_Hempstead%2C_New_York"
    },
    {
      "id": 2,
      "text": "The name literally means “west of Hempstead,” a nod to its English namesake in Essex.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.wisdomlib.org/cities/west-hempstead-23551"
    },
    {
      "id": 3,
      "text": "The West Hempstead Public Library opened in 1956 and received a state charter in 1967.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/West_Hempstead%2C_New_York"
    },
    {
      "id": 4,
      "text": "Mom‑and‑pop shops, a kosher bakery founded in 1931, and other local eateries line Hempstead Avenue.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Local source"
      ],
      "source": "local"
    },
    {
      "id": 5,
      "text": "Halls Pond Park, the town’s main green space, was dedicated by Nassau County in 1961.",
      "sourceSentenceIds": [
        21
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/West_Hempstead%2C_New_York"
    },
    {
      "id": 6,
      "text": "The Cradle of Aviation Museum, with over 70 aircraft, showcases Long Island’s aviation heritage.",
