  "facts": [
    {
      "id": 1,
      "text": "Locust Valley's name came from 1856 when locals noted the many locust trees.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://communityhistoryarchives.com/places/locust-valley-library/"
    },
    {
      "id": 2,
      "text": "The 1869 LIRR extension made Locust Valley the line's terminus until 1889, turning it into a commercial hub for the Gold Coast.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Locust_Valley%2C_New_York"
    },
    {
      "id": 3,
      "text": "The Locust Valley Library, founded in 1909 by publishing tycoon Frank Doubleday and his wife, now hosts a free digital archive of local history.",
      "sourceSentenceIds": [
        26,
        6
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://communityhistoryarchives.com/places/locust-valley-library/"
    },
    {
      "id": 4,
      "text": "Two historic homes from 1698, the Joseph Weeks Jr. house and another, sit within Locust Valley, both on the National Register of Historic Places.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://communityhistoryarchives.com/places/locust-valley-library/"
    },
    {
      "id": 5,
      "text": "The Matinecock Friends Meeting House, built in 1725, once served the Quaker community and is now a National Register landmark.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://communityhistoryarchives.com/places/locust-valley-library/"
