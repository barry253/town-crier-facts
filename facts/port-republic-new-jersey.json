  "facts": [
    {
      "id": 1,
      "text": "Port Republic was renamed when a post office opened, because another town already called Unionville existed.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.livingplaces.com/NJ/Atlantic_County/Port_Republic_City/Port_Republic_Historic_District.html"
    },
    {
      "id": 2,
      "text": "Before its renaming, the area was known as Chestnut Neck, the largest coastal village in 1776 and a busy New York shipping hub.",
      "sourceSentenceIds": [
        25
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.livingplaces.com/NJ/Atlantic_County/Port_Republic_City/Port_Republic_Historic_District.html"
    },
    {
      "id": 3,
      "text": "The slow silting of Nacote Creek, combined with steam‑powered craft and rampant deforestation, caused Port Republic to lose its status as a port and shipbuilding center.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.livingplaces.com/NJ/Atlantic_County/Port_Republic_City/Port_Republic_Historic_District.html"
    },
    {
      "id": 4,
      "text": "Early 18th‑century structures like the Franklin Inn and Haig Place showcase Georgian and Federal architectural styles that still stand today.",
      "sourceSentenceIds": [
        26
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.livingplaces.com/NJ/Atlantic_County/Port_Republic_City/Port_Republic_Historic_District.html"
    },
    {
      "id": 5,
      "text": "Rapid deforestation of southern New Jersey in the 19th century accelerated the silting of Nacote Creek, hastening the town’s decline as a maritime hub.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.livingplaces.com/NJ/Atlantic_County/Port_Republic_City/Port_Republic_Historic_District.html"
    },
    {
      "id": 6,
      "text": "The town’s abandonment as a port left many historic buildings in disrepair, a reminder of its once‑thriving maritime past.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Paterson%2C_New_Jersey"
    }
  ]
}
