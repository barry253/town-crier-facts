  "facts": [
    {
      "id": 1,
      "text": "Millport was originally called Millvale, a name that changed in 1829 when the Chemung Canal was authorized for construction.",
      "sourceSentenceIds": [
        1,
        12,
        13
      ],
      "sourceLabels": [
        "Web source 2",
        "Web source 1"
      ],
      "source": "https://cchsonlineexhibits.wixsite.com/towns-and-villages/millportvillage"
    },
    {
      "id": 2,
      "text": "The village was laid out in 1825 by Green Bentley, a veteran of the French and Indian War and the American Revolution.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://cchsonlineexhibits.wixsite.com/towns-and-villages/millportvillage"
    },
    {
      "id": 3,
      "text": "Millport officially became a village in 1923, solidifying its status along the canal route.",
      "sourceSentenceIds": [
        20
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://cchsonlineexhibits.wixsite.com/towns-and-villages/millportvillage"
    },
    {
      "id": 4,
      "text": "Located north of Elmira, Millport sits amid rolling hills in the Southern Tier/Finger Lakes Region of New York State.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://millportny.gov/post.php?pid=3"
    },
    {
      "id": 5,
      "text": "Early settlers built homes and businesses along the road between Elmira and Watkins Glen, shaping the village’s early economy.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://cchsonlineexhibits.wixsite.com/towns-and-villages/millportvillage"
    },
    {
      "id": 6,
      "text": "The Chemung Canal brought prosperity to Millport, turning it into a bustling hub during its operation.",
