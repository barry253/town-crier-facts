  "facts": [
    {
      "id": 1,
      "text": "Ruby sits 6.3 miles north of Kingston, nestled between the Hudson River and the Catskill foothills.",
      "sourceSentenceIds": [
        17,
        27
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Ruby%2C_New_York"
    },
    {
      "id": 2,
      "text": "Originally called the Dutch Settlement, Ruby grew as an agricultural hub with farms along creek valleys in the 18th century.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/ruby_new_york"
    },
    {
      "id": 3,
      "text": "19th‑ and early 20th‑century stone quarries in Ruby produced millstones and building stone for the Hudson Valley.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/ruby_new_york"
    },
    {
      "id": 4,
      "text": "Esopus Creek, a major tributary of the Hudson, winds through Ruby, shaping local drainage and sediment transport.",
      "sourceSentenceIds": [
        29
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/ruby_new_york"
    },
    {
      "id": 5,
      "text": "The 1663 Esopus Wars, sparked by land tensions, saw indigenous attacks on Dutch outposts near Ruby, reshaping the region.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/ruby_new_york"
    },
    {
      "id": 6,
      "text": "Ruby’s elevation is 312 feet (95 meters) above sea level, giving it a modest hilltop perspective of the valley.",
