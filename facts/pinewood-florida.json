  "facts": [
    {
      "id": 1,
      "text": "Pinewood was annexed into Miami in 1925, once a neighborhood of the city before gaining its own identity.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Pinewood%2C_Florida"
    },
    {
      "id": 2,
      "text": "Today Pinewood sits within the Miami metropolitan area, sharing the vibrant culture of South Florida.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Pinewood%2C_Florida"
    },
    {
      "id": 3,
      "text": "During the Great Depression, Miami relinquished jurisdiction and Pinewood became an unincorporated area of Miami‑Dade County.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Pinewood%2C_Florida"
    },
    {
      "id": 4,
      "text": "The community lies just eight miles north of downtown Miami, a short drive into the heart of the city.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Pinewood%2C_Florida"
    },
    {
      "id": 5,
      "text": "Pinewood is bordered by North Miami to the north, Miami Shores to the east, and West Little River to the south.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Pinewood%2C_Florida"
    },
    {
