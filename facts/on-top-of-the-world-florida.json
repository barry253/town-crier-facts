  "facts": [
    {
      "id": 1,
      "text": "On Top of the World, Florida sits 11 miles southwest of Ocala, the county seat of Marion County.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/On_Top_of_the_World%2C_Florida"
    },
    {
      "id": 2,
      "text": "The community was founded in 1947 by Sidney Colen, a developer who later built the town of Kenneth City in Pinellas County.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.florida-backroads-travel.com/on-top-of-the-world-ocala-florida.html"
    },
    {
      "id": 3,
      "text": "Colen purchased the historic Circle Square Ranch in 1975, preserving 9,000 acres of working cattle land within the new retirement community.",
      "sourceSentenceIds": [
        4,
        22,
        25
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.florida-backroads-travel.com/on-top-of-the-world-ocala-florida.html"
    },
    {
      "id": 4,
      "text": "Residents affectionately call the area OTOW, a nickname that echoes its original ranching roots.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.florida-backroads-travel.com/on-top-of-the-world-ocala-florida.html"
    },
    {
      "id": 5,
      "text": "The master plan includes 15 gated neighborhoods, some offering 99‑year land leases while others grant fee‑simple ownership.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.florida-backroads-travel.com/on-top-of-the-world-ocala-florida.html"
    },
    {
      "id": 6,
      "text": "The median age in On Top of the World is 72.5 years, with over 80% of residents aged 65 or older, reflecting its status as a 55+ retirement community.",
      "sourceSentenceIds": [
