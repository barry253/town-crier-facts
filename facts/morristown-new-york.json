  "facts": [
    {
      "id": 1,
      "text": "Morristown is named after Gouverneur Morris, a signer of the Constitution and Declaration of Independence.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Morristown_(hamlet)%2C_New_York"
    },
    {
      "id": 2,
      "text": "The village’s most famous industry was the manufacture of Morse’s Indian Root Pills, a patent medicine that drew railroad service by 1876.",
      "sourceSentenceIds": [
        1,
        18,
        29
      ],
      "sourceLabels": [
        "Web source 2",
        "Web source 2",
        "Wikipedia"
      ],
      "source": "https://www.morristowngatewaymuseum.org/history.html"
    },
    {
      "id": 3,
      "text": "The Gateway Museum, built by the Comstock family, once served as a community center for employees of Dr. Morse’s Indian Root Pills factory.",
      "sourceSentenceIds": [
        11,
        29
      ],
      "sourceLabels": [
        "Web source 2",
        "Wikipedia"
      ],
      "source": "https://www.morristowngatewaymuseum.org/history.html"
    },
    {
      "id": 4,
      "text": "In the late 1800s, Morristown boasted a bustling commercial district with a cheese factory, boot maker, barrel maker, wheelwright, and blacksmith.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.townofmorristownny.gov/about-morristown.html"
    },
    {
      "id": 5,
      "text": "The Red Barn Museum, originally a prominent barn on the property, now preserves the town’s agricultural heritage and hosts seasonal concerts.",
      "sourceSentenceIds": [
        4,
        8
      ],
      "sourceLabels": [
