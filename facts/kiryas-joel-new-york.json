  "facts": [
    {
      "id": 1,
      "text": "Kiryas Joel is named for Joel Teitelbaum, the late Satmar rebbe who envisioned the village as a haven for his followers.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Kiryas_Joel%2C_New_York"
    },
    {
      "id": 2,
      "text": "Satmar Hasidim who founded Kiryas Joel originally came from Satu Mare, Romania, then part of Hungary.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Kiryas_Joel%2C_New_York"
    },
    {
      "id": 3,
      "text": "In the early 1970s the community bought land and settled 14 Satmar families there in summer 1974.",
      "sourceSentenceIds": [
        19
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Kiryas_Joel%2C_New_York"
    },
    {
      "id": 4,
      "text": "Monroe town officials initially doubted the plan, but allowed Kiryas Joel to incorporate as a village in 1976.",
      "sourceSentenceIds": [
        20
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Kiryas_Joel%2C_New_York"
    },
    {
      "id": 5,
      "text": "In 2019 Kiryas Joel separated from Monroe to become part of the newly formed Town of Palm Tree, New York’s first new town in 38 years.",
