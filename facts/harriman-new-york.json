  "facts": [
    {
      "id": 1,
      "text": "Harriman takes its name from former Union Pacific Railroad president E.H. Harriman, honoring his railroad legacy.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.villageofharriman.gov/"
    },
    {
      "id": 2,
      "text": "The village’s name honors a 19th‑century New York state senator, not President James Monroe.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Monroe_(village)%2C_New_York"
    },
    {
      "id": 3,
      "text": "The Monroe Historical Society, founded in 1974, preserves Harriman’s heritage through photographs, artifacts, and written history.",
      "sourceSentenceIds": [
        1,
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.monroehistoryny.org/"
    },
    {
      "id": 4,
      "text": "In 1990 the Monroe Historical Society received a New York State charter, formalizing its role as a non‑profit heritage organization.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.monroehistoryny.org/"
    },
    {
      "id": 5,
      "text": "Harriman’s Main Street is NY 17M, the village’s historic commercial artery.",
      "sourceSentenceIds": [
