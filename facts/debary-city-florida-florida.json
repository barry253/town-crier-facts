    {
      "id": 1,
      "text": "DeBary was named after Samuel Frederick de Bary, a New York wine merchant who bought land there in 1871 and built a hunting lodge.",
      "sourceSentenceIds": [
        4,
        5,
        23
      ],
      "sourceLabels": [
