  "facts": [
    {
      "id": 1,
      "text": "New Preston was named after George Washington, who passed through the area during the American Revolution.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Preston%2C_Connecticut"
    },
    {
      "id": 2,
      "text": "The Shepaug Railroad arrived in 1872, bringing passenger service to New York City and sparking summer homes around Lake Waramaug.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Preston%2C_Connecticut"
    },
    {
      "id": 3,
      "text": "The East Aspetuck River drops sharply from Lake Waramaug, powering mills built in the early 19th century.",
      "sourceSentenceIds": [
        5,
        6
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Preston%2C_Connecticut"
    },
    {
      "id": 4,
      "text": "New Preston served as a filming location for the 1981 horror movie Friday the 13th Part 2, with several historic buildings used as sets.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Preston%2C_Connecticut"
    },
    {
      "id": 5,
      "text": "Lake Waramaug dominates the town, acting as the headwaters of the East Aspetuck River and the site of New Preston Falls.",
      "sourceSentenceIds": [
        22
