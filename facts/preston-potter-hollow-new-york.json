  "facts": [
    {
      "id": 1,
      "text": "Preston‑Potter Hollow was named after early settler Timothy Potter, who arrived around 1806.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://albanyhilltowns.com/Potter_Hollow"
    },
    {
      "id": 2,
      "text": "The hamlet’s historic buildings along the main road still echo a bustling rural past, even though the area is now largely deserted.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.potterhollow.com/"
    },
    {
      "id": 3,
      "text": "Potter Hollow Garden and Potter Hollow Sheep are the only remaining community farms, keeping the area’s agrarian heritage alive.",
      "sourceSentenceIds": [
        19
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.potterhollow.com/"
    },
    {
      "id": 4,
      "text": "The 19th‑century Sidney White House and the 19th‑century school are listed on the National Register of Historic Places.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Preston-Potter_Hollow%2C_New_York"
    },
    {
      "id": 5,
      "text": "Early settlers included Samuel Palmer, Gerardus Drake, and John Drake, who established the first homes in the hollow by the early 1800s.",
      "sourceSentenceIds": [
        24
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://albanyhilltowns.com/Potter_Hollow"
    },
    {
      "id": 6,
      "text": "Potter Hollow’s location at 42°25′53″N 74°13′23″W places it just inside the western edge of Rensselaerville, near the Greene County border.",
      "sourceSentenceIds": [
        10,
        9
      ],
