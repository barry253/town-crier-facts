    {
      "id": 1,
      "text": "Kensington’s name comes from London’s Kensington Gardens, and the village’s original gates were modeled after those historic gates.",
      "sourceSentenceIds": [
        1,
        3
      ],
      "sourceLabels": [
        "Wikipedia",
