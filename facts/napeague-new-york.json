    },
    {
      "id": 2,
      "text": "The Mackay Radio Tower, 300 feet tall, was one of two towers that began international radio in 1927.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Napeague%2C_New_York"
    },
    {
      "id": 3,
      "text": "The abandoned Smith Meal Fish Factory in Promised Land processed menhaden into fish meal until it closed in 1969.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Napeague%2C_New_York"
    },
    {
      "id": 4,
      "text": "After shutting down, the factory was sold to The Nature Conservancy and later transferred to the State Parks Commission.",
      "sourceSentenceIds": [
