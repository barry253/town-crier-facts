  "facts": [
    {
      "id": 1,
      "text": "Oyster Bay Cove became an incorporated village on December 29, 1931, covering about 4.2 square miles of preserved waterfront estates.",
      "sourceSentenceIds": [
        25,
        26,
        27,
        28
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Oyster_Bay_Cove,_New_York"
    },
    {
      "id": 2,
      "text": "The Oyster Bay Long Island Railroad Station, built in 1889, operated until 1999 and now sits as a town landmark on the National Register.",
      "sourceSentenceIds": [
        4,
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.nps.gov/places/oyster-bay-new-york.htm"
    },
    {
      "id": 3,
      "text": "The Moore Building, a historic town landmark, is listed on the National Register of Historic Places.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.nps.gov/places/oyster-bay-new-york.htm"
    },
    {
      "id": 4,
      "text": "A Carpenter Gothic-style church erected in 1873 is also on the National Register of Historic Places.",
      "sourceSentenceIds": [
        21
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.nps.gov/places/oyster-bay-new-york.htm"
    },
    {
      "id": 5,
      "text": "During the Revolutionary War, members of the Culper Spy Ring operated here, and George Washington and the Roosevelt family visited the area.",
      "sourceSentenceIds": [
        8,
        11
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Oyster_Bay_Cove,_New_York"
    },
    {
      "id": 6,
      "text": "Sagamore Hill National Historic Site, the former home of Theodore Roosevelt, lies just outside Oyster Bay Cove in neighboring Cove Neck.",
