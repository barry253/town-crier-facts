  "facts": [
    {
      "id": 1,
      "text": "Marshallville was founded as a glass‑making village, becoming the earliest “glass town” in the Great Egg Harbor watershed.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.livingplaces.com/NJ/Cape_May_County/Upper_Township/Marshallville_Historic_District.html"
    },
    {
      "id": 2,
      "text": "The historic district sits at the heart of the community, preserving the town’s original glass‑making architecture.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Marshallville%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "A house built beside the original factory once served as the overseer’s residence where Frederick blew glass.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.livingplaces.com/NJ/Cape_May_County/Upper_Township/Marshallville_Historic_District.html"
    },
    {
      "id": 4,
      "text": "Two of Frederick’s sons, Fred and Randall, learned to cut glass in the factory, continuing the family trade.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.livingplaces.com/NJ/Cape_May_County/Upper_Township/Marshallville_Historic_District.html"
    },
    {
      "id": 5,
      "text": "An extensive survey of 88 glass‑making sites in southern New Jersey named Marshallville one of eight eligible for the New Jersey and National Registers of Historic Places.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.livingplaces.com/NJ/Cape_May_County/Upper_Township/Marshallville_Historic_District.html"
    },
    {
      "id": 6,
      "text": "New Jersey Route 49 cuts through Marshallville, connecting the town northwest to Millville and southeast to Tuckahoe.",
