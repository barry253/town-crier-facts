  "facts": [
    {
      "id": 1,
      "text": "Port Henry was founded in 1785 by William McKenzie and quickly became a hub for sawmills and iron production.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.lakechamplainregion.com/history/port-henry-moriah-historic-buildings"
    },
    {
      "id": 2,
      "text": "The town’s historic carriage house now houses the Iron History Museum and the Town of Moriah Historical Society.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.porthenrymoriah.com/living-here/about/more-history/historic-buildings"
    },
    {
      "id": 3,
      "text": "Port Henry’s Sherman Free Library, opened in 1887, was described by the New York Times as “Gothic” and features beaded board vaulted ceilings.",
      "sourceSentenceIds": [
        21,
        22,
        23
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.porthenrymoriah.com/living-here/about/more-history/historic-buildings"
    },
    {
      "id": 4,
      "text": "The Delaware & Hudson Railroad Depot in Port Henry linked the village to regional markets in the late 19th century.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Port_Henry%2C_New_York"
    },
    {
      "id": 5,
      "text": "Port Henry’s Van Ornam & Murdock Block, an Italianate building, still stands today and is listed on the National Register of Historic Places.",
      "sourceSentenceIds": [
