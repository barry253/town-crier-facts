  "facts": [
    {
      "id": 1,
      "text": "Ransomville was founded in 1842 by the Ransom and Curtiss families and named after William Henry Harrison Ransom.",
      "sourceSentenceIds": [
        1,
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ransomville%2C_New_York"
    },
    {
      "id": 2,
      "text": "The hamlet’s early log taverns were built by Gideon Curtiss in 1817 and 1825, predating the town’s official establishment.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ransomville%2C_New_York"
    },
    {
      "id": 3,
      "text": "In 1876 the Rome, Watertown and Ogdensburg Railroad extended tracks through Ransomville, linking it to Lewiston and Syracuse.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ransomville%2C_New_York"
    },
    {
      "id": 4,
      "text": "The Ransomville Historical Room, housed behind the library at 3733 Ransomville Road, preserves the original post office relocated there.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://ransomvillelibrary.org/Historical-Room.html"
    },
    {
      "id": 5,
      "text": "Ransomville lies north of Niagara Falls and is part of the Buffalo–Niagara Falls Metropolitan Statistical Area.",
      "sourceSentenceIds": [
        20
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ransomville%2C_New_York"
    },
    {
      "id": 6,
      "text": "The hamlet’s coordinates are 43.236955°N, 78.915327°W, placing it in western New York’s Niagara County.",
