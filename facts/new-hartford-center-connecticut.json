  "facts": [
    {
      "id": 1,
      "text": "New Hartford Center sits in the valley of the West Branch of the Farmington River, giving the town a classic New England riverside feel.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Hartford_Center%2C_Connecticut"
    },
    {
      "id": 2,
      "text": "The community’s core is the village of New Hartford, surrounded by the historic Pine Meadow district and stretches into nearby forested land.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Hartford_Center%2C_Connecticut"
    },
    {
      "id": 3,
      "text": "Route 44 runs straight through New Hartford Center as Main Street, linking the town to Winsted and Hartford along a historic corridor.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Hartford_Center%2C_Connecticut"
    },
    {
      "id": 4,
      "text": "To the south, the CDP reaches the confluence of the East and West Branches of the Farmington River, a key geographic marker.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Hartford_Center%2C_Connecticut"
    },
    {
      "id": 5,
      "text": "Eastward, the CDP borders Connecticut Route 219 near Lake McDonough, a reservoir on the East Branch of the Farmington River.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/New_Hartford_Center%2C_Connecticut"
    },
    {
      "id": 6,
      "text": "The western edge of the CDP follows an unnamed brook about half a mile west of the village, meeting the Barkhamsted town line to the north.",
