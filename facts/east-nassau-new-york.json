    },
    {
      "id": 2,
      "text": "Historic accounts of East Nassau appear in an 1897 book and in early abstracts of settlers at rensselaer.nygenweb.net.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://villageeastnassau.digitaltowpath.org:10128/content/Generic/View/19"
    },
    {
      "id": 3,
      "text": "Before incorporation, East Nassau was called Schermerhorn's, honoring an early settler who helped shape the hamlet.",
      "sourceSentenceIds": [
        14,
        15
      ],
      "sourceLabels": [
        "Web source 2"
