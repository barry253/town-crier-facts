  "facts": [
    {
      "id": 1,
      "text": "Named after Scotland's River Clyde, the village sits on the Clyde River, a tributary of the Seneca River.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Clyde%2C_New_York"
    },
    {
      "id": 2,
      "text": "Incorporated in 1835, Clyde’s growth followed the river, then the Erie Canal, and later the railroad.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.waynehistorians.org/Places/site.php?site=1251"
    },
    {
      "id": 3,
      "text": "The Clyde Downtown Historic District, with 59 buildings, surrounds Washington Square Park and the old Erie Canal bed.",
      "sourceSentenceIds": [
        6,
        7
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.waynehistorians.org/Places/site.php?site=1251"
    },
    {
      "id": 4,
      "text": "Clyde lies roughly midway between Rochester and Syracuse, near the historic Erie Canal that once powered regional trade.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.citydirectory.us/village-clyde-new-york.html"
    },
    {
      "id": 5,
      "text": "The village’s post office, a mid‑twentieth‑century Colonial Revival building, was listed on the National Register in 1988.",
      "sourceSentenceIds": [
        3,
        4
      ],
      "sourceLabels": [
        "Web source 1",
        "Wikipedia"
      ],
      "source": "https://www.waynehistorians.org/Places/site.php?site=1251"
    },
    {
      "id": 6,
      "text": "The village sits at the crossroads of state routes 31 and 414, a junction that has guided travelers for generations.",
      "sourceSentenceIds": [
        25
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
