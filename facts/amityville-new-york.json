  "facts": [
    {
      "id": 1,
      "text": "Amityville got its name when mill owner Samuel Ireland suggested naming the town after his boat, the Amity, in a 19th‑century meeting.",
      "sourceSentenceIds": [
        8,
        29
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://townofbabylonny.gov/571/Amityville-Village-History"
    },
    {
      "id": 2,
      "text": "Settlers from Huntington first reached the area in 1653, and Chief Wyandanch granted the first deed in 1658, marking the town’s earliest land ownership.",
      "sourceSentenceIds": [
        27,
        28
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Amityville%2C_New_York"
    },
    {
      "id": 3,
      "text": "The South Side Railroad arrived in Amityville in 1867, linking the village to the growing Long Island rail network.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://townofbabylonny.gov/571/Amityville-Village-History"
    },
    {
      "id": 4,
      "text": "The Long Island Home for Nervous Invalids opened in 1881, later becoming South Oaks Hospital, while Louden Hall Psychiatric Hospital was founded in 1886.",
      "sourceSentenceIds": [
        1,
        9
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://townofbabylonny.gov/571/Amityville-Village-History"
    },
    {
      "id": 5,
      "text": "When the History Channel released a 2000 documentary on The Amityville Horror, no member of the Historical Society spoke on camera about the events.",
