  "facts": [
    {
      "id": 1,
      "text": "Worthington Springs takes its name from early settler Sam Worthington, who arrived before the first Seminole War of 1814–1819.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Worthington_Springs%2C_Florida"
    },
    {
      "id": 2,
      "text": "The mineral spring on the Santa Fe River was thought to have healing powers, drawing visitors from the late 1800s to the early 1900s.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Worthington_Springs%2C_Florida"
    },
    {
      "id": 3,
      "text": "An iron and timber bridge spanned the Santa Fe River in 1908, later replaced in 1937 by the concrete bridge still seen today.",
      "sourceSentenceIds": [
        14,
        15
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Worthington_Springs%2C_Florida"
    },
    {
      "id": 4,
      "text": "In the early 1900s, swimming at Worthington Springs was segregated, with men and women assigned separate time slots.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Worthington_Springs%2C_Florida"
    },
    {
      "id": 5,
      "text": "Independence Day at the springs was a highlight, with a special train bringing people from Jacksonville for the holiday festivities.",
      "sourceSentenceIds": [
        11,
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Worthington_Springs%2C_Florida"
    },
    {
      "id": 6,
      "text": "In 1975 a community center opened, housing the town hall, while earlier street lights and a playground brightened the town park.",
