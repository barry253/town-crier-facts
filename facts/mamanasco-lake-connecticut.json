  "facts": [
    {
      "id": 1,
      "text": "Originally about one‑third its current size, two impounding structures built in 1716 expanded Mamanasco Lake to the 96‑acre body it is today.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://mamanasco.com/lake-history/"
    },
    {
      "id": 2,
      "text": "Mamanasco Lake stretches 4,750 feet long and 1,500 feet wide, covering roughly 96 acres of water.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://mamanasco.com/lake-history/"
    },
    {
      "id": 3,
      "text": "The lake’s deepest point sits 10 feet below the surface, while its average depth ranges between five and six feet.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://mamanasco.com/lake-history/"
    },
    {
      "id": 4,
      "text": "Gasoline motors are banned on Mamanasco Lake; boats glide by row, canoe, electric motor or sail instead.",
      "sourceSentenceIds": [
        29
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://mamanasco.com/lake-history/"
    },
    {
      "id": 5,
      "text": "In 1972, the Mamanasco Lake Improvement Fund was founded to oversee and improve the lake’s water quality.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.geocities.ws/mamanasco_2000/LakeHistory.html"
    },
    {
      "id": 6,
      "text": "Mamanasco Lake hosts a variety of recreational activities, from swimming and fishing to sailing and ice fishing during winter.",
      "sourceSentenceIds": [
        25
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://mamanasco.com/lake-history/"
    }
  ]
