  "facts": [
    {
      "id": 1,
      "text": "Randolph takes its name from early settlers who came from Randolph, Vermont, and founded the community in 1820.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://historicpath.com/history/randolph"
    },
    {
      "id": 2,
      "text": "The Atlantic & Great Western Railroad built a station in Randolph, linking the village to major southern and eastern markets in the 19th century.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://historicpath.com/history/randolph"
    },
    {
      "id": 3,
      "text": "The former Chamberlain Institute and Female College, a Methodist school that burned down, now houses Randolph High School.",
      "sourceSentenceIds": [
        16,
        17
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Randolph_(CDP)%2C_New_York"
    },
    {
      "id": 4,
      "text": "Randolph Historic District earned a spot on the National Register of Historic Places in 2012, preserving its 19th‑century architecture.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Randolph_(CDP)%2C_New_York"
    },
    {
      "id": 5,
      "text": "The village of Randolph was officially incorporated in 1867, becoming a formal municipality within the town.",
