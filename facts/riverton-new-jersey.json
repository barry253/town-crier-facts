  "facts": [
    {
      "id": 1,
      "text": "Riverton was founded in 1851 by ten Philadelphians who built summer homes on 120 acres of riverfront land.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://riverton-nj.com/history/"
    },
    {
      "id": 2,
      "text": "Architect Samuel Sloan was hired to design the village, creating a planned community that stretched along the Delaware River.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://riverton-nj.com/history/"
    },
    {
      "id": 3,
      "text": "Architectural historian Henry Russell Hitchcock called Riverton the first totally planned residential subdivision in America.",
      "sourceSentenceIds": [
        23
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://riverton-nj.com/history/"
    },
    {
      "id": 4,
      "text": "The Riverton station on Main Street links the borough to Camden, Trenton, New York City, and Philadelphia via the River Line and NJ Transit.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Riverton%2C_New_Jersey"
    },
    {
      "id": 5,
      "text": "Riverton has been a dry town since 1952, when a deed clause prohibited the sale or manufacture of alcohol.",
      "sourceSentenceIds": [
        29
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Riverton%2C_New_Jersey"
    },
    {
