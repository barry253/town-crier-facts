  "facts": [
    {
      "id": 1,
      "text": "Dorchester is an unincorporated community in Maurice River Township, Cumberland County, New Jersey.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Dorchester%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "The village sits along the Maurice River, just about 2 miles from Delaware Bay, giving it historic maritime ties.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/dorchester_new_jersey"
    },
    {
      "id": 3,
      "text": "Shipbuilding has been Dorchester’s main industry since the 1700s, with the A.J. and Meerwald tall ships built here.",
      "sourceSentenceIds": [
        4,
        10
      ],
      "sourceLabels": [
        "Web source 1",
        "Wikipedia"
      ],
      "source": "https://grokipedia.com/page/dorchester_new_jersey"
    },
    {
      "id": 4,
      "text": "The Dorchester United Methodist Church, erected in 1856, remains a key landmark in the community.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/dorchester_new_jersey"
    },
    {
      "id": 5,
      "text": "The area’s low elevation and tidal dynamics make it prone to flooding, a risk noted in historical records.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/dorchester_new_jersey"
    },
    {
      "id": 6,
      "text": "Dorchester’s wetlands, shaped by brackish water from Delaware Bay, support species adapted to saline conditions and help mitigate floods.",
