  "facts": [
    {
      "id": 1,
      "text": "Palmyra was founded in 1789 as a frontier town originally called Swift's Landing.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.palmyravillageny.gov/about"
    },
    {
      "id": 2,
      "text": "The town’s name honors the ancient Syrian city of Palmyra, reflecting its founders’ admiration for classical antiquity.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Palmyra%2C_New_York"
    },
    {
      "id": 3,
      "text": "Palmyra is the birthplace of the Latter Day Saint movement; Joseph Smith’s 1820 First Vision occurred on a farm near the town.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Palmyra%2C_New_York"
    },
    {
      "id": 4,
      "text": "In 1822 the Erie Canal reached Palmyra, making it a key stop on the canalway that linked the Great Lakes to the Atlantic.",
      "sourceSentenceIds": [
        24
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Palmyra%2C_New_York"
    },
    {
      "id": 5,
      "text": "The East Palmyra Presbyterian Church, built in 1905, was listed on the National Register of Historic Places in 2002.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Palmyra%2C_New_York"
    },
    {
      "id": 6,
      "text": "The town hosts more than 200 historic properties, many on the National Register, showcasing 19th‑century architecture that attracts history buffs.",
