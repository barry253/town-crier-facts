  "facts": [
    {
      "id": 1,
      "text": "Heritage Pines sits on the historic site of Pineland, once home to one of Florida’s largest native settlements that dates back over 2,000 years.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Pineland%2C_Florida"
    },
    {
      "id": 2,
      "text": "For 1,500 years before Europeans arrived, the Calusa people thrived here, leaving behind shell mounds and a canal system still visible today.",
      "sourceSentenceIds": [
        7,
        17
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Pineland%2C_Florida"
    },
    {
      "id": 3,
      "text": "The area’s name, originally called 'Tampa' or 'Tanpa' by the Calusa, was mistakenly transferred north by early explorers.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Pineland%2C_Florida"
    },
    {
      "id": 4,
      "text": "The Randell Research Center, part of the Florida Museum of Natural History, preserves and studies the ancient Calusa settlement right in Heritage Pines.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Pineland%2C_Florida"
    },
    {
      "id": 5,
      "text": "A tiny post office in Heritage Pines ranks among the smallest in the United States, a quirky landmark for locals.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Pineland%2C_Florida"
    },
    {
      "id": 6,
      "text": "Geographically, Heritage Pines lies at 28.4266° N latitude and –82.6257° W longitude in Pasco County.",
