  "facts": [
    {
      "id": 1,
      "text": "Sag Harbor’s original Native American name was “Wegwaganock,” meaning “village at the foot of the hill,” a name later replaced by settlers’ Turkey Hill.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://sagharborhistoricalmuseum.org/"
    },
    {
      "id": 2,
      "text": "Main Street’s curved shape follows the edge of a swamp that was filled in 1745 to create Turkey Hill.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://sagharborhistoricalmuseum.org/"
    },
    {
      "id": 3,
      "text": "Sag Harbor’s first offshore whaling ships departed in 1760, and by 1771 a 500‑foot Long Wharf had been built.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://sagharborhistoricalmuseum.org/"
    },
    {
      "id": 4,
      "text": "In the Battle of Sag Harbor on May 24, 1777, Patriots seized a British fort, burned the fleet, and captured 90 prisoners without casualties.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://sagharborhistoricalmuseum.org/"
    },
    {
      "id": 5,
      "text": "The oldest synagogue on Long Island, Temple Adas Israel, was founded in Sag Harbor in 1896.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Sag_Harbor%2C_New_York"
    },
    {
      "id": 6,
      "text": "The Sag Harbor Whaling & Historical Museum, now open to the public, preserves the village’s maritime heritage.",
      "sourceSentenceIds": [
