  "facts": [
    {
      "id": 1,
      "text": "Deeded to John Winthrop Jr., Governor of Connecticut Colony, in 1664, Patchogue village began its documented history.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://history.pmlib.org/patchoguemedfordareahistory/patchogue"
    },
    {
      "id": 2,
      "text": "Founded during the French and Indian War in 1756, Patchogue grew from a modest settlement into a thriving community.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://history.pmlib.org/patchoguemedfordareahistory/patchogue"
    },
    {
      "id": 3,
      "text": "Incorporated as a village in 1893, Patchogue formalized its local government and civic identity.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://history.pmlib.org/patchoguemedfordareahistory/patchogue"
    },
    {
      "id": 4,
      "text": "Patchogue has historically been a major shopping and commerce hub of Suffolk County, drawing visitors from across Long Island.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/East_Patchogue%2C_New_York"
    },
    {
      "id": 5,
      "text": "The Smith‑Rourke House and Swan River Schoolhouse are listed on the National Register of Historic Places, preserving 19th‑century architecture.",
