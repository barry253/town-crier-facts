  "facts": [
    {
      "id": 1,
      "text": "Batavia was named by Paul Busti after the Batavian Republic, honoring Dutch investors of the Holland Land Company.",
      "sourceSentenceIds": [
        1,
        30
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Batavia%2C_New_York"
    },
    {
      "id": 2,
      "text": "Joseph Ellicott founded the village in 1802, surveying the area the year before and laying out the city’s grid.",
      "sourceSentenceIds": [
        2,
        4
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Batavia%2C_New_York"
    },
    {
      "id": 3,
      "text": "The Holland Land Office Museum, now a National Historic Landmark, sits in the former office where land deals that opened Western New York were signed.",
      "sourceSentenceIds": [
        3,
        6
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Batavia%2C_New_York"
    },
    {
      "id": 4,
      "text": "Batavia became Genesee County’s seat in 1802, making it the administrative heart of the region from the very start.",
      "sourceSentenceIds": [
        7,
        12
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Batavia%2C_New_York"
    },
    {
      "id": 5,
      "text": "The city hosts Batavia Downs, a half‑mile harness racing track that operates from July through December, a unique sporting venue in the area.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://discoverupstateny.com/batavia/"
    },
    {
      "id": 6,
      "text": "Ellicott Street and Ellicott Avenue honor the surveyor who founded the city, and a large monument stands in the town center.",
      "sourceSentenceIds": [
        8
