    },
    {
      "id": 2,
      "text": "The Albany Northern Railroad opened a stop called \"Menand's Crossing\" in 1856, later renamed Menand's Station when the line merged with the Delaware and Hudson.",
      "sourceSentenceIds": [
        2,
        22
      ],
      "sourceLabels": [
