  "facts": [
    {
      "id": 1,
      "text": "Hurlburt Field was named by Brigadier General Grandison Gardner for First Lieutenant Donald Wilson Hurlburt, who died in a 1943 aircraft crash at Eglin.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Hurlburt_Field"
    },
    {
      "id": 2,
      "text": "Before 1944, the airfield was called Eglin Auxiliary Field No. 9.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.hurlburt.af.mil/About-Us/Fact-Sheets/Fact-Sheets/Article/204584/hurlburt-field-history/"
    },
    {
      "id": 3,
      "text": "Today, Hurlburt Field hosts the Air Force Special Operations Command and its 1st Special Operations Wing.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.hurlburt.af.mil/About-Us/Fact-Sheets/Fact-Sheets/Article/204584/hurlburt-field-history/"
    },
    {
      "id": 4,
      "text": "During World War II, Santa Rosa Island’s Site A‑15, just south of Hurlburt Field, launched Republic‑Ford JB‑2 Loons, early U.S. drone prototypes.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Hurlburt_Field"
    },
    {
      "id": 5,
      "text": "Since the 1970s, historians have worked to preserve the legacy of Air Commando operations that began at Hurlburt Field.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Hurlburt_Field"
    },
    {
      "id": 6,
      "text": "The former launch site on Santa Rosa Island is now listed on the National Register of Historic Places.",
