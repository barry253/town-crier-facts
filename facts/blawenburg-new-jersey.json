  "facts": [
    {
      "id": 1,
      "text": "Blawenburg got its name from John Blaw, who bought 400 acres before 1742, and a mill on Great Road gave the town its nickname.",
      "sourceSentenceIds": [
        12,
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Blawenburg%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "The Blawenburg Historic District covers 336 acres along CR 518, CR 601, and Mountain View Road, showcasing 19th‑century Greek Revival and Italianate homes.",
      "sourceSentenceIds": [
        22,
        29
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Blawenburg%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "The village’s first church, the Blawenburg Reformed Church, was founded in 1832 after years of petitioning for a place of worship.",
      "sourceSentenceIds": [
        15,
        7,
        8
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Blawenburg%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "The James Van Zandt Mansion, built 1860‑65, is a Victorian Italian Villa that once housed a prominent local family.",
      "sourceSentenceIds": [
        16,
        27
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Blawenburg%2C_New_Jersey"
    },
    {
      "id": 5,
      "text": "The Blawenburg Tavern, a Federal‑style building on the Georgetown‑Franklin Turnpike, served travelers since the early 1800s.",
      "sourceSentenceIds": [
