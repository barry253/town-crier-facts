  "facts": [
    {
      "id": 1,
      "text": "Henderson’s Historical Society museum campus features three historic buildings: a former Universalist Church, an 1820s Log Cabin, and the Peters‑Stevens Boat Annex.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://hendersonnyhistoricalsociety.com/"
    },
    {
      "id": 2,
      "text": "The fully furnished 1820s Log Cabin offers a window into early settler life in Henderson.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.townofhendersonny.org/historical-society.html"
    },
    {
      "id": 3,
      "text": "The Boat Annex showcases historic boats and nautical artifacts, underscoring Henderson’s deep Lake Ontario maritime heritage.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.townofhendersonny.org/historical-society.html"
    },
    {
      "id": 4,
      "text": "Henderson lies in the valley of Stony Creek, a southwestward‑flowing tributary of Lake Ontario.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Henderson_(CDP)%2C_New_York"
    },
    {
      "id": 5,
      "text": "New York State Route 178 cuts through Henderson, linking it west to Route 3 and southeast to Adams.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Henderson_(CDP)%2C_New_York"
    },
    {
      "id": 6,
      "text": "The museum opens free from mid‑May to mid‑October, with a small donation appreciated to keep it running.",
