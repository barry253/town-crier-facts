  "facts": [
    {
      "id": 1,
      "text": "Six Mile Run Historic District stretches roughly from Grouser Road to the Millstone River, encompassing 149 buildings, 5 sites, and 44 structures.",
      "sourceSentenceIds": [
        18,
        20
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Six_Mile_Run%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "The district’s centerpiece, the Van Liew‑Suydam House, dates back to the 18th century and was expanded in 1875.",
      "sourceSentenceIds": [
        21,
        24
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Six_Mile_Run%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "A 1710 Dutch Reformed congregation founded the town’s first church, which was rebuilt in 1766 and again in 1817 before a fire in 1879.",
      "sourceSentenceIds": [
        27,
        28,
        29
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Six_Mile_Run%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "The 1907 Frelinghuysen Memorial Chapel and the 1958 Fellowship Hall mark the district’s continued religious heritage.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Six_Mile_Run%2C_New_Jersey"
    },
    {
      "id": 5,
      "text": "Other homes in the area showcase Federal and Greek Revival styles, reflecting the region’s architectural diversity.",
