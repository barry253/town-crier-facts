  "facts": [
    {
      "id": 1,
      "text": "Barnum Island was originally called Hog Island because wild pigs were introduced by early European settlers.",
      "sourceSentenceIds": [
        4,
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Barnum_Island%2C_New_York"
    },
    {
      "id": 2,
      "text": "The island was renamed Barnum Island in 1874 after Sarah Ann Baldwin Barnum bought it and sold to Queens County for $13,000.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/barnum_island_new_york"
    },
    {
      "id": 3,
      "text": "In the 19th century, Barnum Island served as a county poor farm and smallpox hospital before becoming a residential community.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/barnum_island_new_york"
    },
    {
      "id": 4,
      "text": "Edgeworth Smith, a New York City realtor, envisioned Barnum Island as a resort destination and acquired it in 1921, renaming it Island Park.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/barnum_island_new_york"
    },
    {
      "id": 5,
      "text": "The Lenape Rockaway band originally used the marshy island for fishing, clamming, and making wampum from shellfish shells.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/barnum_island_new_york"
    },
    {
      "id": 6,
      "text": "Barnum Island lies between Long Island and Long Beach, separated from the Village of Island Park by the Long Beach Branch rail line.",
      "sourceSentenceIds": [
