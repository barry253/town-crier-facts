    {
      "id": 2,
      "text": "Colgate University was founded in Hammond in 1819, making the village a historic college town.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Hamilton_(village)%2C_New_York"
    },
    {
      "id": 3,
      "text": "A 2008 Utica television travel show aired a two‑part tour showcasing Hammond’s sights and activities.",
      "sourceSentenceIds": [
        3
