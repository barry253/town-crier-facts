    {
      "id": 2,
      "text": "The town’s original spelling was “Ellisburgh,” a detail still remembered by locals.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ellisburg%2C_New_York"
    },
    {
      "id": 3,
      "text": "Rural Hill, northwest on County Road 79, was once called “Buck Hill” before the Hill brothers settled there.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ellisburg%2C_New_York"
    },
    {
      "id": 4,
      "text": "Wardwell Settlement, at County Roads 85 and 91, honors Colonel Wardwell, an early landowner.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
