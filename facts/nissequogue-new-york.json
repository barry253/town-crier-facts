  "facts": [
    {
      "id": 1,
      "text": "Nissequogue incorporated as a village in 1925, carving out its own local government within the Town of Smithtown.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Nissequogue%2C_New_York"
    },
    {
      "id": 2,
      "text": "The village’s roots reach back to 1665, when Richard Smith founded Smithtown on land granted by Lion Gardiner and the Montaukett sachem Wyandanch.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.newsday.com/long-island/towns/nissequogue-centennial-100-years-celebration-vlbnclfu"
    },
    {
      "id": 3,
      "text": "Although the village was officially founded in 1926, it sits on the original colonial settlement that began the history of Smithtown.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.newsday.com/long-island/towns/nissequogue-centennial-100-years-celebration-vlbnclfu"
    },
    {
      "id": 4,
      "text": "In 2017, Nissequogue Village Hall was dedicated to former mayor Donahue, honoring his long service to the community.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Nissequogue%2C_New_York"
    },
    {
      "id": 5,
      "text": "Nissequogue preserves its natural Long Island landscape with a two‑acre minimum on subdivisions and a ban on industrial real estate.",
      "sourceSentenceIds": [
        21
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Nissequogue%2C_New_York"
    },
    {
      "id": 6,
      "text": "The Nissequogue River borders the village to the west, while Long Island Sound lies to the north, framing its scenic shoreline.",
