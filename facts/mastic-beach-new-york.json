  "facts": [
    {
      "id": 1,
      "text": "Mastic Beach stretches out on a peninsula that extends into Moriches Bay, placing it within the Long Island Sound and Atlantic Ocean Watershed.",
      "sourceSentenceIds": [
        16,
        17
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
