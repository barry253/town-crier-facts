    },
    {
      "id": 2,
      "text": "The area’s name honors the Unkechaug tribe of Algonquian‑speaking Native Americans who hunted and fished along the peninsula.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Mastic_Beach,_New_York"
    },
    {
      "id": 3,
      "text": "William Floyd Estate, a 613‑acre National Park Service site, houses the 25‑room Old Mastic House built in 1724, once home to a Declaration signer.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Mastic_Beach,_New_York"
    },
    {
      "id": 4,
      "text": "In 2010 residents voted to incorporate Mastic Beach as a village, believing stricter code enforcement would beautify the community.",
      "sourceSentenceIds": [
        6,
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Mastic_Beach%2C_New_York"
    },
    {
      "id": 5,
      "text": "The village dissolved in 2018 after political and fiscal struggles, becoming the third‑shortest‑lived village in New York history.",
      "sourceSentenceIds": [
        12,
