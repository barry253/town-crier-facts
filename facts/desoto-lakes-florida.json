  "facts": [
    {
      "id": 1,
      "text": "Desoto Lakes grew around a saw mill built in 1905, then expanded when a railroad reached the area in 1911.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.livingplaces.com/FL/Sarasota_County/Desoto_Lakes.html"
    },
    {
      "id": 2,
      "text": "Early settlers in the region focused on stock raising, sugar cane, and truck crops before citrus took hold.",
      "sourceSentenceIds": [
        25
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.livingplaces.com/FL/Sarasota_County/Desoto_Lakes.html"
    },
    {
      "id": 3,
      "text": "Citrus production was largely ignored until the 1880s, when Frank Higel launched a pioneering canned citrus operation.",
      "sourceSentenceIds": [
        26,
        27
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.livingplaces.com/FL/Sarasota_County/Desoto_Lakes.html"
    },
    {
      "id": 4,
      "text": "Higel’s enterprise produced jams, pickled orange peel, lemon juice, orange wine, and a famous “Pure Florida Orange Syrup.”",
      "sourceSentenceIds": [
        27
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.livingplaces.com/FL/Sarasota_County/Desoto_Lakes.html"
    },
    {
      "id": 5,
      "text": "The community remained a modest fishing and farming center through 1924, despite the Florida Land Boom of 1925.",
