  "facts": [
    {
      "id": 1,
      "text": "Arkport was founded in 1797 by Christopher Hurlbut as a thriving agricultural hub.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Arkport%2C_New_York"
    },
    {
      "id": 2,
      "text": "The village’s name comes from the arks that ferried crops down the Canisteo River until the Erie Canal opened in 1825.",
      "sourceSentenceIds": [
        15,
        16,
        17,
        18
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Arkport%2C_New_York"
    },
    {
      "id": 3,
      "text": "Arkport became a railroad stop in 1851, serving the Buffalo division of the Erie and the Central New York & Western Railroad.",
      "sourceSentenceIds": [
        6,
        9
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://canisteovalleyhistoricalsociety.org/arkport-history"
    },
    {
      "id": 4,
      "text": "Historic factories in Arkport included a large planing mill, a feed and grist mill, and the Stephens wagon factory.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://canisteovalleyhistoricalsociety.org/arkport-history"
    },
    {
      "id": 5,
      "text": "Arkport sits on the eastern bank of the Canisteo River at 42°23′36″N 77°41′46″W.",
      "sourceSentenceIds": [
        21,
        20
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Arkport%2C_New_York"
    },
    {
      "id": 6,
      "text": "New York State Route 36 cuts through Arkport, running north to south across the village.",
