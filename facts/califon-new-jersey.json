  "facts": [
    {
      "id": 1,
      "text": "Califon's name traces back to Jacob Neighbor’s enthusiasm for the 1849 Gold Rush, later shortened because train‑station signs couldn’t fit the longer word.",
      "sourceSentenceIds": [
        26,
        28,
        22
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Califon%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "A historic iron bridge spans the South Branch Raritan River, literally dividing Califon into two halves and serving as a local landmark.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Califon%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "The 1875 High Bridge Branch station now houses the Califon Historical Society museum, preserving the borough’s railroad heritage.",
      "sourceSentenceIds": [
        3,
        4,
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Califon%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "Philip Van Doren Stern based his 1943 story “The Greatest Gift” on Califon, later inspiring the film It’s a Wonderful Life’s fictional Bedford Falls.",
      "sourceSentenceIds": [
        21
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.nps.gov/places/califon-historic-district.htm"
    },
    {
      "id": 5,
      "text": "Califon became an official borough on April 2, 1918, carved out of portions of Lebanon and Tewksbury Townships.",
