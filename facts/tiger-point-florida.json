  "facts": [
    {
      "id": 1,
      "text": "Tiger Point’s name echoes the Yeehaw station on the Florida East Coast Railway, which ran through the area from 1915 to 1947.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Yeehaw_Junction%2C_Florida"
    },
    {
      "id": 2,
      "text": "Local lore says the community once called itself “Jackass Junction,” a nickname that appeared in early newspaper clippings.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Yeehaw_Junction%2C_Florida"
    },
    {
      "id": 3,
      "text": "The town sits within the Timucuan Ecological and Historic Preserve, safeguarding nearby salt marshes and wildlife.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.trawellino.com/destinations/united-states/florida_tiger-point"
    },
    {
      "id": 4,
      "text": "Tiger Point lies at the crossroads of US 441/SR 15, SR 60, and Florida’s Turnpike, about 30 miles north of Lake Okeechobee.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Yeehaw_Junction%2C_Florida"
    },
    {
      "id": 5,
      "text": "In the early 1930s, ranchers rode burros to the Desert Inn—then a local brothel—at the four‑corner site that would become Tiger Point.",
