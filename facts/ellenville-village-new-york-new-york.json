  "facts": [
    {
      "id": 1,
      "text": "Ellenville got its name from Alpheus Fairchild, who bought most of the village in 1798 and built its first house.",
      "sourceSentenceIds": [
        6,
        28
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ellenville%2C_New_York"
    },
    {
      "id": 2,
      "text": "Christ Lutheran Church, once the German Evangelical Lutheran Church, sits in downtown Ellenville and dates back to the village’s early days.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://ellenvillewawarsinghistory.com/category/public-places"
    },
    {
      "id": 3,
      "text": "The Hunt Memorial Building, erected in 1917, now graces Ellenville’s Main Street and is listed on the National Register of Historic Places.",
      "sourceSentenceIds": [
        4,
        17,
        21
      ],
      "sourceLabels": [
        "Web source 1",
        "Wikipedia"
      ],
      "source": "https://ellenvillewawarsinghistory.com/category/public-places"
    },
    {
      "id": 4,
      "text": "Greenfield Park Museum, once a one‑room schoolhouse, opened as a museum in 1965 and preserves local history.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://ellenvillewawarsinghistory.com/category/public-places"
    },
    {
      "id": 5,
      "text": "Modernizing Old Mine Road into US 209 kept vacationers flowing through Ellenville even after passenger trains disappeared in the 1940s.",
