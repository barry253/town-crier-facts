      ],
      "source": "https://www.longandisland.com/blog/discover-carle-place-ny-your-ultimate-guide-to-history-schools-real-estate-and-more"
    },
    {
      "id": 3,
      "text": "The Long Island Rail Road's Carle Place station, opened in 1869, still connects residents to Manhattan.",
      "sourceSentenceIds": [
        12
