  "facts": [
    {
      "id": 1,
      "text": "Holland Patent was founded in 1797 by Gerrit Boon, agent of Holland Land Company, to develop and sell land.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Holland_Patent%2C_New_York"
    },
    {
      "id": 2,
      "text": "The village’s public square, established by deed June 30 1798, has been a symbol of Holland Patent for two centuries.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.hollandpatentny.gov/history"
    },
    {
      "id": 3,
      "text": "The Holland Patent Library opened July 6 1916, originally housed in Holland Hall, and now boasts over 12,000 holdings.",
      "sourceSentenceIds": [
        10,
        11,
        16
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://hollandpatentlibrary.org/local-history/"
    },
    {
      "id": 4,
      "text": "The Holland Patent Railroad Station, a historic landmark, was added to the National Register in 2000.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Holland_Patent%2C_New_York"
    },
    {
      "id": 5,
      "text": "The Holland Patent Stone Churches Historic District, featuring five churches, was listed on the National Register in 1991.",
      "sourceSentenceIds": [
