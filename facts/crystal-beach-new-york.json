  "facts": [
    {
      "id": 1,
      "text": "Crystal Beach sits on Canandaigua Lake’s eastern shore, once a Seneca Indian camp before European settlement.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/crystal_beach_new_york"
    },
    {
      "id": 2,
      "text": "Historic summer cottages line Crystal Beach, preserving a lakeside tradition that dates back to the early 20th century.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/crystal_beach_new_york"
    },
    {
      "id": 3,
      "text": "In 1929 Paul Ritchie’s Finger Lakes Company parceled a former grape farm into 965 30‑by‑80‑foot lots, complete with roads and lakefront rights‑of‑way.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/crystal_beach_new_york"
    },
    {
      "id": 4,
      "text": "Canandaigua Lake’s water quality is impaired by algal blooms, yet it still supports diverse aquatic life.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/crystal_beach_new_york"
    },
    {
      "id": 5,
      "text": "The lake moderates Crystal Beach’s climate, creating microclimates that keep temperatures milder than surrounding areas.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/crystal_beach_new_york"
    },
    {
      "id": 6,
      "text": "Seasonal weather shifts cause Canandaigua Lake levels to rise and fall, with average elevation around 688 feet and winter lows near 687 feet.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/crystal_beach_new_york"
