  "facts": [
    {
      "id": 1,
      "text": "Paterson, New Jersey, earned its nickname \"America's Silk City\" after becoming the cradle of the Industrial Revolution in America.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Paterson%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "In 1791, Alexander Hamilton and others founded the Society for Establishing Useful Manufactures, laying the groundwork for Paterson’s planned industrial boom.",
      "sourceSentenceIds": [
        18,
        27
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://newjersey.wiki/a/Paterson_(Passaic_County_Seat)"
    },
    {
      "id": 3,
      "text": "Paterson’s historic Paterson silk strike of 1913, led by Luigi Galleani and Carlo Tresca, pushed for an eight‑hour day and better conditions.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Paterson%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "The Paterson Museum, opened in 1925 in the Great Falls Historic District, preserves the city’s industrial heritage.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Paterson%2C_New_Jersey"
    },
    {
      "id": 5,
      "text": "Joe Pesci and Frankie Valli, both born and raised in Paterson, are among the city’s most famous cultural exports.",
