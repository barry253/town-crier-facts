    },
    {
      "id": 2,
      "text": "The town’s Congregational Church began as the Union Church of Christ before becoming the Tangerine Community Church in the 1940s.",
      "sourceSentenceIds": [
        2,
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Tangerine%2C_Florida"
    },
    {
      "id": 3,
      "text": "Local women founded the Tangerine Improvement Society, a community group that helped shape the town’s civic life.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Tangerine%2C_Florida"
    },
    {
      "id": 4,
      "text": "Tangerine’s mild winters and sunny skies once made it a prime spot for early citrus groves, fueling the area’s agricultural roots.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Tangerine,_Florida"
    },
    {
      "id": 5,
      "text": "The town’s name changed from Olaville to Tangerine after a fruit tree grew beside a resident’s doorstep, inspiring the new identity.",
      "sourceSentenceIds": [
