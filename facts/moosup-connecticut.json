  "facts": [
    {
      "id": 1,
      "text": "Moosup takes its name from Sachem Maussup, a Narragansett leader who lived there in the early 1600s.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Moosup%2C_Connecticut"
    },
    {
      "id": 2,
      "text": "The town was officially established in 1689, just over a decade after Maussup’s death at the hands of Mohawks.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Moosup%2C_Connecticut"
    },
    {
      "id": 3,
      "text": "Moosup is the childhood home of Major League Baseball star Walt Dropo, who grew up playing sandlot ball with his brothers.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Moosup%2C_Connecticut"
    },
    {
      "id": 4,
      "text": "Over his career, Dropo played for five teams: the Red Sox, Tigers, White Sox, Redlegs, and Orioles.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Moosup%2C_Connecticut"
    },
    {
      "id": 5,
      "text": "In 1895, Moosup boasted both a post office and railroad service, linking it to regional trade.",
