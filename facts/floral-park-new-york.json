  "facts": [
    {
      "id": 1,
      "text": "John Lewis Childs founded Floral Park in 1874, turning East Hinsdale into a horticultural hub.",
      "sourceSentenceIds": [
        21,
        18,
        6
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://floralparkny.gov/village-history/"
    },
    {
      "id": 2,
      "text": "The village’s name changed from East Hinsdale to Floral Park thanks to Childs’ flower‑named streets, reflecting the blooming industry.",
      "sourceSentenceIds": [
        9,
        16
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Floral_Park%2C_New_York"
    },
    {
      "id": 3,
      "text": "The Floral Park Hotel opened in 1874, becoming the first major building that sparked community growth.",
      "sourceSentenceIds": [
        6,
        1
      ],
      "sourceLabels": [
        "Web source 2",
        "Web source 2"
      ],
      "source": "https://www.lipages.com/towns-villages-hamlets/nassau-county/town-of-hempstead/about-floral-park-new-york/the-history-of-floral-park-new-york/"
    },
    {
      "id": 4,
      "text": "In 1908, residents incorporated Floral Park as a village to better manage growth and infrastructure.",
      "sourceSentenceIds": [
        25
