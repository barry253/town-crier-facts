  "facts": [
    {
      "id": 1,
      "text": "Fort Plain earned its name from a Revolutionary War fort built at the junction of the Mohawk River and Otsquago Creek.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Fort_Plain%2C_New_York"
    },
    {
      "id": 2,
      "text": "During the war a blockhouse garrisoned the fort, and women disguised as men defended it against Indian attacks.",
      "sourceSentenceIds": [
        23,
        24
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Fort_Plain%2C_New_York"
    },
    {
      "id": 3,
      "text": "The village grew around the confluence of Otsquago Creek and the Mohawk River, where the fort once stood.",
      "sourceSentenceIds": [
        5,
        22
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Fort_Plain%2C_New_York"
    },
    {
      "id": 4,
      "text": "Fort Plain incorporated in 1832, then surged economically when the Erie Canal opened nearby.",
      "sourceSentenceIds": [
        25,
        26
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Fort_Plain%2C_New_York"
    },
    {
      "id": 5,
      "text": "The Fort Plain Museum began archaeological digs in the 1980s, uncovering 18th‑century artifacts from the fort.",
