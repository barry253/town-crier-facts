  "facts": [
    {
      "id": 1,
      "text": "Port Ewen was founded in 1851 by the Pennsylvania Coal Company as a coal depot.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://exhibits.archives.marist.edu/s/marist-heritage-project/page/Esopus-Community-Early-History-Geography"
    },
    {
      "id": 2,
      "text": "The town sits where the Rondout Creek meets the Hudson River, bordered by Connelly, Sleightsburgh, Ulster Park, and New Salem.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Port_Ewen%2C_New_York"
    },
    {
      "id": 3,
      "text": "In 1921 the Kingston–Port Ewen Suspension Bridge opened, replacing the chain ferry that once crossed the Rondout.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Port_Ewen%2C_New_York"
    },
    {
      "id": 4,
      "text": "The West Shore Railroad once served Port Ewen, shipping high explosives from the Nitro Powder Company in Kingston.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Port_Ewen%2C_New_York"
    },
    {
      "id": 5,
      "text": "French Huguenots settled the area in 1677, naming it after the Rhenish Palatinate.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://exhibits.archives.marist.edu/s/marist-heritage-project/page/Esopus-Community-Early-History-Geography"
    },
    {
