  "facts": [
    {
      "id": 1,
      "text": "Gotha was founded in 1885 by German immigrant H.A. Hempel, who named the town after his hometown in Germany.",
      "sourceSentenceIds": [
        2,
        5,
        8,
        9,
        13
      ],
      "sourceLabels": [
        "Web source 2",
        "Wikipedia"
      ],
      "source": "https://www.orangecountyfl.net/BoardofCommissioners/District1Commissioner/District1Communities/Gotha.aspx"
    },
    {
      "id": 2,
      "text": "Hempel Avenue, the town’s main street, honors its founder and still serves as the commercial hub of Gotha.",
      "sourceSentenceIds": [
        6,
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Gotha%2C_Florida"
    },
    {
      "id": 3,
      "text": "A post office opened in Gotha in 1883, making it one of the earliest postal sites in Orange County.",
      "sourceSentenceIds": [
        27,
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Gotha%2C_Florida"
    },
    {
      "id": 4,
      "text": "Nehrling Gardens, created by botanist Henry Nehrling, sits on the historic Palm Cottage property and is listed on the National Register of Historic Places.",
      "sourceSentenceIds": [
        16,
        17,
        21
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.mygotha.org/"
    },
    {
      "id": 5,
      "text": "The 1916 One‑Room Schoolhouse, now the Gotha Community Center, was originally a one‑room schoolhouse built by the early settlers.",
      "sourceSentenceIds": [
        19,
        14
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.mygotha.org/"
    },
    {
      "id": 6,
      "text": "The Yellow Dog Eats Café, housed in the historic Fishers Country Store, offers a unique dining experience that reflects Gotha’s rural charm.",
