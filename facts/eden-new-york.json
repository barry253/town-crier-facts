  "facts": [
    {
      "id": 1,
      "text": "Founded in 1970, the Eden Historical Society preserves and promotes the town’s history.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://museumsdatabase.com/museums/view/22212"
    },
    {
      "id": 2,
      "text": "The Holland Land Company’s 1796 purchase sparked settlement; first settler Deacon Samuel Tubbs arrived in 1808.",
      "sourceSentenceIds": [
        7,
        29
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/eden_cdp_new_york"
    },
    {
      "id": 3,
      "text": "By the 1830s, log cabins gave way to frame houses and mills, creating a barter economy amid cash scarcity.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/eden_cdp_new_york"
    },
    {
      "id": 4,
      "text": "The railroad reached Eden in 1873, and passenger service began in 1875, linking the town to Buffalo and Jamestown.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/eden_cdp_new_york"
    },
    {
      "id": 5,
      "text": "During World War I, 153 men from Eden served, with seven not returning, reflecting the town’s sacrifices.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/eden_cdp_new_york"
    },
    {
      "id": 6,
      "text": "The original warehouse, once a Cracker Barrel, now houses the Eden Historical Society museum, showcasing artifacts and documents.",
      "sourceSentenceIds": [
        11,
        12
      ],
      "sourceLabels": [
        "Web source 2"
