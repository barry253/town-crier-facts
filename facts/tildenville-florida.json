  "facts": [
    {
      "id": 1,
      "text": "Tildenville, once called South Apopka, adopted its current name in the 1870s as the area grew.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.orangeobserver.com/news/2016/aug/24/community-not-forgotten-tildenville/"
    },
    {
      "id": 2,
      "text": "In 1876, New York farmer Luther Fuller Tilden bought 561 acres southwest of Winter Garden that would become Tildenville.",
      "sourceSentenceIds": [
        2,
        27
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://www.ocfl.net/BoardofCommissioners/District1Commissioner/District1Communities/Tildenville.aspx"
    },
    {
      "id": 3,
      "text": "Tilden built the first citrus packinghouses in the area, setting the stage for Orange County’s fruit industry.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.ocfl.net/BoardofCommissioners/District1Commissioner/District1Communities/Tildenville.aspx"
    },
    {
      "id": 4,
      "text": "Brick Road, a historic half‑mile stretch from Plant Street to Tildenville School Road, will soon receive a county historic marker.",
      "sourceSentenceIds": [
        8,
        9
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.orangeobserver.com/news/2016/aug/24/community-not-forgotten-tildenville/"
    },
    {
      "id": 5,
      "text": "Today, Tildenville Elementary School and Tildenville Marketplace lie within Winter Garden’s city limits, preserving the community’s legacy.",
      "sourceSentenceIds": [
        4
