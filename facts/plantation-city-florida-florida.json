  "facts": [
    {
      "id": 1,
      "text": "Frederick Peters moved his family to South Florida in 1931 to escape harsh Midwest winters, sparking the founding of Plantation.",
      "sourceSentenceIds": [
        29
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.plantation.org/residents/history"
    },
    {
      "id": 2,
      "text": "The city’s first school, Berenice Todd Peters Elementary, was dedicated in 1945, honoring the founder’s wife.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Plantation%2C_Florida"
    },
    {
      "id": 3,
      "text": "In 1962, Edwin Deicke donated $100,000 to expand the Hoffman Building, later renamed Deicke Auditorium in 1973.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Plantation%2C_Florida"
    },
    {
      "id": 4,
      "text": "That same year, Plantation’s Chamber of Commerce was founded and Doctors General Hospital opened, marking a civic boom.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Plantation%2C_Florida"
    },
    {
      "id": 5,
      "text": "The Plantation Historical Society was founded in 1962 by Genevieve Veltri and others, preserving the town’s early heritage.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Plantation%2C_Florida"
    },
    {
