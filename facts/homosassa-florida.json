  "facts": [
    {
      "id": 1,
      "text": "The name Homosassa comes from Seminole words meaning “where pepper grows” or “river of fishes.”",
      "sourceSentenceIds": [
        12,
        14
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Homosassa,_Florida"
    },
    {
      "id": 2,
      "text": "In 1851, David Levy Yulee planted a 5,000‑acre sugar farm on the Homosassa River, operating a steam mill until 1864.",
      "sourceSentenceIds": [
        20,
        24
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Homosassa%2C_Florida"
    },
    {
      "id": 3,
      "text": "The 1887 railroad arrival shifted Homosassa’s economy toward fishing and tourism, a trend that grew after the line’s 1941 retirement.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Homosassa,_Florida"
    },
    {
      "id": 4,
      "text": "Water lines reached Homosassa in 1957, followed by a fire station, library, elementary school, and post office in the years that followed.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.homosassaflorida.com/location/history-facts"
    },
    {
      "id": 5,
      "text": "The Homosassa Inn, now a private residence owned by the MacRae family, remains a historic landmark on the town’s waterfront.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.homosassaflorida.com/location/history-facts"
    },
    {
      "id": 6,
      "text": "Homosassa Springs State Park features a “fish bowl” underwater viewing platform where visitors can watch manatees glide through the spring.",
