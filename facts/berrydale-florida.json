  "facts": [
    {
      "id": 1,
      "text": "On July 16, 1967, a riot erupted at the State Prison Road Camp 12 barracks near Berrydale, sparking a fire that would change Florida’s prison system.",
      "sourceSentenceIds": [
        25,
        26,
        27
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.usdeadlyevents.com/1967-july-16-riot-and-fire-state-prison-road-camp-12-barracks-jay-fl-38/"
    },
    {
      "id": 2,
      "text": "The fire consumed a 40‑by‑90‑foot World War II barrack that had been repurposed as a stockade, highlighting the building’s dangerous design.",
      "sourceSentenceIds": [
        18,
        19
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.usdeadlyevents.com/1967-july-16-riot-and-fire-state-prison-road-camp-12-barracks-jay-fl-38/"
    },
    {
      "id": 3,
      "text": "Guard Lovett, who had a shotgun and controlled inmates from a chain‑link fence, fled the scene after the riot began around 10 p.m.",
      "sourceSentenceIds": [
        22,
        27
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.usdeadlyevents.com/1967-july-16-riot-and-fire-state-prison-road-camp-12-barracks-jay-fl-38/"
    },
    {
      "id": 4,
      "text": "Inmates smashed fluorescent lights and hurled a television set to the floor before the blaze broke out.",
      "sourceSentenceIds": [
        26,
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.usdeadlyevents.com/1967-july-16-riot-and-fire-state-prison-road-camp-12-barracks-jay-fl-38/"
    },
    {
      "id": 5,
      "text": "The blaze left only one wall and the steel cage standing, where the guard had been stationed during the chaos.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.usdeadlyevents.com/1967-july-16-riot-and-fire-state-prison-road-camp-12-barracks-jay-fl-38/"
    },
    {
      "id": 6,
      "text": "The incident at Berrydale’s camp was a catalyst for ending Florida’s chain‑gang system, prompting the state to phase out such stockades.",
      "sourceSentenceIds": [
        18,
        20
      ],
      "sourceLabels": [
        "Web source 2"
      ],
