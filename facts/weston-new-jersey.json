    },
    {
      "id": 2,
      "text": "The Camden County Railroad arrived in 1891, sparking further growth in Blackwood.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Blackwood%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "Blackwood’s 42‑acre Historic District, centered on the Black Horse Pike, was listed on the National Register in 1989 for its commercial heritage.",
      "sourceSentenceIds": [
        7,
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Blackwood%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "Blackwood Lake operated as a summer resort from 1891 until 1932, drawing visitors to its waterfront.",
      "sourceSentenceIds": [
        13
