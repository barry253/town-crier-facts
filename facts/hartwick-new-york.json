  "facts": [
    {
      "id": 1,
      "text": "Hartwick was named for Lutheran minister John Christopher Hartwick, an early landowner who bought the area from the Mohawk in 1763.",
      "sourceSentenceIds": [
        1,
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.hartwickny.gov/about/history/"
    },
    {
      "id": 2,
      "text": "The town’s founding land, the Hartwick Patent, was granted in 1761 and later sold to the Mohawk Indians in 1763.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.hartwickny.gov/about/history/"
    },
    {
      "id": 3,
      "text": "In 1802, Hartwick split from Otsego, becoming its own town amid shifting county lines.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.hartwickny.gov/about/history/"
    },
    {
      "id": 4,
      "text": "Otego Creek winds southward through Hartwick, carving the hamlet’s landscape.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Hartwick_(CDP)%2C_New_York"
    },
    {
      "id": 5,
      "text": "Hartwick Seminary, opened in 1812, holds the title of the oldest Lutheran seminary in the United States.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.hartwickny.gov/about/history/"
    },
    {
      "id": 6,
      "text": "Local entrepreneurs run the Cooperstown Bat Company Factory, a niche business that reflects the town’s rural charm.",
      "sourceSentenceIds": [
