    },
    {
      "id": 2,
      "text": "Brookville Church, founded by 17th‑century Dutch settlers, dates back to the village’s earliest days.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.villageofbrookville.gov/history"
    },
    {
      "id": 3,
      "text": "The Brookville Reformed Church, still on its original site, is one of the nation’s oldest continuous congregations.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.villageofbrookville.gov/history"
    },
    {
      "id": 4,
      "text": "During the War of 1812, Civil War, and later conflicts, young residents of Old Brookville served overseas.",
      "sourceSentenceIds": [
