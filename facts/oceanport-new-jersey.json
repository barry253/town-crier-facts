  "facts": [
    {
      "id": 1,
      "text": "Sarah Reape, a Quaker landowner, held all of Oceanport before selling parcels that formed the town’s western half.",
      "sourceSentenceIds": [
        27,
        30
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.oceanportboro.com/visitor/history"
    },
    {
      "id": 2,
      "text": "Reape’s holdings made her the largest landowner in today’s Monmouth County, encompassing the entire Oceanport area.",
      "sourceSentenceIds": [
        28,
        29
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.oceanportboro.com/visitor/history"
    },
    {
      "id": 3,
      "text": "In the 19th century, Oceanport competed with other river docks and two railroad lines built in 1860 and 1875.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.oceanportboro.com/visitor/history"
    },
    {
      "id": 4,
      "text": "The town’s early growth was driven by its strategic location on the Shrewsbury River, where Reape built her home.",
      "sourceSentenceIds": [
        27
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.oceanportboro.com/visitor/history"
    },
    {
      "id": 5,
      "text": "Oceanport’s name reflects its coastal character, with the Shrewsbury River shaping its early maritime economy.",
      "sourceSentenceIds": [
        27
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.oceanportboro.com/visitor/history"
    },
    {
      "id": 6,
      "text": "The borough form of government, common in New Jersey, governs Oceanport, a structure shared by 253 municipalities statewide.",
