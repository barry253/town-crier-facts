    },
    {
      "id": 2,
      "text": "The town sits at 41°20′18″N 73°41′50″W, right in the heart of Westchester County.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Heritage_Hills%2C_New_York"
    },
    {
      "id": 3,
      "text": "Sprawling over 1,100 acres, Heritage Hills stretches across northern Westchester, offering ample green space for its residents.",
      "sourceSentenceIds": [
        19
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.heritagehills.com/"
    },
    {
      "id": 4,
      "text": "The development houses 2,600 condos grouped into 30 clusters, with 53 different floor‑plan models to choose from.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.heritagehills.com/"
    },
    {
      "id": 5,
      "text": "Somers National Golf Club, a private 18‑hole course, anchors the community and features the Grille at Somers Pointe Restaurant.",
      "sourceSentenceIds": [
        20
