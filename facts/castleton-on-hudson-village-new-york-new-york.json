  "facts": [
    {
      "id": 1,
      "text": "Castleton-on-Hudson takes its name from Henry Hudson’s 1609 sighting of a Mahican storehouse that resembled a castle.",
      "sourceSentenceIds": [
        20,
        21,
        22
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Castleton-on-Hudson%2C_New_York"
    },
    {
      "id": 2,
      "text": "When it incorporated in 1827, Castleton-on-Hudson had only about 100 residents living along the Hudson.",
      "sourceSentenceIds": [
        24
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Castleton-on-Hudson%2C_New_York"
    },
    {
      "id": 3,
      "text": "The 1851 arrival of the railroad and the 1856 founding of the Fort Orange Paper Company cemented the village’s industrial era.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Castleton-on-Hudson%2C_New_York"
    },
    {
      "id": 4,
      "text": "Castleton-on-Hudson’s volunteer fire company, established in 1871, remains a historic community pillar.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/castleton_on_hudson_new_york"
    },
    {
      "id": 5,
      "text": "The Village Hall, built in 1868 on a former school site, stands as a testament to 19th‑century civic architecture.",
      "sourceSentenceIds": [
        15
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/castleton_on_hudson_new_york"
    },
    {
      "id": 6,
      "text": "The Hudson River’s fertile banks and its role as a trade corridor shaped Castleton-on-Hudson’s early geography and economy.",
