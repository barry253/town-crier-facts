  "facts": [
    {
      "id": 1,
      "text": "Beattystown takes its name from George Beatty, who built a mill here around 1760.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Beattystown%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "The original Beattystown Mill, constructed in 1750, was restored in 1996 and now serves as a single‑family home.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://preservationnj.org/10-most/beattystown/"
    },
    {
      "id": 3,
      "text": "In 1990, Beattystown earned a spot on both the New Jersey and National Registers of Historic Places.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://preservationnj.org/10-most/beattystown/"
    },
    {
      "id": 4,
      "text": "Founded in 1762, Beattystown is the oldest historic village in Mansfield Township.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://preservationnj.org/10-most/beattystown/"
    },
    {
      "id": 5,
      "text": "The village’s early growth mirrored other New Jersey mill towns that sprang up between 1750 and 1830.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://preservationnj.org/10-most/beattystown/"
    },
    {
      "id": 6,
      "text": "Mansfield Township’s ridges and valleys stretch along the scenic Musconetcong River, framing Beattystown’s historic landscape.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 2"
      ],
