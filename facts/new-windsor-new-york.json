  "facts": [
    {
      "id": 1,
      "text": "New Windsor was laid out in 1749 and officially became a town in 1763.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.britannica.com/place/New-Windsor"
    },
    {
      "id": 2,
      "text": "The New Windsor Cantonment was the Continental Army’s winter camp in 1782‑83 and now stands as a state historic site.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://parks.ny.gov/visit/historic-sites/new-windsor-cantonment-state-historic-site"
    },
    {
      "id": 3,
      "text": "From mid‑April to October, costumed reenactors perform living‑history demonstrations each week at the Cantonment.",
      "sourceSentenceIds": [
        19
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://parks.ny.gov/visit/historic-sites/new-windsor-cantonment-state-historic-site"
    },
    {
      "id": 4,
      "text": "The Cantonment also houses the National Purple Heart Hall of Honor, where the first Purple Heart medal was presented in 1932.",
      "sourceSentenceIds": [
        21,
        22
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://parks.ny.gov/visit/historic-sites/new-windsor-cantonment-state-historic-site"
    },
    {
      "id": 5,
      "text": "Every Memorial Day, Independence Day, and Veterans Day, the Cantonment opens for special commemorations, including a military drill and artillery demonstration.",
      "sourceSentenceIds": [
        24,
        30
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://parks.ny.gov/visit/historic-sites/new-windsor-cantonment-state-historic-site"
    },
    {
      "id": 6,
      "text": "New Windsor’s historic Edmonston House, built in 1755, once served as officers’ quarters during the Revolution and sits beside the Cantonment.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.britannica.com/place/New-Windsor"
    }
  ]
