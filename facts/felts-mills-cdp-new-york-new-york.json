  "facts": [
    {
      "id": 1,
      "text": "Felts Mills was originally called 'Mid Road' because it sits right between Watertown and Carthage.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Felts_Mills%2C_New_York"
    },
    {
      "id": 2,
      "text": "The first settlement in Felts Mills began around 1800 with a gristmill on a natural fall of the Black River.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Felts_Mills%2C_New_York"
    },
    {
      "id": 3,
      "text": "An improved dam was erected in 1821, followed by a stone mill the next year.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Felts_Mills%2C_New_York"
    },
    {
      "id": 4,
      "text": "In 1824 John Felts built large sawmills that gave the community its enduring name.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Felts_Mills%2C_New_York"
    },
    {
      "id": 5,
      "text": "Taggart Paper Company erected a massive paper mill on an island across the Black River in 1889; its ruins still stand.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Felts_Mills%2C_New_York"
    },
    {
      "id": 6,
      "text": "New York State Route 3 cuts through Felts Mills, leading eight miles west to Watertown and ten miles east to Carthage.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
