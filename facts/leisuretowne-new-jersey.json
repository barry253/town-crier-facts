  "facts": [
    {
      "id": 1,
      "text": "LeisureTowne first opened its doors in December 1970, when the first buyers moved into the new retirement community.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.leisuretowne.org/about-us/community-history/"
    },
    {
      "id": 2,
      "text": "Back then, the streets were unpaved and there were no sidewalks or streetlights, giving the place a true pioneer feel.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.leisuretowne.org/about-us/community-history/"
    },
    {
      "id": 3,
      "text": "Mail delivery was nonexistent; residents had to travel to Settlers Hall to pick up their letters.",
      "sourceSentenceIds": [
        29
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.leisuretowne.org/about-us/community-history/"
    },
    {
      "id": 4,
      "text": "Every Friday night, the community gathered at Settlers Hall to dance to records, turning the hall into a lively social hub.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.leisuretowne.org/about-us/community-history/"
    },
    {
      "id": 5,
      "text": "LeisureTowne is a retirement village that requires prospective residents to be at least 55 years old before buying a home.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Leisuretowne%2C_New_Jersey"
    },
    {
      "id": 6,
      "text": "When it first opened, many residents had no close neighbors or houses across the street, creating a sense of isolation that shaped the community’s early character.",
      "sourceSentenceIds": [
