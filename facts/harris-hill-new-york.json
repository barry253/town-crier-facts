  "facts": [
    {
      "id": 1,
      "text": "Harris Hill takes its name from Asa Harris, a Revolutionary War colonel who built a tavern that sheltered Buffalo evacuees during the 1812 burning.",
      "sourceSentenceIds": [
        1,
        3
      ],
      "sourceLabels": [
        "Web source 1",
        "Wikipedia"
      ],
      "source": "https://grokipedia.com/page/harris_hill_new_york"
    },
    {
      "id": 2,
      "text": "The historic Asa Harris Tavern also served as a stop on the Underground Railroad.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Harris_Hill%2C_New_York"
    },
    {
      "id": 3,
      "text": "Harris Hill experiences a humid continental climate, with cold, snowy winters from Lake Erie and mild, humid summers.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/harris_hill_new_york"
    },
    {
      "id": 4,
      "text": "Harris Hill is part of the Buffalo‑Niagara Falls metropolitan area.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Harris_Hill%2C_New_York"
    },
    {
      "id": 5,
      "text": "A large crushed‑stone quarry, opened in 1904 and now owned by Buffalo Crushed Stone, lies just southeast of Harris Hill.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Harris_Hill%2C_New_York"
    },
    {
      "id": 6,
      "text": "In 1858, Protestant settlers of English and German descent founded the United Brethren Church, shaping Harris Hill’s early religious life.",
