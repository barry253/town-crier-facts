      "id": 1,
      "text": "Peconic, on Long Island's North Fork, was first home to the Algonquian‑speaking Corchaug tribe for thousands of years before Europeans arrived.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
