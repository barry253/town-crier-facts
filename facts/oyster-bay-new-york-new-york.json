    },
    {
      "id": 2,
      "text": "The historic Moore Building, also on the National Register, stands as a proud Town of Oyster Bay landmark.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.nps.gov/places/oyster-bay-new-york.htm"
    },
    {
      "id": 3,
      "text": "A Carpenter Gothic church erected in 1873 is another National Register gem and town landmark.",
