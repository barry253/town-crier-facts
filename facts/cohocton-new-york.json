  "facts": [
    {
      "id": 1,
      "text": "Cohocton’s village name echoes either England’s Bath or Lady Laura Pulteney, a 18th‑century landowner.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bath_(village)%2C_New_York"
    },
    {
      "id": 2,
      "text": "Cohocton was founded in 1793, long before it became the county seat of Steuben County.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bath_(village)%2C_New_York"
    },
    {
      "id": 3,
      "text": "The village incorporated in 1816 but didn’t organize its government until 1836.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bath_(village)%2C_New_York"
    },
    {
      "id": 4,
      "text": "Bath’s rail link once ran the Bath & Hammondsport line, connecting to Norfolk Southern at Painted Post before the line was abandoned.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bath_(village)%2C_New_York"
    },
    {
      "id": 5,
      "text": "The Steuben County Fair, held in Bath, is the oldest continuous fair in the United States.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bath_(village)%2C_New_York"
    },
    {
      "id": 6,
      "text": "Bath housed the land office that sold 1.2 million acres during the westward expansion.",
