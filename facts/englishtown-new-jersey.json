  "facts": [
    {
      "id": 1,
      "text": "Englishtown got its name from an English family that bought a large tract of fertile land before 1730.",
      "sourceSentenceIds": [
        2,
        3
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://www.englishtownnj.com/about"
    },
    {
      "id": 2,
      "text": "The Village Inn, built in the 1700s, now hosts Revolutionary and Civil War reenactors every summer.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.englishtownnj.com/about"
    },
    {
      "id": 3,
      "text": "In 1978 the Battleground Historical Society rescued the Village Inn from an uncertain future.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.englishtownnj.com/about"
    },
    {
      "id": 4,
      "text": "The old Municipal Building, now a historic landmark, originally served as a tavern in early Englishtown.",
      "sourceSentenceIds": [
        4,
        5
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://www.englishtownnj.com/about"
    },
    {
      "id": 5,
      "text": "The earliest documented record of Englishtown dates to 1688 when James Johnston, an Englishman, owned property there.",
      "sourceSentenceIds": [
        7,
        10
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://www.englishtownnj.com/about"
    },
    {
      "id": 6,
      "text": "Englishtown operates under New Jersey’s borough form of government, the most common municipal structure in the state.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
