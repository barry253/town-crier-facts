    },
    {
      "id": 3,
      "text": "In 1985 the historic Hetfield House was relocated down Route 22, a move that stunned longtime residents.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.mountainsidehistory.org/research"
    },
    {
      "id": 4,
      "text": "Mountainside’s residents still recall the 1987 tornado that rattled the borough and sparked community resilience.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.mountainsidehistory.org/research"
    },
    {
      "id": 5,
      "text": "Bordered by the Watchung ridges, Mountainside’s four square miles offer a parklike setting amid exurban activity.",
      "sourceSentenceIds": [
