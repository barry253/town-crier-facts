  "facts": [
    {
      "id": 1,
      "text": "Myers Corner sits where All Angels Hill Road, New Hackensack Road, and Route 376 meet, once bustling with shops and the historic Woronock House tavern.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.wappingershistoricalsociety.org/town-of-wappinger-history"
    },
    {
      "id": 2,
      "text": "The town’s first railroad station opened here, marking Myers Corner as an early rail hub in the 19th century.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.wappingershistoricalsociety.org/town-of-wappinger-history"
    },
    {
      "id": 3,
      "text": "In the 1860s, the Carthage Landing Mill was built, and by 1870 it had become the Carthage Cement Factory.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.wappingershistoricalsociety.org/town-of-wappinger-history"
    },
    {
      "id": 4,
      "text": "The town’s name, Wappinger, honors the Wappani Native Americans who once lived along the Hudson’s east side.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.wappingershistoricalsociety.org/town-of-wappinger-history"
    },
    {
      "id": 5,
      "text": "Myers Corner School, a local educational institution, serves the community’s children within the hamlet.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.wappingershistoricalsociety.org/town-of-wappinger-history"
    },
    {
      "id": 6,
      "text": "Myers Corner lies at the intersection of County Routes 93 and 94, anchoring it within the town of Wappinger.",
      "sourceSentenceIds": [
        9
      ],
