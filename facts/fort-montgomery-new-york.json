  "facts": [
    {
      "id": 1,
      "text": "Fort Montgomery CDP takes its name from the Revolutionary fort stormed by the British on October 6, 1777.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Fort_Montgomery%2C_New_York"
    },
    {
      "id": 2,
      "text": "The state historic site brings the battle to life with living history demos of artillery, musketry, music, and camp life.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://parks.ny.gov/visit/historic-sites/fort-montgomery-state-historic-site"
    },
    {
      "id": 3,
      "text": "In 1850, New York State acquired Washington’s Headquarters, the nation’s first state historic site, paving the way for places like Fort Montgomery.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://parks.ny.gov/visit/historic-sites/fort-montgomery-state-historic-site"
    },
    {
      "id": 4,
      "text": "The fort’s position on the Hudson’s west bank delayed the British from sailing upriver to relieve Burgoyne’s forces at Saratoga.",
      "sourceSentenceIds": [
        21
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Fort_Montgomery%2C_New_York"
    },
    {
      "id": 5,
      "text": "After the fort fell, American defenses shifted to West Point, and the site was never reused militarily.",
      "sourceSentenceIds": [
        22
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Fort_Montgomery%2C_New_York"
    },
    {
      "id": 6,
      "text": "Today, the hamlet sits on the Appalachian Trail, offering hikers a convenient stop with food and lodging near the historic fort.",
      "sourceSentenceIds": [
        27
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
