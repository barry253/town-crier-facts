    },
    {
      "id": 2,
      "text": "The village incorporated in 1854 and became the county seat in 1864, replacing Martinsburg.",
      "sourceSentenceIds": [
        21
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lowville%2C_New_York"
    },
    {
      "id": 3,
      "text": "Nicholas Low, an early landowner, gave the town its name.",
      "sourceSentenceIds": [
        3
