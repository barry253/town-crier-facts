  "facts": [
    {
      "id": 1,
      "text": "New Hempstead village grew out of the original Hempstead settlement founded around 1644 after a treaty with the Lenape Indians.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Hempstead%2C_New_York"
    },
    {
      "id": 2,
      "text": "The village’s name echoes its roots in the Dutch town Heemstede, reflected in early 1640s documents that called it Heemstede.",
      "sourceSentenceIds": [
        21
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Hempstead%2C_New_York"
    },
    {
      "id": 3,
      "text": "In 1664, the new settlement adopted the Duke’s Laws, austere statutes that later shaped many colonial legal systems.",
      "sourceSentenceIds": [
        2,
        5
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Hempstead%2C_New_York"
    },
    {
      "id": 4,
      "text": "During the Revolution, Loyalists in the south and Patriots in the north split the town in 1784 into North and South Hempstead.",
      "sourceSentenceIds": [
        23
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Hempstead%2C_New_York"
    },
    {
      "id": 5,
      "text": "The town’s early founders, John Carman and Robert Fordham, were English colonists who purchased land from the Lenape in 1643.",
