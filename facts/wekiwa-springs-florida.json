    },
    {
      "id": 2,
      "text": "The springs have been a freshwater source for the Timucua people since before European arrival, long before Spanish explorers noted them in the 16th century.",
      "sourceSentenceIds": [
        2,
        27
      ],
      "sourceLabels": [
        "Web source 1"
