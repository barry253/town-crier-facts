  "facts": [
    {
      "id": 1,
      "text": "Haverstraw’s name comes from Dutch “Haverstroo,” meaning “oat straw,” describing the river meadow’s waving grass.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://townofhaverstraw.gov/history.html"
    },
    {
      "id": 2,
      "text": "The town was founded in 1666, but Dutch maps already called the area “Haverstroo” in 1616.",
      "sourceSentenceIds": [
        6,
        9
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://villageofhaverstraw.gov/about-the-village/"
    },
    {
      "id": 3,
      "text": "In 1828 John Glass launched the first textile mill on Minisceongo Creek, sparking Haverstraw’s early industrial boom.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://townofhaverstraw.gov/history.html"
    },
    {
      "id": 4,
      "text": "The 1950s saw a wave of Hispanic workers arrive to fill garment factory jobs, reshaping the village’s cultural fabric.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://villageofhaverstraw.gov/about-the-village/"
    },
    {
      "id": 5,
      "text": "Haverstraw played a role in American wars: Benedict Arnold’s treason, Washington’s troops, a Civil War infantry company, and two Medal of Honor recipients.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://villageofhaverstraw.gov/about-the-village/"
    },
    {
      "id": 6,
      "text": "A stop on Route 9W offers a view of Edward Hopper’s “The House by the Railroad,” a famous painting of the village’s historic station.",
      "sourceSentenceIds": [
        3
      ],
