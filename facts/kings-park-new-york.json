  "facts": [
    {
      "id": 1,
      "text": "Kings Park sprang into existence after the 1885 opening of the Kings Park State Hospital, now the Psychiatric Center.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.longislandguide.com/visit/kings-park/"
    },
    {
      "id": 2,
      "text": "The village’s name honors the historic Kings County Farm, once a local institution for the poor and mentally ill.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.longislandexchange.com/towns/kings-park/"
    },
    {
      "id": 3,
      "text": "Nestled on Long Island’s North Shore, Kings Park is celebrated for its waterfront parks and historic charm.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.longislandguide.com/visit/kings-park/"
    },
    {
      "id": 4,
      "text": "Spanning 870 acres, the Kings Park Psychiatric Center was founded in 1885 and remains a landmark of the area.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.longislandexchange.com/towns/kings-park/"
    },
    {
      "id": 5,
      "text": "To the east, the Nissequogue River separates Kings Park from the neighboring hamlet of Nissequogue.",
      "sourceSentenceIds": [
        14
