      ],
      "source": "https://www.livingplaces.com/CT/Fairfield_County/Westport_Town/Compo-Owenoke_Historic_District.html"
    },
    {
      "id": 3,
      "text": "Westport Country Playhouse, originally Kemper's Tannery, has produced novels, plays, and movies, attracting actors, writers, and architects.",
      "sourceSentenceIds": [
