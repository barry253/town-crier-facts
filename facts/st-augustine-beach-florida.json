  "facts": [
    {
      "id": 1,
      "text": "Founded in 1565, St. Augustine Beach traces its roots to the earliest Spanish settlement in Florida.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.citystaug.com/693/Our-History"
    },
    {
      "id": 2,
      "text": "The town’s name honors Saint Augustine, named by Governor Gonzalo Méndez de Canzo after the saint whose feast day matched the day of first sighting.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.citystaug.com/693/Our-History"
    },
    {
      "id": 3,
      "text": "St. Augustine Beach’s wide, welcoming shores are perfect for swimming, sunbathing, and beachcombing, with volleyball courts and picnic spots near the Pier.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.visitstaugustine.com/regions/st-augustine-beach"
    },
    {
      "id": 4,
      "text": "The city’s library, the Anastasia Island Beach Branch of Johns County Public Library, serves residents and visitors alike.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/St._Augustine_Beach%2C_Florida"
    },
    {
      "id": 5,
      "text": "St. Augustine Beach is bordered by the Atlantic Ocean to the north, A1A to the east, Pope Road to the south, and Sandpiper Village to the west.",
