  "facts": [
    {
      "id": 1,
      "text": "Mount Plymouth was developed during the Florida land boom of the 1920s as a planned golf resort community centered around the Mount Plymouth Hotel and Country Club.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Mount_Plymouth%2C_Florida"
    },
    {
      "id": 2,
      "text": "The historic Mount Plymouth Hotel, built in 1926 for $350,000, once hosted famous guests like Al Capone, Babe Ruth, Connie Mack, and singer Kate Smith.",
      "sourceSentenceIds": [
        10,
        21,
        6
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Mount_Plymouth%2C_Florida"
    },
    {
      "id": 3,
      "text": "After the hotel closed, the 150‑room building became Florida Central Academy in 1959 and operated until 1983 before being condemned and later destroyed by fire.",
      "sourceSentenceIds": [
        26,
        27,
        28,
        29
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Mount_Plymouth%2C_Florida"
    },
    {
      "id": 4,
      "text": "The original golf course, Mount Plymouth Golf Club, closed in 2007, leaving only the abandoned fairways visible along County Road 435 today.",
      "sourceSentenceIds": [
        24,
        11
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Mount_Plymouth%2C_Florida"
    },
    {
      "id": 5,
      "text": "Mount Plymouth sits within the Orlando–Kissimmee Metropolitan Statistical Area, linking it to the broader Central Florida region.",
