  "facts": [
    {
      "id": 1,
      "text": "Northport was originally called Great Cow Harbor before adopting its current name in 1837.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Northport%2C_New_York"
    },
    {
      "id": 2,
      "text": "The village’s historic harbor is framed by four towering smokestacks that can be seen from Connecticut across Long Island Sound.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Northport%2C_New_York"
    },
    {
      "id": 3,
      "text": "Every September, Northport hosts Cow Harbor Day, a festival that includes a parade, antique cars, and a temporary trolley revival on Main Street.",
      "sourceSentenceIds": [
        9,
        11
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Northport%2C_New_York"
    },
    {
      "id": 4,
      "text": "Northport’s Main Street still carries the original trolley rails from a streetcar line that once linked residents to the Long Island Rail Road station.",
      "sourceSentenceIds": [
        19
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Northport%2C_New_York"
    },
    {
      "id": 5,
      "text": "The Northport Power Station, opened in 1967, remains the largest oil‑fired electric generating plant on the East Coast.",
      "sourceSentenceIds": [
        24
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Northport%2C_New_York"
    },
    {
      "id": 6,
      "text": "Steer’s Pit, a deep cliffside basin just south of the power plant, is a local landmark carved into the harbor’s cliffs.",
      "sourceSentenceIds": [
        25
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Northport%2C_New_York"
