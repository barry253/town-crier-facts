  "facts": [
    {
      "id": 1,
      "text": "Belle Terre was founded in 1906 as a Gold Coast resort, with the Belle Terre Club opening that same year as a private members club.",
      "sourceSentenceIds": [
        2,
        25
      ],
      "sourceLabels": [
        "Web source 1",
        "Wikipedia"
      ],
      "source": "https://belleterrebrookhavenneighborhood.org/a-journey-through-time-the-rich-history-and-heritage-of-belle-terre-brookhaven/"
    },
    {
      "id": 2,
      "text": "The village’s name means “beautiful land,” a nod to the wooded terrain that once covered the peninsula.",
      "sourceSentenceIds": [
        3,
        4
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 1"
      ],
      "source": "https://belleterrebrookhavenneighborhood.org/a-journey-through-time-the-rich-history-and-heritage-of-belle-terre-brookhaven/"
    },
    {
      "id": 3,
      "text": "After a 1934 fire destroyed the original club, the building was never rebuilt, leaving only the memory of its grand halls.",
      "sourceSentenceIds": [
        28,
        29
      ],
      "sourceLabels": [
        "Wikipedia",
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Belle_Terre%2C_New_York"
    },
    {
      "id": 4,
      "text": "Post‑World War II, Belle Terre attracted year‑round residents—academics, artists, and professionals—seeking a peaceful escape from the city.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://belleterrebrookhavenneighborhood.org/a-journey-through-time-the-rich-history-and-heritage-of-belle-terre-brookhaven/"
    },
    {
      "id": 5,
      "text": "The village’s historic homes are carefully preserved, and new construction must blend with the existing landscape to maintain its classic feel.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://belleterrebrookhavenneighborhood.org/a-journey-through-time-the-rich-history-and-heritage-of-belle-terre-brookhaven/"
    },
    {
      "id": 6,
      "text": "Belle Terre’s pink mansion, once owned by actress Farber, was featured in the 1989 film She‑Devil and remains a local landmark.",
