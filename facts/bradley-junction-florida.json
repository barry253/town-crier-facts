  "facts": [
    {
      "id": 1,
      "text": "Bradley Junction began as a phosphate mining town in the early 1900s, its growth tied to the booming mineral industry.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.floridasmart.com/city-guide/bradley-junction"
    },
    {
      "id": 2,
      "text": "The town’s name honors Peter Bradley, a Boston industrialist who helped shape Polk County’s phosphate economy.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.floridasmart.com/city-guide/bradley-junction"
    },
    {
      "id": 3,
      "text": "Bradley Junction’s railroad junction linked the north‑south line with the Seaboard Air Line, making it a key phosphate shipment hub by 1910.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/bradley_junction_florida"
    },
    {
      "id": 4,
      "text": "Today, the nearby Mulberry Phosphate Museum preserves the region’s mining heritage and offers a fossil dig area for curious visitors.",
      "sourceSentenceIds": [
        10,
        11
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.floridasmart.com/city-guide/bradley-junction"
    },
    {
      "id": 5,
      "text": "Bradley Junction remains unincorporated, reflecting its origins as a modest, industry‑dependent outpost without formal municipal governance.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 2"
      ],
