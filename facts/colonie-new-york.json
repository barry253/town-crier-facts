      ],
      "source": "https://en.wikipedia.org/wiki/Colonie%2C_New_York"
    },
    {
      "id": 2,
      "text": "The town was formed in 1895 when residents opposed turning the whole town into the city of Watervliet.",
      "sourceSentenceIds": [
        21
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Colonie%2C_New_York"
    },
    {
      "id": 3,
      "text": "Pruyn House in Newtonville serves as the town's historical and cultural arts center.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Colonie%2C_New_York"
    },
    {
      "id": 4,
      "text": "Albany Rural Cemetery, one of Upstate New York's oldest cemeteries, sits in Colonie.",
      "sourceSentenceIds": [
