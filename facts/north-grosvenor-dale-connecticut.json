  "facts": [
    {
      "id": 1,
      "text": "North Grosvenor Dale grew around a large brick cotton mill built in 1872, which gave the village its name.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/North_Grosvenordale"
    },
    {
      "id": 2,
      "text": "The mill complex covers about 70 acres and includes more than 100 historic buildings, many of which were worker homes.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/North_Grosvenordale"
    },
    {
      "id": 3,
      "text": "The village’s core is listed as the North Grosvenor Dale Mill Historic District on the National Register of Historic Places.",
      "sourceSentenceIds": [
        20
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/North_Grosvenordale"
    },
    {
      "id": 4,
      "text": "The mill sits on the French River in central Thompson, where the river’s north–south course roughly follows Connecticut Route 12.",
      "sourceSentenceIds": [
        21,
        22
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/North_Grosvenordale"
    },
    {
      "id": 5,
      "text": "The abandoned mill complex is visible from Riverside Drive, a public road that runs through the historic village.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://ghostofnewengland.com/north-grosvenordale-mill/"
    },
    {
      "id": 6,
      "text": "The mill’s surrounding neighborhood once housed immigrant workers in clusters called “Little Canada” and “Swede Village.”",
      "sourceSentenceIds": [
        29
      ],
      "sourceLabels": [
