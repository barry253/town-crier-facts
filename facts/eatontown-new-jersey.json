  "facts": [
    {
      "id": 1,
      "text": "Eatontown takes its name from Thomas Eaton, who surveyed the area and built a grist mill there in 1670.",
      "sourceSentenceIds": [
        4,
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Eatontown%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "The community first incorporated as Eatontown Township in 1873 and became a borough in 1926 after a local referendum.",
      "sourceSentenceIds": [
        6,
        10
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Eatontown%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "Fort Monmouth, a major U.S. Army installation, operated in Eatontown from 1917 until its closure in September 2011.",
      "sourceSentenceIds": [
        11,
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Eatontown%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "The Eatontown Historical Museum, located at 75 Broad Street, was purchased by the borough in 1978 and preserves local history.",
