    },
    {
      "id": 2,
      "text": "In 1946, Nassau County closed Old Mill Pond Brook by enclosing it in a culvert after residents complained of washouts.",
      "sourceSentenceIds": [
        4,
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Saddle_Rock_Estates%2C_New_York"
    },
    {
      "id": 3,
      "text": "The 1941 expansion project that shaped the area was estimated at $140,000 in 1941 dollars.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Saddle_Rock_Estates%2C_New_York"
    },
    {
      "id": 4,
      "text": "The hamlet falls inside the Great Neck Library District, giving residents access to its extensive collections.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Saddle_Rock_Estates%2C_New_York"
    },
    {
      "id": 5,
      "text": "Children in Saddle Rock Estates attend Great Neck public schools, the same district that serves the surrounding community.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
