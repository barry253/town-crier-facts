  "facts": [
    {
      "id": 1,
      "text": "Ocean Ridge began as the Town of Boynton Beach in 1931, before adopting its current name in 1939 to avoid mail mix‑ups.",
      "sourceSentenceIds": [
        1,
        26
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ocean_Ridge%2C_Florida"
    },
    {
      "id": 2,
      "text": "The town sits on a narrow coastal ridge just north of Briny Breezes, with the Atlantic Ocean to its east.",
      "sourceSentenceIds": [
        7,
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ocean_Ridge%2C_Florida"
    },
    {
      "id": 3,
      "text": "Before Europeans arrived, the Jaega people inhabited this barrier island, leaving shell mounds that once marked ceremonial lookout points.",
      "sourceSentenceIds": [
        13,
        14,
        15
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ocean_Ridge%2C_Florida"
    },
    {
      "id": 4,
      "text": "In 1897, Boynton opened the Boynton Beach Hotel, a grand resort that once promised 2,000 rooms and dazzled early tourists.",
      "sourceSentenceIds": [
        18,
        20,
        21
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ocean_Ridge%2C_Florida"
    },
    {
      "id": 5,
      "text": "The town’s climate is tropical savanna, bordering on tropical monsoon, making it one of only a few U.S. regions with that classification.",
      "sourceSentenceIds": [
        10,
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Ocean_Ridge%2C_Florida"
    },
    {
      "id": 6,
      "text": "Boynton Beach itself was incorporated in 1920, a few years before the area that would become Ocean Ridge was founded.",
