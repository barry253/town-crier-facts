    },
    {
      "id": 2,
      "text": "The hamlet’s name comes from a glass company whose products were hauled down the Glasco Turnpike to the Hudson for shipment.",
      "sourceSentenceIds": [
        18,
        19,
        7
      ],
      "sourceLabels": [
