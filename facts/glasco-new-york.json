      "id": 1,
      "text": "Glasco grew from a 19th‑century bluestone quarry and brick‑making hub into a quiet artist enclave.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
