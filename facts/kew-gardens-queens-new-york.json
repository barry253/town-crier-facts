  "facts": [
    {
      "id": 1,
      "text": "Founded in 1909 by lawyer Alrick Man, Kew Gardens was envisioned as a “garden suburb” for New York’s emerging professional class.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.cityneighborhoods.nyc/kew-gardens"
    },
    {
      "id": 2,
      "text": "Lefferts Boulevard anchors the neighborhood’s commercial life, with shops and cafés clustering around the historic Kew Gardens LIRR station.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.cityneighborhoods.nyc/kew-gardens"
    },
    {
      "id": 3,
      "text": "The Kew Gardens Inn opened in 1920 beside the railroad, offering guests a room, bath, and meals for $40 a week.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Kew_Gardens%2C_Queens"
    },
    {
      "id": 4,
      "text": "Ralph Bunche’s home in Kew Gardens is listed on the National Register of Historic Places and is a designated National Historic Landmark.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
