  "facts": [
    {
      "id": 1,
      "text": "Sam Kellner, a New York businessman, founded Beverly Hills in the early 1960s as a planned retirement community.",
      "sourceSentenceIds": [
        2,
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Beverly_Hills,_Florida"
    },
    {
      "id": 2,
      "text": "He named the community Beverly Hills, inspired by its rolling terrain, and marketed it as “The Alps of Florida” to attract snow‑free retirees.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Beverly_Hills,_Florida"
    },
    {
      "id": 3,
      "text": "From just 20 homes in spring 1962, Beverly Hills expanded to about 400 homes by the end of 1965.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Beverly_Hills%2C_Florida"
    },
    {
      "id": 4,
      "text": "The Central Ridge Library of Citrus Libraries serves the Beverly Hills community.",
      "sourceSentenceIds": [
