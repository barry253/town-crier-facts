  "facts": [
    {
      "id": 1,
      "text": "Brownville takes its name from Jacob Brown, a War of 1812 major‑general whose leadership helped shape the region.",
      "sourceSentenceIds": [
        19
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Brownville%2C_New_York"
    },
    {
      "id": 2,
      "text": "The town of Brownville was created in 1802 from Leyden while still part of Herkimer County.",
      "sourceSentenceIds": [
        20
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Brownville%2C_New_York"
    },
    {
      "id": 3,
      "text": "In 1828 the village of Brownville separated from the town, becoming an incorporated municipality.",
      "sourceSentenceIds": [
        22
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Brownville%2C_New_York"
    },
    {
      "id": 4,
      "text": "Brown Mansion, a Georgian house built in the 1800s, now serves as the village office, library, and community center.",
      "sourceSentenceIds": [
        10,
        13
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.villageofbrownvilleny.gov/"
    },
    {
      "id": 5,
      "text": "Lake Ontario borders Brownville’s western edge while the Black River defines its southern boundary, emptying into Black River Bay.",
      "sourceSentenceIds": [
        26
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Brownville%2C_New_York"
    },
    {
      "id": 6,
      "text": "Paul’s Church, Vogt House, and Arthur Walrath House in Brownville are all listed on the National Register of Historic Places.",
