  "facts": [
    {
      "id": 1,
      "text": "St. George’s ferry‑railroad terminal was renamed for developer George Law after Erastus Wiman promised to “canonize” him in exchange for land rights.",
      "sourceSentenceIds": [
        1,
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/St._George%2C_Staten_Island"
    },
    {
      "id": 2,
      "text": "The former Richmond County Bank Ballpark opened in 2001, later renamed SIUH Community Park, and hosted the Staten Island Yankees until 2020.",
      "sourceSentenceIds": [
        5,
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/St._George%2C_Staten_Island"
    },
    {
      "id": 3,
      "text": "Before European settlement, the Munsee‑speaking Lenape people inhabited what is now St. George.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/St._George%2C_Staten_Island"
    },
    {
      "id": 4,
      "text": "A surviving 1870s house at 272 Richmond Terrace remains part of a trio of similar homes built around that time.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://preserve.org/stgeorge/stgeorgedistrict.htm"
    },
    {
      "id": 5,
      "text": "Between 1878 and 1882, Joseph Wilks constructed the brick double house at 30‑32 Westervelt Avenue, showcasing Romanesque Revival style.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://preserve.org/stgeorge/stgeorgedistrict.htm"
    },
    {
      "id": 6,
      "text": "In 1951, St. George Terminal reopened after a rebuild that added a parking lot, new ferry slips, and better bus connections.",
