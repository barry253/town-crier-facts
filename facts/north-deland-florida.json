  "facts": [
    {
      "id": 1,
      "text": "North DeLand sits just a mile from Stetson University, Florida’s oldest private college, founded in 1853.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/north_deland_florida"
    },
    {
      "id": 2,
      "text": "The area that became North DeLand was once called Persimmon Hollow, named for the wild persimmon trees that lined its springs.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/north_deland_florida"
    },
    {
      "id": 3,
      "text": "North DeLand experiences a warm, rainy season from May to October, followed by a cooler dry stretch from November to April.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/north_deland_florida"
    },
    {
      "id": 4,
      "text": "The community’s median age is 35.4 years, a few years younger than Florida’s state average.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/north_deland_florida"
    },
    {
      "id": 5,
      "text": "Residents bring a mix of ancestries—English, German, and American—while about nine percent are foreign‑born, mainly from Latin America and Europe.",
      "sourceSentenceIds": [
        29
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/north_deland_florida"
    },
    {
      "id": 6,
      "text": "A striking 97.3 percent of adults 25 and older hold at least a high school diploma, and 31.5 percent have earned a bachelor’s degree.",
