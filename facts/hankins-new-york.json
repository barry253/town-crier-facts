  "facts": [
    {
      "id": 1,
      "text": "Hankins takes its name from pioneer John Hankins, who founded the first permanent settlement here in 1835 with a home, store, sawmill and blacksmith’s shop.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.americancatskills.com/blog/2024/6/hankins-stone-arch-bridge-a-photographic-study"
    },
    {
      "id": 2,
      "text": "The Hankins Stone Arch Bridge, built in 1905, is a rare example of traditional stone arch construction in the Upper Delaware River region.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.americancatskills.com/blog/2024/6/hankins-stone-arch-bridge-a-photographic-study"
    },
    {
      "id": 3,
      "text": "The single‑arch bridge spans Hankins Creek just north of its confluence with the Delaware River, a crossing that once carried local traffic for decades.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.americancatskills.com/blog/2024/6/hankins-stone-arch-bridge-a-photographic-study"
    },
    {
      "id": 4,
      "text": "In 1973 the bridge was abandoned after East Ridge Road was rerouted, ending its role as a vital creek crossing for the community.",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.americancatskills.com/blog/2024/6/hankins-stone-arch-bridge-a-photographic-study"
    },
    {
      "id": 5,
      "text": "The bridge earned a place on the National Register of Historic Places as a well‑preserved example of early 20th‑century stone bridge design.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.americancatskills.com/blog/2024/6/hankins-stone-arch-bridge-a-photographic-study"
    },
    {
      "id": 6,
      "text": "Hankins sits along New York State Route 97 beside the Delaware River, about 8.2 miles west‑northwest of Jeffersonville.",
      "sourceSentenceIds": [
        20
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Hankins%2C_New_York"
    }
  ]
