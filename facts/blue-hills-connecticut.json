      "id": 1,
      "text": "Blue Hills hosts the 1930s-era Blue Hills Fire Tower, a historic lookout that still offers sweeping views of the Farmington Valley.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
