    },
    {
      "id": 2,
      "text": "The neighborhood’s trails wind along Metacomb Ridge, making it a quiet base for hikers and history buffs alike.",
      "sourceSentenceIds": [
        3,
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.trawellino.com/destinations/united-states/connecticut_blue-hills"
    },
    {
      "id": 3,
      "text": "Blue Hills is the U.S. Census Bureau’s highest‑percentage Jamaican‑American community, with nearly a quarter of residents tracing Jamaican heritage.",
      "sourceSentenceIds": [
        22,
        23
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Blue_Hills%2C_Connecticut"
    },
    {
      "id": 4,
      "text": "The area is home to the University of Hartford, one of Connecticut’s major higher‑education institutions.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Blue_Hills%2C_Connecticut"
    },
    {
      "id": 5,
      "text": "Blue Hills lies within the city limits of Bloomfield and the neighboring city of Hartford, blending suburban and urban character.",
      "sourceSentenceIds": [
