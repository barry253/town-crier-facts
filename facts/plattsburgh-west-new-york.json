  "facts": [
    {
      "id": 1,
      "text": "Plattsburgh’s history was forged by two pivotal battles: Valcour Island in 1776 and Plattsburgh Bay in 1814.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.cityofplattsburgh-ny.gov/department/city-historian"
    },
    {
      "id": 2,
      "text": "Plattsburgh City Hall chronicles the town’s past, while the former Barracks served the military from 1814 to 1995.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.cityofplattsburgh-ny.gov/department/city-historian"
    },
    {
      "id": 3,
      "text": "Today, the historic buildings and scenic grounds of the former barracks welcome visitors to explore the area’s heritage.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.cityofplattsburgh-ny.gov/department/city-historian"
    },
    {
      "id": 4,
      "text": "Mooers sits in northern New York, just a stone’s throw from the Canada–United States border with Quebec.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Mooers_(CDP)%2C_New_York"
    },
    {
      "id": 5,
      "text": "The hamlet of Mooers lies roughly three miles south of the Canada‑US border, near the Great Chazy River.",
      "sourceSentenceIds": [
        7
