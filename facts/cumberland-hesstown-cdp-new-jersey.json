  "facts": [
    {
      "id": 1,
      "text": "Cumberland‑Hesstown takes its name from Prince William, Duke of Cumberland, who was honored when the county was formed in 1748.",
      "sourceSentenceIds": [
        1,
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Cumberland_County%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "During the Underground Railroad, Cumberland‑Hesstown sheltered fugitives, including famed conductor Harriet Tubman and William Still.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Cumberland_County%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "The first European settlers were Swedes who called the area New Sweden in the early 1600s.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Cumberland_County%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "Oyster harvesting sparked shipbuilding in 1780, and by the late 1800s schooners replaced sloops for oystering.",
      "sourceSentenceIds": [
        22,
        23
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Cumberland_County%2C_New_Jersey"
    },
    {
      "id": 5,
      "text": "The highest point in the CDP rises only about 140 feet above sea level, while the lowest is at sea level.",
