  "facts": [
    {
      "id": 1,
      "text": "Hastings-on-Hudson’s name honors the 17th‑century landowner Frederick Philipse, whose manor once spanned the area.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.hastingsgov.org/428/Village-History"
    },
    {
      "id": 2,
      "text": "The John William Draper House, a National Historic Landmark, sits on the village’s historic core.",
      "sourceSentenceIds": [
        2,
        3
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Hastings-on-Hudson%2C_New_York"
    },
    {
      "id": 3,
      "text": "During the Civil War, the Underground Railroad ran through Hastings‑on‑Hudson, offering a vital escape route for enslaved people.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Hastings-on-Hudson%2C_New_York"
    },
    {
      "id": 4,
      "text": "Billie Burke, the famed “Good Witch” of The Wizard of Oz, once owned a lavish estate in Hastings‑on‑Hudson that now serves the school district.",
      "sourceSentenceIds": [
        9,
        20
      ],
      "sourceLabels": [
        "Web source 2",
        "Wikipedia"
      ],
      "source": "https://www.hastingsgov.org/428/Village-History"
    },
    {
      "id": 5,
      "text": "The village’s two historic homes, Cropsey House and Hastings Prototype House, are listed on the National Register of Historic Places.",
      "sourceSentenceIds": [
        13,
        17
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Hastings-on-Hudson%2C_New_York"
    },
    {
      "id": 6,
      "text": "Hastings‑on‑Hudson lies just 20 miles north of Manhattan and is served by a Metro‑North Hudson Line stop, linking it directly to the city.",
      "sourceSentenceIds": [
        22
      ],
