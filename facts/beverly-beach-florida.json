        26,
        27
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://mybeverlybeach.org/"
    },
    {
      "id": 3,
      "text": "Beverly Beach incorporated as a sovereign municipality on June 23, 1955.",
      "sourceSentenceIds": [
        28
