  "facts": [
    {
      "id": 1,
      "text": "Fort Denaud was named after Pierre Denaud, a French‑Canadian trapper who traded skins with the Seminole before the war.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Fort_Denaud%2C_Florida"
    },
    {
      "id": 2,
      "text": "The military outpost was founded in 1838 during the Second Seminole War and later became an agricultural settlement after 1858.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://unitedstatesghosttowns.com/fort-denaud-inhabited-florida-ghost-town/"
    },
    {
      "id": 3,
      "text": "A historic marker on the south side of the Fort Denaud Bridge commemorates the fort’s role in the Seminole Wars.",
      "sourceSentenceIds": [
        4,
        8
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Fort_Denaud%2C_Florida"
    },
    {
      "id": 4,
      "text": "The 1963 Fort Denaud Swing Bridge and the cemetery are the only surviving landmarks from the original town.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://unitedstatesghosttowns.com/fort-denaud-inhabited-florida-ghost-town/"
    },
    {
      "id": 5,
      "text": "Today, citrus farms and modern homes surround the ghost town, keeping the area alive while preserving its past.",
      "sourceSentenceIds": [
        11,
        19
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://unitedstatesghosttowns.com/fort-denaud-inhabited-florida-ghost-town/"
    },
    {
      "id": 6,
      "text": "In 1856, a small army detachment was attacked near the river, leaving only one survivor.",
