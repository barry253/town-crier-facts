  "facts": [
    {
      "id": 1,
      "text": "Prattsburgh’s town hall, built in 1894, now houses the Prattsburgh Community Historical Society museum.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://museumsdatabase.com/museums/view/22102"
    },
    {
      "id": 2,
      "text": "The museum showcases the town’s early days, including its founding in 1813 and the Kanona & Prattsburgh Railway Company.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://prattsburgfreelibrary.org/prattsburg-online/attractions/prattsburgh-historical-society-museum/"
    },
    {
      "id": 3,
      "text": "The Prattsburgh Community Historical Society, founded in 1977, preserves local history through research, preservation, and public outreach.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://museumsdatabase.com/museums/view/22102"
    },
    {
      "id": 4,
      "text": "Visitors can browse an extensive library of local history publications and genealogy resources at the museum’s research desk.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://museumsdatabase.com/museums/view/22102"
    },
    {
      "id": 5,
      "text": "The town historian meets at the museum every Tuesday from 9:00 AM to noon, offering guided tours of Prattsburgh’s heritage.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://prattsburgfreelibrary.org/prattsburg-online/attractions/prattsburgh-historical-society-museum/"
    },
    {
      "id": 6,
      "text": "The museum’s collection includes photographs, maps, artifacts, and oral histories that chronicle Prattsburgh’s agricultural past.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://museumsdatabase.com/museums/view/22102"
    }
  ]
