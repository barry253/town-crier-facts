    },
    {
      "id": 3,
      "text": "State University of New York at Morrisville, home to a fish hatchery and equestrian center, anchors the village’s educational scene.",
      "sourceSentenceIds": [
        14,
        30
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Morrisville%2C_New_York"
    },
    {
      "id": 4,
      "text": "The Chenango River originates in Morrisville Swamp just northwest of town, flowing south toward the Susquehanna.",
      "sourceSentenceIds": [
        21
