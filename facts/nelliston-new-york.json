  "facts": [
    {
      "id": 1,
      "text": "Nelliston takes its name from the Nellis family, who still live in the village today.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.nelliston.org/government"
    },
    {
      "id": 2,
      "text": "The Nellis family were part of the Palatine settlement, German immigrants from Rhineland‑Palatinate.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.nelliston.org/government"
    },
    {
      "id": 3,
      "text": "Nelliston’s Historic District spans roughly 39 acres, featuring streets built between 1860 and 1890 and a railroad area.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://mohawkvalley.today/location/nelliston-ny/"
    },
    {
      "id": 4,
      "text": "Before Europeans arrived, the Mohawk Tribe made the area their capital, the center‑most village of the Iroquois Confederacy.",
      "sourceSentenceIds": [
        19
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.nelliston.org/government"
    },
    {
      "id": 5,
      "text": "The village sits on a bow‑shaped bend of the Mohawk River, where the river flows almost directly south.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://mohawkvalley.today/location/nelliston-ny/"
    },
    {
      "id": 6,
      "text": "The official history book, “Waymarks in Nelliston,” by former historian Ruth Lupo, can be viewed at Village Hall.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.nelliston.org/government"
    }
  ]
