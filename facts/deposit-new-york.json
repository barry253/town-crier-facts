  "facts": [
    {
      "id": 1,
      "text": "Deposit village sits where Oquaga Creek meets the West Branch of the Delaware River.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Deposit%2C_New_York"
    },
    {
      "id": 2,
      "text": "The town’s name comes from log deposits lumbermen left to raft down the Delaware to Philadelphia.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Deposit%2C_New_York"
    },
    {
      "id": 3,
      "text": "In the 1890s, Deposit became a publishing hub when Outing Publishing Company moved there, printing The Bohemian.",
      "sourceSentenceIds": [
        12,
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Deposit%2C_New_York"
    },
    {
      "id": 4,
      "text": "The Deposit Community Historical Society’s owl logo celebrates the village’s rich heritage.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://deposithistoricalsociety.org/history-of-deposit"
    },
    {
      "id": 5,
      "text": "Deposit lies in a valley sixty miles from the West Branch source, surrounded by mountains nearly a thousand feet high.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://deposithistoricalsociety.org/history-of-deposit"
    },
    {
      "id": 6,
      "text": "Cannonsville Reservoir, which supplies New York City water, sits just three miles east of Deposit on the West Branch.",
