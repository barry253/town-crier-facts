  "facts": [
    {
      "id": 1,
      "text": "Noank sits on a steep peninsula at the mouth of the Mystic River, a place famed for fishing, lobstering, and boatbuilding.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Noank%2C_Connecticut"
    },
    {
      "id": 2,
      "text": "Founded in 1954, the Noank Historical Society preserves maritime history in the historic Spicer Memorial Library building, built in 1901 and listed on the National Register of Historic Places.",
      "sourceSentenceIds": [
        1,
        2,
        6
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://museumsdatabase.com/museums/view/5415"
    },
    {
      "id": 3,
      "text": "The village hosts one of the longest‑running Memorial Day parades in the country, a tradition that began in 1876.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Noank%2C_Connecticut"
    },
    {
      "id": 4,
      "text": "The Noank Smack, a traditional fishing sailboat, originated here and is displayed at Mystic Seaport.",
      "sourceSentenceIds": [
        26,
        27
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Noank%2C_Connecticut"
    },
    {
      "id": 5,
      "text": "In 1912, the Connecticut State Lobster Hatchery was established in Noank, helping to boost the local lobster industry.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Noank%2C_Connecticut"
    },
    {
      "id": 6,
      "text": "Scenes for the movie Mystic Pizza were filmed at Ford's Lobsters in Noank, giving the town a memorable pop‑culture moment.",
      "sourceSentenceIds": [
