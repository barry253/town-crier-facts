  "facts": [
    {
      "id": 1,
      "text": "Hadley CDP sits on the Hudson River, with Lake Luzerne just across the water in Warren County.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Hadley_(CDP)%2C_New_York"
    },
    {
      "id": 2,
      "text": "The Sacandaga River skirts the town’s southern edge, meeting the Hudson at Hadley’s southeastern corner.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Hadley_(CDP)%2C_New_York"
    },
    {
      "id": 3,
      "text": "Hadley’s historic fire lookout, the Hadley Mountain Fire Observation Station, is listed on the National Register of Historic Places.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://townofhadleyny.gov/"
    },
    {
      "id": 4,
      "text": "The town’s 1930 Conklingville Dam created the Sacandaga Reservoir, helping control flooding in the region.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://townofhadleyny.gov/"
    },
    {
      "id": 5,
      "text": "Hadley was formed in 1801 from parts of Greenfield and Northumberland, and its borders changed when Corinth split off in 1818.",
      "sourceSentenceIds": [
        16,
        17
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://townofhadleyny.gov/"
    },
    {
      "id": 6,
      "text": "The Hadley‑Lake Luzerne Historical Society preserves the area’s heritage, showcasing artifacts from farming, logging, and summer camps.",
      "sourceSentenceIds": [
