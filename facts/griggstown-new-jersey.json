  "facts": [
    {
      "id": 1,
      "text": "Griggstown takes its name from Benjamin Griggs, who arrived in 1727 and built a grist mill on the Millstone River.",
      "sourceSentenceIds": [
        4,
        5
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Griggstown%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "The Delaware and Raritan Canal ran through Griggstown, and its bridge tender station once housed a wireless telegraph in 1873.",
      "sourceSentenceIds": [
        14,
        17
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Griggstown%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "When the canal closed in 1932, the tiny bridge tender station was converted into the smallest county library in New Jersey.",
      "sourceSentenceIds": [
        20
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.livingplaces.com/NJ/Somerset_County/Franklin_Township/Griggstown_Historic_District.html"
    },
    {
      "id": 4,
      "text": "Griggstown’s historic district features four masonry buildings: two brick structures—the Barracks and Terra Cotta Factory—and two stone houses, the Griggs House and Canal House.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.livingplaces.com/NJ/Somerset_County/Franklin_Township/Griggstown_Historic_District.html"
    },
    {
      "id": 5,
      "text": "Both the Millstone River and the Delaware and Raritan Canal flow through Griggstown, making it a historic waterway hub.",
      "sourceSentenceIds": [
        22
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Griggstown%2C_New_Jersey"
    },
    {
      "id": 6,
      "text": "A legend of a ghostly feral cow haunted the canal until a real bull was found in a ditch in 2002, ending the myth.",
      "sourceSentenceIds": [
