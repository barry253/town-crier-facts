    {
      "id": 2,
      "text": "The name Queens Village emerged in 1923 when the Long Island Railroad added “Village” to its station to avoid confusion with the county.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Web source 2"
      ],
