  "facts": [
    {
      "id": 1,
      "text": "Camp Mills, a World War I Army camp opened in August 1917, was named for Brigadier General Albert L.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://gardencityrecreation.org/village-markers"
    },
    {
      "id": 2,
      "text": "A 2,500‑bed Base Hospital at Camp Mills, built between Washington Avenue and Clinton Road, treated soldiers and influenza patients.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://gardencityrecreation.org/village-markers"
    },
    {
      "id": 3,
      "text": "The Merillon Avenue LIRR station, straddling Garden City Park and the Village of Garden City, links the hamlet to the rail network.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Garden_City_Park%2C_New_York"
    },
    {
      "id": 4,
      "text": "Garden City Park is bounded by Hillside Avenue to the north, Herricks Road to the east, Denton Avenue to the west, and Atlantic Avenue to the south.",
      "sourceSentenceIds": [
        23,
        24
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Garden_City_Park%2C_New_York"
    },
    {
      "id": 5,
      "text": "Before becoming Garden City Park, the area was known as Clowesville and served as Queens County’s seat until the 1870s.",
      "sourceSentenceIds": [
        21,
        22
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Garden_City_Park%2C_New_York"
    },
    {
      "id": 6,
      "text": "Historic markers across Garden City Park commemorate sites dating back before 1869, including the former Camp Mills and other significant locations.",
      "sourceSentenceIds": [
        6,
        7
      ],
