  "facts": [
    {
      "id": 1,
      "text": "Clark Mills takes its name from the Clark Mills Company, founded by brothers Ralph, Ammi, and Eneas Clark in the mid‑1800s.",
      "sourceSentenceIds": [
        2,
        8
      ],
      "sourceLabels": [
        "Web source 1",
        "Wikipedia"
      ],
      "source": "https://www.wgpfoundation.org/historic-markers/clark-mills/"
    },
    {
      "id": 2,
      "text": "The first mill’s cornerstone was laid in June 1846, with brickwork finished that fall, creating a four‑story, 275‑foot long building on Oriskany Creek.",
      "sourceSentenceIds": [
        9
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.wgpfoundation.org/historic-markers/clark-mills/"
    },
    {
      "id": 3,
      "text": "In 1891 British businessman Arthur Hind bought the old Clark Mills factory and launched the Hind and Harrison Plush Company, bringing a new industry to the hamlet.",
      "sourceSentenceIds": [
        6,
        13
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.wgpfoundation.org/historic-markers/clark-mills/"
    },
    {
      "id": 4,
      "text": "The Clark Brothers founded a textile mill in 1846 that ran for roughly thirty years, supplying the region with cotton and silk products.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://townofkirkland.gov/history/"
    },
    {
      "id": 5,
      "text": "A large portion of the historic mill was destroyed in 1972, leaving only fragments of the original structure.",
      "sourceSentenceIds": [
        24
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.wgpfoundation.org/historic-markers/clark-mills/"
