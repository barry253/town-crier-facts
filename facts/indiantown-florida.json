  "facts": [
    {
      "id": 1,
      "text": "Indiantown began as a Seminole trading post in the early 1800s, where traders exchanged hides and pelts for goods.",
      "sourceSentenceIds": [
        7,
        4
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Indiantown%2C_Florida"
    },
    {
      "id": 2,
      "text": "Davies Warfield extended the Seaboard Air Line Railroad through Indiantown in 1924, turning the village into a rail hub.",
      "sourceSentenceIds": [
        10,
        28
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Indiantown%2C_Florida"
    },
    {
      "id": 3,
      "text": "The 1926 Indiantown station, built by Warfield, featured paved streets, a school, and a hotel that became the historic Seminole Inn.",
      "sourceSentenceIds": [
        6,
        5,
        3
      ],
      "sourceLabels": [
        "Web source 1",
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://www.florida-backroads-travel.com/indiantown-florida.html"
    },
    {
      "id": 4,
      "text": "The Seminole Inn, still operating today, earned a spot on the National Register of Historic Places for its classic Florida architecture.",
      "sourceSentenceIds": [
        11,
        15
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Indiantown%2C_Florida"
    },
    {
      "id": 5,
      "text": "A 2019 plaque at the Seminole Inn honors Betty Mae Jumper, the first female chairwoman of the Seminole Tribe of Florida.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Indiantown,_Florida"
    },
    {
      "id": 6,
      "text": "Indiantown officially incorporated on December 31, 2017, becoming the first new municipality in Martin County in over four decades.",
      "sourceSentenceIds": [
