    },
    {
      "id": 2,
      "text": "The society runs a museum and library that house artifacts and documents chronicling Dividing Creek’s past.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://museumsdatabase.com/museums/view/19286"
    },
    {
      "id": 3,
      "text": "Historic sites under the society’s care include an old mill, a one‑room schoolhouse, and a blacksmith shop.",
