  "facts": [
    {
      "id": 1,
      "text": "Belmont village was originally called Foster's Meadow, a name that stuck for two centuries before it became Elmont.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Elmont%2C_New_York"
    },
    {
      "id": 2,
      "text": "Before Nassau County formed, Belmont was part of Queens County.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Elmont%2C_New_York"
    },
    {
      "id": 3,
      "text": "In 1898, when Nassau County was created, Belmont’s borders changed, sparking land disputes and unpaid debts.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Elmont%2C_New_York"
    },
    {
      "id": 4,
      "text": "Late 1800s saw a wave of Roman Catholic and Ashkenazi Jewish farmers from Brooklyn settle in Belmont.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Elmont%2C_New_York"
    },
    {
      "id": 5,
      "text": "The 1905 opening of Belmont Park turned the village into a racing hub.",
      "sourceSentenceIds": [
        15
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Elmont%2C_New_York"
    },
    {
      "id": 6,
      "text": "Belmont Park still hosts the Belmont Stakes, the final leg of the Triple Crown.",
