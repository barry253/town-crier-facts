  "facts": [
    {
      "id": 1,
      "text": "William John Howey founded Howey-in-the-Hills in 1921, building Florida's first citrus juice plant on Little Lake Harris.",
      "sourceSentenceIds": [
        5,
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Howey-in-the-Hills%2C_Florida"
    },
    {
      "id": 2,
      "text": "The town’s name changed to Howey-in-the-Hills in 1927 to honor its rolling hills, which Howey dubbed the “Florida Alps.”",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Howey-in-the-Hills%2C_Florida"
    },
    {
      "id": 3,
      "text": "Howey Mansion, a restored historic landmark, still stands and offers guided tours of its grand architecture.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.florida-backroads-travel.com/howey-in-the-hills-florida.html"
    },
    {
      "id": 4,
      "text": "The historic Citrus Tower, once overlooking miles of citrus groves, now provides panoramic views of Central Florida from its observation deck.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.florida-backroads-travel.com/howey-in-the-hills-florida.html"
    },
    {
      "id": 5,
      "text": "Presidents Hall of Fame in town displays wax figures of U.S. presidents and presidential memorabilia.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.florida-backroads-travel.com/howey-in-the-hills-florida.html"
    },
    {
      "id": 6,
      "text": "Yalaha Bakery, just north of Howey on SR‑19, serves European pastries and coffee while overlooking Lake Harris.",
