  "facts": [
    {
      "id": 1,
      "text": "Lordship, once called Great Neck, was a “Common Field” worked by settlers who returned nightly to the palisade fort at Academy Hill.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lordship%2C_Connecticut"
    },
    {
      "id": 2,
      "text": "The name Lordship first appeared in land deeds from 1650 to 1660, referring to Mill’s Lordship meadow.",
      "sourceSentenceIds": [
        18,
        19
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lordship%2C_Connecticut"
    },
    {
      "id": 3,
      "text": "The Stratford Point Light, a historic lighthouse on Lordship’s waterfront, still guides ships along the coast.",
      "sourceSentenceIds": [
        7,
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lordship%2C_Connecticut"
    },
    {
      "id": 4,
      "text": "In 1924, 25 Lordship residents founded the Lordship Improvement Association to fix the washboard road to Bridgeport.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.lordshipct.org/history"
    },
    {
      "id": 5,
      "text": "Gustave Whitehead reportedly used Lordship’s windswept sands for early powered flight trials in the early 1900s.",
      "sourceSentenceIds": [
        21
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lordship%2C_Connecticut"
    },
    {
      "id": 6,
      "text": "Lordship is reachable only via two roads that are part of Route 113, giving it a secluded waterfront feel.",
