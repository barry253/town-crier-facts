  "facts": [
    {
      "id": 1,
      "text": "Glenville first appeared in print as the Glenville Manufacturing Company in 1848.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://greenwichhistory.org/glenville-historic-district/"
    },
    {
      "id": 2,
      "text": "The area began as a saw and grist mill in 1717‑18, then called Sherwood’s Bridge.",
      "sourceSentenceIds": [
        21
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://greenwichhistory.org/glenville-historic-district/"
    },
    {
      "id": 3,
      "text": "In 1852 the American Felt Company turned the mill into America’s first woven felt factory, the largest of its kind.",
      "sourceSentenceIds": [
        22
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://greenwichhistory.org/glenville-historic-district/"
    },
    {
      "id": 4,
      "text": "Glenville Historic District was added to the National Register of Historic Places in 2007.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Glenville%2C_Connecticut"
    },
    {
      "id": 5,
      "text": "The district showcases a 1879 Stick‑style depot and an 1881 Romanesque mill, plus a Georgian Revival school now the civic center.",
      "sourceSentenceIds": [
        23
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://greenwichhistory.org/glenville-historic-district/"
    },
    {
      "id": 6,
      "text": "Glenville remains the primary Polish settlement in Greenwich, a legacy of 20th‑century immigration.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Glenville%2C_Connecticut"
    }
