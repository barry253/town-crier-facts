    },
    {
      "id": 2,
      "text": "The borough officially formed on February 13, 1925, after a March 17 referendum split it from Clementon Township.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Clementon%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "Clementon Lake shelters the historic Clementon Amusement Park, once home to the 1919 Jack Rabbit wooden roller coaster.",
      "sourceSentenceIds": [
        13,
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Clementon%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "Around 1800, Jonathon Haines erected a glass factory on a hill that later became the site of modern Clementon Park.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
