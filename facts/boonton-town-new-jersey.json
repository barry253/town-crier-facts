    },
    {
      "id": 2,
      "text": "The Boonton Iron Works, founded around 1770 by Samuel Ogden, sparked the town’s early industrial boom.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Boonton%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "In 1866 a single‑span fieldstone arch bridge from the Boonton Ironworks was built and later listed on the National Register in 2022.",
      "sourceSentenceIds": [
        23
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Boonton%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "Boonton became an independent municipality in March 1867, incorporated as a town by state charter.",
