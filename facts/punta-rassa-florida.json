  "facts": [
    {
      "id": 1,
      "text": "Punta Rassa was named by Spanish conquistadors in the mid‑16th century, meaning 'smooth or flat point', after they unloaded cattle there.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://puntarassa.org/History"
    },
    {
      "id": 2,
      "text": "Fort Dulany, built after 1838, served as an army supply depot and hospital during the Seminole Wars.",
      "sourceSentenceIds": [
        29
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Punta_Rassa%2C_Florida"
    },
    {
      "id": 3,
      "text": "A Seaboard Air Line Railroad line was started in the early 1920s toward Punta Rassa, but the track never reached the community, leaving a still‑existing abandoned subdivision.",
      "sourceSentenceIds": [
        9,
        11
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Punta_Rassa%2C_Florida"
    },
    {
      "id": 4,
      "text": "Hurricane October 1841 destroyed Fort Dulany, ending its brief military role.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Punta_Rassa%2C_Florida"
    },
    {
      "id": 5,
      "text": "Punta Rassa sits at the east end of the Sanibel Causeway, the bridge that links San Carlos Bay to Sanibel Island.",
      "sourceSentenceIds": [
        23
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Punta_Rassa%2C_Florida"
    },
