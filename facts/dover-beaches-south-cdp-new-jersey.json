    },
    {
      "id": 2,
      "text": "Development kicked off when the Pennsylvania Railroad reached the peninsula in 1883 and Route 35 opened in 1913.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Dover_Beaches_South%2C_New_Jersey"
    },
    {
      "id": 3,
      "text": "The rise of cars turned the area into a bungalow‑filled getaway for middle‑class families from Philadelphia and New York.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Dover_Beaches_South,_New_Jersey"
    },
    {
      "id": 4,
      "text": "A Life‑Saving Service station was established there in 1871 under the local name Ortley Beach.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/Dover_Beaches_South,_New_Jersey"
    },
    {
      "id": 5,
      "text": "Dover Beaches South sits on the Barnegat Peninsula, a narrow barrier that separates Barnegat Bay from the Atlantic Ocean.",
      "sourceSentenceIds": [
        6
