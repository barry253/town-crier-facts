  "facts": [
    {
      "id": 1,
      "text": "Spring Hill was founded in 1967 as a planned community by the Deltona Corporation and the Mackle Brothers.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Spring_Hill%2C_Florida"
    },
    {
      "id": 2,
      "text": "The developers originally called the community Spring Lake, but switched to Spring Hill when the name was already in use locally.",
      "sourceSentenceIds": [
        6,
        11
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Spring_Hill%2C_Florida"
    },
    {
      "id": 3,
      "text": "The historic Little Red Schoolhouse Branch Library has been turned into a bookstore run by the Friends of the Library, with proceeds supporting the library system.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Spring_Hill%2C_Florida"
    },
    {
      "id": 4,
      "text": "The main entrance to the original development is marked by a waterfall on Spring Hill Drive beside U.S. Route 19.",
      "sourceSentenceIds": [
        15,
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Spring_Hill%2C_Florida"
    },
    {
      "id": 5,
      "text": "Spring Hill is bordered to the west by U.S. 19, known locally as Commercial Way, and to the north by State Road 50, Cortez Boulevard.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Spring_Hill%2C_Florida"
    },
    {
      "id": 6,
      "text": "Situated in southwestern Hernando County, Spring Hill lies east of Hernando Beach, southwest of Brooksville, and north of Tampa.",
      "sourceSentenceIds": [
