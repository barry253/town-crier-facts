  "facts": [
    {
      "id": 1,
      "text": "Miller Place takes its name from the Miller family, whose Andrew Miller bought a 30‑acre plot in 1679.",
      "sourceSentenceIds": [
        4,
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Miller_Place%2C_New_York"
    },
    {
      "id": 2,
      "text": "The first known house in the area dates back to the 1660s, built by Captain John Scott.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Miller_Place%2C_New_York"
    },
    {
      "id": 3,
      "text": "Commercial life once centered on North Country Road, but today Route 25A dominates the hamlet’s main street.",
      "sourceSentenceIds": [
        12
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Miller_Place%2C_New_York"
    },
    {
      "id": 4,
      "text": "Mount Sinai Congregational Church sits on Miller Place’s border, symbolizing the long‑standing link between the two communities.",
      "sourceSentenceIds": [
        8
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Miller_Place%2C_New_York"
    },
    {
      "id": 5,
      "text": "In 2013, former railroad land was turned into a public bicycle trail after an agreement with LIPA.",
      "sourceSentenceIds": [
        23
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Miller_Place%2C_New_York"
    },
    {
      "id": 6,
      "text": "The 1720 William Miller House, one of Long Island’s oldest homes, now serves as a living museum thanks to the Mount Sinai Historical Society.",
