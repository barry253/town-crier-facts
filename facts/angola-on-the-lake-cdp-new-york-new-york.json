  "facts": [
    {
      "id": 1,
      "text": "Angola on the Lake sits on Lake Erie's eastern shore and is part of the Buffalo‑Niagara Falls metropolitan area.",
      "sourceSentenceIds": [
        6,
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Angola_on_the_Lake%2C_New_York"
    },
    {
      "id": 2,
      "text": "In 1855 the federal government moved a post office to the area, naming it “Angola” after the closed Taylor Hollow office.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.villageofangolany.gov/history"
    },
    {
      "id": 3,
      "text": "Long before the railroad, the spot was called Evans Station, a reminder of early train travel through the region.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.villageofangolany.gov/history"
    },
    {
      "id": 4,
      "text": "Angola on the Lake was officially incorporated in 1873 and has continued to prosper ever since.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.villageofangolany.gov/history"
    },
    {
      "id": 5,
      "text": "The hamlet covers roughly one square mile, described by locals as a quaint square mile of friendship and historic treasures.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.villageofangolany.gov/history"
    },
    {
      "id": 6,
      "text": "Its coordinates, 42°39′17″N 79°02′56″W, place it just west of the village of Angola in Erie County.",
