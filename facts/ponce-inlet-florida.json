  "facts": [
    {
      "id": 1,
      "text": "Ponce Inlet’s name comes from the Spanish explorer Ponce de León, whose inlet was once called Mosquito Inlet.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
