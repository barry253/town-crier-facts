  "facts": [
    {
      "id": 1,
      "text": "Homosassa Springs gets its name from a Seminole word meaning either \"river of fishes\" or \"pepper ridge.\"",
      "sourceSentenceIds": [
        17
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Homosassa%2C_Florida"
    },
    {
      "id": 2,
      "text": "A railroad extension reached Homosassa in 1887‑1888, linking it to Dunnellon and opening the town to northern tourists.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.homosassaflorida.com/location/history-facts"
    },
    {
      "id": 3,
      "text": "The 1940s brought a new highway that made motor tourists easier to reach Homosassa, sparking a tourism boom.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.floridavisiting.com/list/homosassa/"
    },
    {
      "id": 4,
      "text": "Water lines arrived in 1957, and soon after a fire station, library, elementary school, and post office were built in the area.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.homosassaflorida.com/location/history-facts"
    },
    {
      "id": 5,
      "text": "The Homosassa Inn, now a private residence owned by the MacRae family, remains a historic landmark in the community.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.homosassaflorida.com/location/history-facts"
    },
    {
      "id": 6,
      "text": "At Homosassa Springs Wildlife State Park, an underwater viewing platform called the \"fish bowl\" lets visitors watch manatees and fish swim in the spring.",
      "sourceSentenceIds": [
