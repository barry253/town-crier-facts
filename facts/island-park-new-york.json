    },
    {
      "id": 2,
      "text": "The area was once called Hog Island, then Barnum Island, before developing into a resort community in the early 1900s.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
