    },
    {
      "id": 3,
      "text": "Native Americans raised hogs on the marshy island, a practice that gave the place its original name, Hog Island, recorded as early as 1665.",
      "sourceSentenceIds": [
        5,
        6
      ],
      "sourceLabels": [
        "Web source 2"
