    },
    {
      "id": 3,
      "text": "The community hosts a train station on the Gladstone Branch of the Morris & Essex Lines, connecting residents to New York Penn Station.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Basking_Ridge%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "In 1912, the Delaware, Lackawanna and Western Railroad built the Basking Ridge station, a historic rail hub still in use today.",
      "sourceSentenceIds": [
        14
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
