  "facts": [
    {
      "id": 1,
      "text": "Salisbury’s name comes from its flat, open terrain that reminded early settlers of England’s Salisbury Plain, home to Stonehenge.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Salisbury%2C_Nassau_County%2C_New_York"
    },
    {
      "id": 2,
      "text": "The town’s roots trace back to the 1770 Jerseyfield Patent, with the area officially forming in 1797 from Palatine.",
      "sourceSentenceIds": [
        24,
        25
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://townofsalisburyny.gov/about/"
    },
    {
      "id": 3,
      "text": "In 1817, Salisbury joined Herkimer County before later becoming part of Montgomery County.",
      "sourceSentenceIds": [
        26
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://townofsalisburyny.gov/about/"
    },
    {
      "id": 4,
      "text": "The Salisbury Historical Society Museum preserves artifacts that chronicle the town’s 18th‑century beginnings.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://mumble.nationalgeographic.com/salisbury-new-york-city"
    },
    {
      "id": 5,
      "text": "Salisbury Cemetery, established in the late 1700s, features intricate headstones that tell the stories of early residents.",
      "sourceSentenceIds": [
        6,
        7
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://mumble.nationalgeographic.com/salisbury-new-york-city"
    },
    {
      "id": 6,
      "text": "Levitt‑style homes line the streets near Eisenhower Park, a former Salisbury Park that reflects the town’s mid‑20th‑century growth.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
