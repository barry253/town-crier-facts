  "facts": [
    {
      "id": 1,
      "text": "Founded by Captains Thomas and John Bell in the early 1800s, Bellport was originally planned as a bustling seaport.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.bellportvillageny.gov/village-info/"
    },
    {
      "id": 2,
      "text": "Bellport became an incorporated village in 1910, formalizing the community that had grown around the Great South Bay.",
      "sourceSentenceIds": [
        29
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bellport%2C_New_York"
    },
    {
      "id": 3,
      "text": "The Gateway Playhouse, a professional summer theater that opened in 1950, remains a cultural staple of Bellport.",
      "sourceSentenceIds": [
        22
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bellport%2C_New_York"
    },
    {
      "id": 4,
      "text": "Bellport takes its name from the Bell family, early settlers who owned much of the area in the 1700s.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Bellport%2C_New_York"
    },
    {
      "id": 5,
      "text": "Strolling Bellport’s quiet roads, visitors see historic homes from the 1800s and enjoy private beaches along the Great South Bay.",
      "sourceSentenceIds": [
