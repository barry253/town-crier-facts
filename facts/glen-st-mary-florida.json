  "facts": [
    {
      "id": 1,
      "text": "In the late 1800s, Ohio developer Alverdo Geitgey bought 12,700 acres and platted Glen St. Mary, naming its streets after U.S. presidents.",
      "sourceSentenceIds": [
        1,
        2
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.florida-backroads-travel.com/glen-st-mary-florida.html"
    },
    {
      "id": 2,
      "text": "After the Civil War, abandoned cotton fields attracted settlers from Georgia and South Carolina, turning the area into a quiet farming community.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.florida-backroads-travel.com/glen-st-mary-florida.html"
    },
    {
      "id": 3,
      "text": "Northern investors from Chicago and elsewhere purchased abandoned cotton fields, reshaping the town’s economy in the post‑war era.",
      "sourceSentenceIds": [
        6
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.florida-backroads-travel.com/glen-st-mary-florida.html"
    },
    {
      "id": 4,
      "text": "The town’s first non‑Native American settlers arrived in the 1800s, establishing the foundations of modern Glen St. Mary.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.florida-backroads-travel.com/glen-st-mary-florida.html"
    },
    {
      "id": 5,
      "text": "Heritage Park Village, just three miles away, showcases restored buildings that illustrate life in early Florida.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
