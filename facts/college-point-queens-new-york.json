  "facts": [
    {
      "id": 1,
      "text": "Conrad Poppenhusen’s Poppenhusen Institute housed the nation’s first free kindergarten, a library, and a museum, making it a 19th‑century educational hub.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.cityneighborhoods.nyc/college-point"
    },
    {
      "id": 2,
      "text": "In 1997 the Queens Historical Society awarded College Point a Queensmark to encourage preservation of its historic architecture.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/College_Point"
    },
    {
      "id": 3,
      "text": "College Point began as a 19th‑century company town centered on Poppenhusen’s rubber factory, a legacy that still gives the area an industrial feel.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://theneighborhoods.substack.com/p/college-point-queens"
    },
    {
      "id": 4,
      "text": "The historic St Agnes Convent on High Street stood for almost two centuries before being demolished by 2022.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/College_Point"
    },
    {
      "id": 5,
      "text": "In 1854 Poppenhusen founded the Poppenhusen India Rubber Company, employing hundreds and shaping the neighborhood’s early economy.",
      "sourceSentenceIds": [
        23
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.cityneighborhoods.nyc/college-point"
    },
    {
      "id": 6,
      "text": "Pepsi’s bottling plant remains one of the few large‑scale factories anchoring College Point today.",
      "sourceSentenceIds": [
        29
