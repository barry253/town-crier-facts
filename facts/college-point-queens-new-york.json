  "facts": [
    {
      "id": 1,
      "text": "Poppenhusen Institute still stands today as a historic landmark, symbolizing philanthropy and progressivism that shaped early College Point.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.cityneighborhoods.nyc/college-point"
    },
    {
      "id": 2,
      "text": "The neighborhood began as a 19th‑century company town centered on Conrad Poppenhusen's rubber factory, and its industrial character endures.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://theneighborhoods.substack.com/p/college-point-queens"
    },
    {
      "id": 3,
      "text": "In 1854, Poppenhusen founded the Poppenhusen India Rubber Company, producing hard rubber goods and employing hundreds of locals.",
      "sourceSentenceIds": [
        23
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.cityneighborhoods.nyc/college-point"
    },
    {
      "id": 4,
      "text": "By the late 19th century, College Point boasted breweries, piano factories, and boatyards lining its waterfront.",
      "sourceSentenceIds": [
        24
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.cityneighborhoods.nyc/college-point"
    },
    {
      "id": 5,
      "text": "Streets in College Point bear the names of early settlers, reflecting a reputation for cleanliness, industriousness, and civic independence.",
      "sourceSentenceIds": [
        25
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.cityneighborhoods.nyc/college-point"
    },
    {
      "id": 6,
      "text": "The German‑born Poppenhusen moved to the U.S. to open a whalebone factory on the banks of the East River.",
