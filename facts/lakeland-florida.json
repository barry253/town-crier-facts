  "facts": [
    {
      "id": 1,
      "text": "Lakeland was founded in 1884 when Abraham Munn platted 80 acres of land in what is now downtown, turning a Kentucky farmer into a city founder.",
      "sourceSentenceIds": [
        6,
        13
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Lakeland%2C_Florida"
    },
    {
      "id": 2,
      "text": "The city’s name comes from the dozens of lakes that surround the area, giving Lakeland its watery nickname.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lakeland%2C_Florida"
    },
    {
      "id": 3,
      "text": "Munn Park, a historic downtown green, hosts festivals and community gatherings, making it the heart of Lakeland’s social life.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://downtownlkld.com/about-downtown/history/"
    },
    {
      "id": 4,
      "text": "The Lakeland History Room, opened in 1987, houses over 7,000 images and offers one‑on‑one research help for local history lovers.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Lakeland%2C_Florida"
    },
    {
      "id": 5,
      "text": "Lakeland Magic, the city’s NBA G League team, plays its home games at the Lakeland Civic Center, a venue that once filmed Prince’s music video.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
