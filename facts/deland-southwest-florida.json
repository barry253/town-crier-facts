  "facts": [
    {
      "id": 1,
      "text": "DeLand Southwest sits in Volusia County, East Central Florida, along the eastern shore of the St. Johns River.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.deland.org/320/History-of-DeLand"
    },
    {
      "id": 2,
      "text": "Volusia County boasts more than 400 years of history, tracing back to early indigenous and colonial eras.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.deland.org/320/History-of-DeLand"
    },
    {
      "id": 3,
      "text": "The landscape once featured high pine meadows, rolling hills, and a narrow strip of fertile hammock along the St. Johns.",
      "sourceSentenceIds": [
        19,
        20
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.deland.org/320/History-of-DeLand"
    },
    {
      "id": 4,
      "text": "Early Native Americans, Spanish explorers, French colonists, and English settlers all left their mark on Florida’s history.",
      "sourceSentenceIds": [
        21
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.deland.org/320/History-of-DeLand"
    },
    {
      "id": 5,
      "text": "Ruben Marsh, a scout during the Seminole Indian War, became the first settler in the area, arriving in 1846.",
      "sourceSentenceIds": [
        24,
        25,
        26,
        27,
        28
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.deland.org/320/History-of-DeLand"
    },
    {
      "id": 6,
      "text": "After the war, Marsh built a cabin, raised cattle, and exemplified the self‑sufficient pioneer spirit of early DeLand.",
      "sourceSentenceIds": [
