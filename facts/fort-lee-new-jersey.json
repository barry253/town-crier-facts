  "facts": [
    {
      "id": 1,
      "text": "Fort Lee was named for General Charles Lee after George Washington’s troops camped at Mount Constitution during the Revolutionary War.",
      "sourceSentenceIds": [
        2,
        10
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Fort_Lee%2C_New_Jersey"
    },
    {
      "id": 2,
      "text": "Fort Lee is considered the birthplace of the American film industry, where early studios filmed before Hollywood’s rise in the 1930s.",
      "sourceSentenceIds": [
        4,
        20
      ],
      "sourceLabels": [
        "Web source 1",
        "Wikipedia"
      ],
      "source": "https://www.fortleenj.org/279/All-About-Fort-Lee"
    },
    {
      "id": 3,
      "text": "The George Washington Bridge, the world’s busiest motor vehicle bridge, connects Fort Lee to Manhattan across the Hudson River.",
      "sourceSentenceIds": [
        13,
        15
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Fort_Lee%2C_New_Jersey"
    },
    {
      "id": 4,
      "text": "Fort Lee Historic Park preserves the Revolutionary War encampment where Washington’s troops camped and where Thomas Paine penned The American Crisis.",
      "sourceSentenceIds": [
        19,
        26
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 2"
      ],
      "source": "https://en.wikipedia.org/wiki/Fort_Lee%2C_New_Jersey"
    },
    {
      "id": 5,
      "text": "Fort Lee lies on the Washington‑Rochambeau Revolutionary Route, a National Historic Trail that follows Washington and Rochambeau’s march to New York.",
