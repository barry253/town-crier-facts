  "facts": [
    {
      "id": 1,
      "text": "Pittsford village, the oldest incorporated village in New York, was founded in 1827 and sits on the historic Erie Canal.",
      "sourceSentenceIds": [
        28,
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Pittsford_(village)%2C_New_York"
    },
    {
      "id": 2,
      "text": "The town of Pittsford, surrounding the village, was established in 1789 and was originally called Northfield.",
      "sourceSentenceIds": [
        2
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Pittsford_(village)%2C_New_York"
    },
    {
      "id": 3,
      "text": "Pittsford’s waterfront charm comes from canal warehouses, mills, and silos that have been repurposed into boutiques and restaurants.",
      "sourceSentenceIds": [
        10,
        16
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Pittsford_(village)%2C_New_York"
    },
    {
      "id": 4,
      "text": "Historic Pittsford, a grassroots preservation group, has championed the village for thirty‑five years, securing grants and historic designations.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.villageofpittsfordny.gov/village-introduction"
    },
    {
      "id": 5,
      "text": "The settlement once housed the county’s first school, library, church, post office, and newspaper, all established between 1794 and 1815.",
      "sourceSentenceIds": [
        23,
        24
      ],
      "sourceLabels": [
        "Wikipedia",
        "Web source 1"
      ],
      "source": "https://en.wikipedia.org/wiki/Pittsford_(village)%2C_New_York"
    },
    {
      "id": 6,
      "text": "Pittsford Farms, the oldest of three village estates, was founded in the 1860s by canal contractor Jarvis Lord and remains a 200‑acre working farm.",
