  "facts": [
    {
      "id": 1,
      "text": "Retsof earned its quirky name when founder William Foster Jr. flipped his own name to create the town’s unique identity.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Retsof%2C_New_York"
    },
    {
      "id": 2,
      "text": "In 1994, the Retsof Salt Mine, once North America’s largest, collapsed after groundwater flooded its 1,000‑foot‑deep chambers.",
      "sourceSentenceIds": [
        16,
        17,
        18
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Retsof%2C_New_York"
    },
    {
      "id": 3,
      "text": "The Genesee & Wyoming Railroad once hauled salt from Retsof to neighboring main lines, and its tracks still echo the town’s mining past.",
      "sourceSentenceIds": [
        2,
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Retsof%2C_New_York"
    },
    {
      "id": 4,
      "text": "Retsof sits about 30 miles southwest of Rochester, just off New York State Route 63 near Route 36.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Retsof%2C_New_York"
    },
    {
      "id": 5,
      "text": "Water from Retsof drains into Salt Creek, a northward‑flowing tributary that eventually feeds the Genesee River.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Retsof%2C_New_York"
    },
    {
      "id": 6,
      "text": "The Livingston County Historical Society Museum preserves artifacts from the Retsof Mine Collapse, telling the story of the town’s underground legacy.",
      "sourceSentenceIds": [
        4
