  "facts": [
    {
      "id": 1,
      "text": "Whitestone’s name comes from a 17th‑century white limestone boulder once visible on the shoreline, a landmark for early settlers.",
      "sourceSentenceIds": [
        15,
        27
      ],
      "sourceLabels": [
        "Web source 1",
        "Web source 2"
      ],
      "source": "https://www.cityneighborhoods.nyc/whitestone"
    },
    {
      "id": 2,
      "text": "Originally part of the Town of Flushing, Whitestone evolved from an agrarian settlement into a suburban borough of Queens.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.cityneighborhoods.nyc/whitestone"
    },
    {
      "id": 3,
      "text": "A Whitestone line station opened where 11th Avenue is today, but it closed in 1932 after decades of service.",
      "sourceSentenceIds": [
        9,
        10
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://urbanareas.net/info/resources/neighborhoods-queens/whitestone-queens-history/"
    },
    {
      "id": 4,
      "text": "The Whitestone Hebrew Centre, founded in 1929, occupies two buildings on Clintonville Street and serves the local Jewish community.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Whitestone%2C_Queens"
    },
    {
      "id": 5,
      "text": "Whitestone Shopping Center opened in the 1960s and became the neighborhood’s commercial anchor, drawing shoppers from across Queens.",
      "sourceSentenceIds": [
        16
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.cityneighborhoods.nyc/whitestone"
    },
    {
      "id": 6,
      "text": "Jane Champ Park, a triangle by Malba Drive and 11th Avenue, was dedicated in 1969 and renovated in 2005 by the local club.",
      "sourceSentenceIds": [
