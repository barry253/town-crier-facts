    },
    {
      "id": 2,
      "text": "From the 1920s through the 1970s, Kauneonga Lake was a centerpiece of the Catskills Borscht Belt, drawing New York City vacationers.",
      "sourceSentenceIds": [
        11
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://grokipedia.com/page/kauneonga_lake_new_york"
    },
    {
      "id": 3,
      "text": "The Kenmore Hotel, a four‑story landmark built in the early 1900s, stood on Kauneonga Lake until it closed in the 1970s.",
      "sourceSentenceIds": [
        23
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://borschtbelthistoricalmarkerproject.org/bethel%2Fkauneonga-lake"
    },
    {
      "id": 4,
      "text": "The Fur Workers Resort, an interracial hotel, hosted cultural programs before becoming the Jewish summer camp Camp Hi‑Li.",
      "sourceSentenceIds": [
        16,
        17
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://borschtbelthistoricalmarkerproject.org/bethel%2Fkauneonga-lake"
    },
    {
      "id": 5,
      "text": "Forestview Lodge in Kauneonga Lake served the African American community during the mid‑20th century.",
