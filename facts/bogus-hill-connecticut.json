  "facts": [
    {
      "id": 1,
      "text": "Bogus Hill sits on a peninsula in Candlewood Lake, the largest lake in Connecticut, offering residents private sandy beaches and boat docks.",
      "sourceSentenceIds": [
        13,
        14
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/bogus_hill_connecticut"
    },
    {
      "id": 2,
      "text": "The community’s name appears in local records by the early 20th century, but its origin remains undocumented.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/bogus_hill_connecticut"
    },
    {
      "id": 3,
      "text": "In 1724, twelve settlers from Fairfield negotiated land from the Schaghticoke tribe, eventually acquiring the tract that includes Bogus Hill.",
      "sourceSentenceIds": [
        24,
        25
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/bogus_hill_connecticut"
    },
    {
      "id": 4,
      "text": "The 2005 dispute over road maintenance and drainage highlighted growing residential pressure on the peninsula’s infrastructure.",
      "sourceSentenceIds": [
        10
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://grokipedia.com/page/bogus_hill_connecticut"
    },
    {
      "id": 5,
      "text": "The Historic Harden House Museum, located in nearby Harrybrooke Park, opens to visitors and offers a glimpse into local history.",
      "sourceSentenceIds": [
        8,
        9
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.komoot.com/guide/1968422/attractions-around-bogus-hill"
    },
    {
      "id": 6,
      "text": "Bogus Hill’s elevation creates a narrow, water‑surrounded landform where over 40% of the area is water, giving it a secluded lakeside character.",
