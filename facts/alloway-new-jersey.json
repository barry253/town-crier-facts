  "facts": [
    {
      "id": 1,
      "text": "Alloway Township’s name comes from the Lenni Lenape chief Allowas, reflecting the area’s Native American roots.",
      "sourceSentenceIds": [
        4,
        24
      ],
      "sourceLabels": [
        "Web source 1",
        "Wikipedia"
      ],
      "source": "https://visitingamuseum.com/2024/12/15/alloway-township-history-museum-49-greenwich-street-room-216-alloway-nj-08001/"
    },
    {
      "id": 2,
      "text": "The town’s history museum, housed in the former municipal building at 49 South Greenwich Street, opened its doors in 2024.",
      "sourceSentenceIds": [
        5,
        6
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://visitingamuseum.com/2024/12/15/alloway-township-history-museum-49-greenwich-street-room-216-alloway-nj-08001/"
    },
    {
      "id": 3,
      "text": "The museum’s exhibit recreates an early classroom, complete with historic school desks and lunch boxes from the 1970s.",
      "sourceSentenceIds": [
        8,
        13
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://visitingamuseum.com/2024/12/15/alloway-township-history-museum-49-greenwich-street-room-216-alloway-nj-08001/"
    },
    {
      "id": 4,
      "text": "Alloway’s architecture includes over a hundred patterned‑end houses built between 1720 and 1760, a hallmark of early colonial design.",
      "sourceSentenceIds": [
        18
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.livingplaces.com/NJ/Salem_County/Alloway_Township.html"
    },
    {
      "id": 5,
      "text": "The township’s municipal building, now a museum, once served as the community’s civic heart, hosting town meetings and local events for centuries.",
      "sourceSentenceIds": [
        12,
        14
      ],
      "sourceLabels": [
        "Web source 1"
      ],
