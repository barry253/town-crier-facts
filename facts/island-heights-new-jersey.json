  "facts": [
    {
      "id": 1,
      "text": "Island Heights began as a Methodist camp meeting resort in 1878, preserving a highly intact community of mostly residential buildings.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://petomuseum.org/island-heights-history/"
    },
    {
      "id": 2,
      "text": "The borough sits on the north side of the Toms River, right at the mouth of Barnegat Bay.",
      "sourceSentenceIds": [
        29
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://petomuseum.org/island-heights-history/"
    },
    {
      "id": 3,
      "text": "Island House Hotel, built on the waterfront in 1880, welcomed visitors arriving by train from Philadelphia.",
      "sourceSentenceIds": [
        30
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://petomuseum.org/island-heights-history/"
    },
    {
      "id": 4,
      "text": "Alcohol sales are forbidden in Island Heights and within 1½ miles of the camp meeting grounds, a rule rooted in its Methodist heritage.",
      "sourceSentenceIds": [
        4
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.livingplaces.com/NJ/Ocean_County/Island_Heights_Borough/Island_Heights_Historic_District.html"
    },
    {
      "id": 5,
      "text": "The borough’s name honors the small island that once formed part of the original land patent granted to John Johnston in 1690.",
      "sourceSentenceIds": [
        29
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://petomuseum.org/island-heights-history/"
    },
    {
      "id": 6,
      "text": "Island Heights’ historic district includes 375 structures, most built within 25 years of its founding, showcasing Victorian and colonial architecture.",
      "sourceSentenceIds": [
        28
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.livingplaces.com/NJ/Ocean_County/Island_Heights_Borough/Island_Heights_Historic_District.html"
