  "facts": [
    {
      "id": 1,
      "text": "Roebling began as the Kinkora Works of the Roebling Company, a 160‑acre steel factory built in 1905 that included a planned employee town.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.nj.gov/dca/njht/funded/sitedetails/roebling_kinkora.shtml"
    },
    {
      "id": 2,
      "text": "The Roebling Steel Mill produced the wire rope for the George Washington Bridge and the Golden Gate Bridge.",
      "sourceSentenceIds": [
        13
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.nj.gov/dca/njht/funded/sitedetails/roebling_kinkora.shtml"
    },
    {
      "id": 3,
      "text": "In 2009 the Roebling Museum opened on the historic mill grounds, offering a video documentary and exhibits about the town’s industrial life.",
      "sourceSentenceIds": [
        15,
        7,
        8
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://njhistoryandsites.org/2026/01/25/roebling-museum-in-roebling-new-jersey/"
    },
    {
      "id": 4,
      "text": "The Roebling Historic District spans 76 acres and was added to the National Register of Historic Places in 1978 for its industrial and immigrant heritage.",
      "sourceSentenceIds": [
        9,
        10
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Roebling%2C_New_Jersey"
    },
    {
      "id": 5,
      "text": "The company’s original factory complex once employed 8,000 workers at its peak, making it a major employer in the early 20th century.",
      "sourceSentenceIds": [
        5
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://njhistoryandsites.org/2026/01/25/roebling-museum-in-roebling-new-jersey/"
    },
    {
      "id": 6,
      "text": "The town’s name honors John A. Roebling, the bridge engineer whose family founded the company that built the Brooklyn Bridge.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
