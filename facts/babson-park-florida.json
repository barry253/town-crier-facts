  "facts": [
    {
      "id": 1,
      "text": "Roger Babson, a noted economist, founded Babson Park in the early 1900s, championing health, wellness, and education.",
      "sourceSentenceIds": [
        1
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.floridasmart.com/city-guide/babson-park"
    },
    {
      "id": 2,
      "text": "In 1927, Babson and his wife Grace founded Webber International University, one of the nation’s oldest business colleges.",
      "sourceSentenceIds": [
        2,
        4
      ],
      "sourceLabels": [
        "Web source 1"
      ],
      "source": "https://www.floridasmart.com/city-guide/babson-park"
    },
    {
      "id": 3,
      "text": "The community was renamed from Crooked Lake to Babson Park in honor of its founder.",
      "sourceSentenceIds": [
        3
      ],
      "sourceLabels": [
        "Wikipedia"
      ],
      "source": "https://en.wikipedia.org/wiki/Babson_Park%2C_Florida"
    },
    {
      "id": 4,
      "text": "Webber International University began as a women’s college dedicated to teaching business to women.",
      "sourceSentenceIds": [
        7
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.florida-backroads-travel.com/babson-park-florida.html"
    },
    {
      "id": 5,
      "text": "Hillcrest Lodge, built in 1917 on the south edge of Babson Park, was originally the Lakeside Club on Crooked Lake.",
      "sourceSentenceIds": [
        8,
        9
      ],
      "sourceLabels": [
        "Web source 2"
      ],
      "source": "https://www.florida-backroads-travel.com/babson-park-florida.html"
